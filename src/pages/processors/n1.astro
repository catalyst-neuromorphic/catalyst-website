---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Catalyst N1 — First Generation Neuromorphic Processor" description="128-core neuromorphic processor with full Loihi 1 parity. The foundation of the Catalyst platform.">

  <!-- Banner -->
  <div class="pt-16 text-center py-3 banner-bar">
    <a href="/processors/n2" class="text-sm text-catalyst-blue/70 hover:text-catalyst-blue transition-colors no-underline">
      Looking for the latest? Catalyst N2 &rarr;
    </a>
  </div>

  <!-- HERO -->
  <section class="hero-section py-32 flex flex-col items-center justify-center text-center px-6">
    <div class="reveal w-[240px] md:w-[320px] mb-8">
      <img src="/images/renders/n1-top.webp" alt="Catalyst N1 processor die shot" class="w-full h-auto rounded-xl chip-glow-subtle" loading="eager" />
    </div>
    <p class="text-[11px] uppercase tracking-widest text-white/30 mb-4">First Generation</p>
    <h1 class="text-[clamp(4rem,8vw,7rem)] font-bold tracking-tighter leading-none">N1</h1>
    <p class="text-[clamp(1rem,1.5vw,1.35rem)] text-white/40 mt-4">Where it all began.</p>
    <div class="flex items-center gap-4 mt-8">
      <a href="/papers/catalyst-n1.pdf" class="btn-primary" target="_blank">Read the paper</a>
      <a href="mailto:henry@catalyst-neuromorphic.com" class="btn-pill">Enquire</a>
    </div>
  </section>

  <!-- WHAT N1 IS -->
  <section class="py-32 px-6 md:px-12">
    <div class="max-w-[800px] mx-auto text-center">
      <h2 class="reveal text-[clamp(2rem,3.5vw,3rem)] font-bold tracking-tight">128 cores. Full Loihi 1 parity.</h2>
      <p class="reveal text-lg text-white/40 mt-6 leading-relaxed max-w-[600px] mx-auto">
        The Catalyst N1 is a 128-core spiking neuromorphic processor with complete parity to Intel's first-generation Loihi chip. Each core contains 1,024 neurons, 131K synapses, and a programmable learning engine with a 14-opcode ISA.
      </p>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="py-20 px-6 md:px-12">
    <div class="max-w-[900px] mx-auto grid grid-cols-1 sm:grid-cols-3 gap-6 reveal-stagger">
      {[
        { title: 'Dendritic trees', desc: 'Four compartments per neuron for spatial computation and signal processing.' },
        { title: 'Graded spikes', desc: 'Eight-bit payload per spike for analog-like signalling between neurons.' },
        { title: 'On-chip learning', desc: 'Programmable plasticity rules with a 14-opcode microcode engine.' },
      ].map(feat => (
        <div class="glass p-8 text-center">
          <h3 class="text-lg font-semibold mb-2">{feat.title}</h3>
          <p class="text-sm text-white/40">{feat.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- N1 → N2 EVOLUTION -->
  <section class="py-32 px-6 md:px-12">
    <div class="max-w-[900px] mx-auto">
      <h2 class="reveal text-center text-[clamp(2rem,3.5vw,3rem)] font-bold tracking-tight mb-16">From N1 to N2.</h2>
      <div class="space-y-4 reveal-stagger">
        {[
          { n1: '1 neuron model (LIF)', n2: '5 neuron models' },
          { n1: '14-opcode learning ISA', n2: '16-register programmable microcode engine' },
          { n1: 'Simulation only', n2: 'Real FPGA hardware validation (28/28)' },
          { n1: '96 tests', n2: '3,091 tests' },
          { n1: 'Loihi 1 parity', n2: 'Loihi 2 parity' },
        ].map((item) => (
          <div class="glass p-5 flex items-center gap-6">
            <span class="text-white/25 text-sm w-56 shrink-0">{item.n1}</span>
            <span class="text-white/15 text-lg">&rarr;</span>
            <span class="text-sm font-semibold text-white/80">{item.n2}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SPECS -->
  <section class="py-32 px-6 md:px-12">
    <div class="max-w-[700px] mx-auto">
      <h2 class="reveal text-center text-2xl font-bold tracking-tight mb-12">Technical Specifications</h2>
      <div class="reveal space-y-0">
        {[
          ['Cores', '128'],
          ['Neurons per core', '1,024 (LIF)'],
          ['Total neurons', '131,072'],
          ['Synapses per core', '131,072 (CSR format)'],
          ['Learning ISA', '14 opcodes, STDP'],
          ['Axonal delays', '1\u201363 timesteps'],
          ['Graded spikes', '8-bit payload'],
          ['Dendrites', '4 compartments'],
          ['SHD benchmark', '85.9% (float) / 85.4% (quantized)'],
          ['Tests passing', '96'],
          ['Parity target', 'Intel Loihi 1'],
          ['Patent', 'UK patent filed (Feb 2026)'],
        ].map(([label, value]) => (
          <div class="spec-row-n1"><span>{label}</span><span>{value}</span></div>
        ))}
      </div>
    </div>
  </section>

  <!-- PAPER -->
  <section class="py-20 px-6 md:px-12 text-center">
    <div class="glass max-w-[500px] mx-auto p-10 reveal">
      <h3 class="text-xl font-semibold mb-2">Read the N1 paper</h3>
      <p class="text-sm text-white/40 mb-2">13 pages. Architecture, instruction set, SDK, benchmarks.</p>
      <p class="text-xs text-white/25 font-mono mb-6">DOI: 10.5281/zenodo.18727094</p>
      <a href="/papers/catalyst-n1.pdf" class="btn-pill" target="_blank">View PDF</a>
    </div>
  </section>

  <!-- ENQUIRE -->
  <section class="py-32 px-6 md:px-12">
    <div class="max-w-[600px] mx-auto text-center">
      <div class="glass-accent p-12 reveal">
        <h2 class="text-2xl font-bold tracking-tight mb-4">Interested in N1?</h2>
        <p class="text-white/40 leading-relaxed mb-8">Licensing and research enquiries.</p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="mailto:henry@catalyst-neuromorphic.com" class="btn-primary">Enquire</a>
          <a href="/processors/n2" class="btn-pill">See what's next: N2 &rarr;</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .banner-bar { background: rgba(59,130,246,0.06); border-bottom: 1px solid rgba(59,130,246,0.1); }
  .chip-glow-subtle {
    filter: drop-shadow(0 0 40px rgba(255,255,255,0.05));
  }
  .spec-row-n1 {
    display: flex;
    justify-content: space-between;
    padding: 0.75rem 0;
    font-size: 0.875rem;
    border-top: 1px solid rgba(255,255,255,0.05);
  }
  .spec-row-n1:last-child { border-bottom: 1px solid rgba(255,255,255,0.05); }
  .spec-row-n1 span:first-child { color: rgba(255,255,255,0.35); }
  .spec-row-n1 span:last-child { color: rgba(255,255,255,0.6); }
</style>
