<!-- ═══ CHIP WALKTHROUGH ═══ -->
<section class="walkthrough" id="architecture">
  <div class="walkthrough-sticky">
    <div class="wt-text">
      <!-- Step 0: Core Mesh -->
      <div class="wt-step active" data-step="0">
        <p class="wt-step-eyebrow">128-Core Mesh</p>
        <h2>Massively parallel<br>spike processing.</h2>
        <p>128 neuromorphic cores arranged in an 8&times;16 mesh network. Each core processes 1,024 neurons independently, communicating through barrier-synchronized spike routing.</p>
      </div>
      <!-- Step 1: Neuron Models -->
      <div class="wt-step" data-step="1">
        <p class="wt-step-eyebrow">Neuron Array</p>
        <h2>Five programmable<br>neuron models.</h2>
        <p>CUBA LIF, Izhikevich, ALIF, Sigma-Delta, and Resonate-and-Fire. Each model runs on a fully programmable microcode engine with 16 general-purpose registers and 256 instructions.</p>
      </div>
      <!-- Step 2: Learning Engine -->
      <div class="wt-step" data-step="2">
        <p class="wt-step-eyebrow">Learning Engine</p>
        <h2>On-chip learning<br>that adapts.</h2>
        <p>3-factor STDP with 5 eligibility traces, persistent reward signals, and homeostatic threshold regulation. Per-group plasticity enables independent learning rules across synapse populations.</p>
      </div>
      <!-- Step 3: Synapse Memory -->
      <div class="wt-step" data-step="3">
        <p class="wt-step-eyebrow">Synapse Memory</p>
        <h2>Variable-precision<br>weight storage.</h2>
        <p>1, 2, 4, 8, or 16-bit weights with barrel shifter decompression. Convolutional shared kernels for efficient spatial pattern detection. 131,072 synapses per core in compressed sparse row format.</p>
      </div>
      <!-- Step 4: Mesh Network -->
      <div class="wt-step" data-step="4">
        <p class="wt-step-eyebrow">Mesh Interconnect</p>
        <h2>Hierarchical<br>spike routing.</h2>
        <p>Barrier-synchronized mesh network with binary, 8-bit, 16-bit, and 24-bit spike payloads. Configurable axonal delays from 1 to 63 timesteps per synapse.</p>
      </div>
      <!-- Step 5: Full Die -->
      <div class="wt-step" data-step="5">
        <p class="wt-step-eyebrow">Full Die</p>
        <h2>All of this.<br>~20 watts.</h2>
        <p>A complete neuromorphic processor that matches Intel Loihi 2's feature set while remaining fully open for research and deployment through the Catalyst Cloud API.</p>
      </div>
    </div>
    <div class="wt-chip">
      <ChipFloorplan chip="n2" showLabels={true} class="chip-wt" />
    </div>
    <div class="wt-dots">
      {Array.from({ length: 6 }).map((_, i) => (
        <div class:list={['wt-dot', { active: i === 0 }]} data-dot={i}></div>
      ))}
