---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Catalyst N2 — Second Generation Neuromorphic Processor" description="128-core neuromorphic processor with full Loihi 2 parity. Five neuron models, on-chip learning, hardware validated.">

  <!-- STICKY SUB-NAV -->
  <nav id="sub-nav" class="fixed top-14 left-0 right-0 z-40 h-10 opacity-0 transition-all duration-300 pointer-events-none" style="background: rgba(10,12,16,0.85); backdrop-filter: blur(20px); border-bottom: 1px solid rgba(255,255,255,0.04);">
    <div class="max-w-[1200px] mx-auto h-full flex items-center gap-6 px-6 md:px-12 overflow-x-auto">
      {['Overview', 'Architecture', 'Neuron Models', 'Learning', 'Comparison', 'Specs', 'Paper'].map((label) => (
        <a href={`#${label.toLowerCase().replace(/\s+/g, '-')}`} class="sub-nav-link text-xs text-white/30 no-underline hover:text-white/60 transition-colors whitespace-nowrap">{label}</a>
      ))}
    </div>
  </nav>

  <!-- HERO -->
  <section id="overview" class="hero-section min-h-screen flex flex-col items-center justify-center text-center relative px-6">
    <div class="reveal w-[280px] md:w-[360px] lg:w-[420px] mb-8">
      <img src="/images/renders/n2-angled.webp" alt="Catalyst N2 processor die shot" class="w-full h-auto chip-glow" loading="eager" />
    </div>
    <h1 class="text-[clamp(4rem,8vw,8rem)] font-bold tracking-tighter leading-none">N2</h1>
    <p class="text-[clamp(1rem,1.5vw,1.35rem)] text-white/40 mt-4 max-w-[480px]">Second generation. Full Loihi 2 parity. 128 cores, 131,072 neurons, 5 neuron models.</p>
    <div class="flex items-center gap-4 mt-8">
      <a href="/papers/catalyst-n2.pdf" class="btn-primary" target="_blank">Read the paper</a>
      <a href="#specs" class="btn-pill">View specs</a>
    </div>
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 w-6 h-10 rounded-xl border border-white/15 flex justify-center pt-2 max-md:hidden">
      <span class="w-[3px] h-2 rounded-full bg-white/30 animate-bounce"></span>
    </div>
  </section>

  <!-- CHIP ZOOM ANIMATION -->
  <section id="architecture" class="relative" style="height: 500vh;">
    <div class="sticky top-0 h-screen flex items-center justify-center overflow-hidden">
      <div class="relative w-[80vmin] h-[80vmin] max-w-[600px] max-h-[600px]" style="perspective: 1200px;">

        <!-- Level 1: Transistors -->
        <div class="zoom-level absolute inset-0 flex flex-col items-center justify-center" id="zoom-1">
          <div class="w-48 h-48 rounded-2xl p-4 grid grid-cols-8 grid-rows-8 gap-px transistor-grid">
            {Array.from({length: 64}).map(() => (
              <div class="rounded-sm bg-catalyst-blue/10"></div>
            ))}
          </div>
          <p class="text-xl font-semibold mt-8 tracking-tight">Individual transistors.</p>
          <p class="text-sm text-white/40 mt-2">Billions of switches.</p>
        </div>

        <!-- Level 2: Logic Gates -->
        <div class="zoom-level absolute inset-0 flex flex-col items-center justify-center opacity-0" id="zoom-2">
          <div class="w-56 h-56 rounded-2xl p-6 flex flex-wrap gap-2 items-center justify-center gate-box">
            {Array.from({length: 12}).map(() => (
              <div class="w-10 h-10 rounded-lg flex items-center justify-center text-[10px] text-white/30 font-mono gate-cell">AND</div>
            ))}
          </div>
          <p class="text-xl font-semibold mt-8 tracking-tight">Logic gates.</p>
          <p class="text-sm text-white/40 mt-2">The building blocks.</p>
        </div>

        <!-- Level 3: Single Core -->
        <div class="zoom-level absolute inset-0 flex flex-col items-center justify-center opacity-0" id="zoom-3">
          <div class="w-64 h-64 rounded-2xl p-5 grid grid-cols-2 grid-rows-2 gap-3 core-box">
            <div class="rounded-xl flex flex-col items-center justify-center core-cell">
              <span class="text-xs font-semibold text-white/50">Neurons</span>
              <span class="text-[10px] text-white/25 mt-1">1,024</span>
            </div>
            <div class="rounded-xl flex flex-col items-center justify-center core-cell">
              <span class="text-xs font-semibold text-white/50">Synapses</span>
              <span class="text-[10px] text-white/25 mt-1">131K</span>
            </div>
            <div class="rounded-xl flex flex-col items-center justify-center core-cell">
              <span class="text-xs font-semibold text-white/50">Learning</span>
              <span class="text-[10px] text-white/25 mt-1">On-chip</span>
            </div>
            <div class="rounded-xl flex flex-col items-center justify-center core-cell">
              <span class="text-xs font-semibold text-white/50">Models</span>
              <span class="text-[10px] text-white/25 mt-1">5 types</span>
            </div>
          </div>
          <p class="text-xl font-semibold mt-8 tracking-tight">One core. 1,024 spiking neurons.</p>
          <p class="text-sm text-white/40 mt-2">Five neuron models. Programmable everything.</p>
        </div>

        <!-- Level 4: Core Mesh -->
        <div class="zoom-level absolute inset-0 flex flex-col items-center justify-center opacity-0" id="zoom-4">
          <div class="w-72 h-72 rounded-2xl p-4 grid grid-cols-8 grid-rows-8 gap-1 mesh-grid">
            {Array.from({length: 64}).map((_, i) => (
              <div class={`rounded-md ${i < 16 ? "core-active" : "core-dim"}`}></div>
            ))}
          </div>
          <p class="text-xl font-semibold mt-8 tracking-tight">128 cores. One mesh network.</p>
          <p class="text-sm text-white/40 mt-2">Every core communicates. Every spike arrives.</p>
        </div>

        <!-- Level 5: Full Die (real render) -->
        <div class="zoom-level absolute inset-0 flex flex-col items-center justify-center opacity-0" id="zoom-5">
          <div class="w-80 h-80 rounded-3xl overflow-hidden">
            <img src="/images/renders/n2-top.webp" alt="N2 full die" class="w-full h-full object-cover chip-glow" />
          </div>
          <p class="text-2xl font-bold mt-8 tracking-tight">Catalyst N2.</p>
          <p class="text-sm text-white/40 mt-2">131,072 neurons. UK patent filed.</p>
        </div>
      </div>

      <!-- Scroll dots -->
      <div class="absolute right-8 top-1/2 -translate-y-1/2 flex flex-col gap-2 max-md:hidden">
        {['Transistor', 'Gate', 'Core', 'Mesh', 'Die'].map((label, i) => (
          <div class="flex items-center gap-2">
            <span class={`zoom-dot w-2 h-2 rounded-full transition-all duration-300 ${i === 0 ? "bg-catalyst-blue" : "bg-white/15"}`} data-level={i + 1}></span>
            <span class="text-[10px] text-white/20">{label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HIGHLIGHTS STRIP -->
  <section class="py-20 px-6 md:px-12">
    <div class="max-w-[1100px] mx-auto grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-6 reveal-stagger">
      {[
        { stat: '5', label: 'Neuron models' },
        { stat: '3-factor', label: 'On-chip learning' },
        { stat: '1000x', label: 'More efficient' },
        { stat: '3', label: 'Dev backends' },
        { stat: '28/28', label: 'FPGA validated' },
      ].map((item) => (
        <div class="text-center py-6">
          <div class="text-lg font-bold text-catalyst-blue">{item.stat}</div>
          <div class="text-sm text-white/40 mt-1">{item.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- EFFICIENCY -->
  <section class="py-40 px-6 md:px-12">
    <div class="max-w-[800px] mx-auto text-center">
      <h2 class="reveal text-[clamp(2.5rem,5vw,4rem)] font-bold tracking-tight">1000x more efficient.</h2>
      <p class="reveal text-lg text-white/40 mt-6 leading-relaxed max-w-[600px] mx-auto">
        N2 only computes when something happens. No event, no energy. While GPUs burn through billions of operations every cycle, N2 sits silent until a spike arrives &mdash; then responds in microseconds.
      </p>
      <div class="reveal mt-16 max-w-[500px] mx-auto grid grid-cols-2 gap-8 text-center">
        <div class="glass p-8">
          <div class="text-2xl font-bold text-white/20 mb-2">GPU</div>
          <p class="text-xs text-white/20 leading-relaxed">Always on. Every cycle computes whether it needs to or not.</p>
        </div>
        <div class="glass p-8" style="border-color: rgba(59,130,246,0.15);">
          <div class="text-2xl font-bold text-catalyst-blue/50 mb-2">N2</div>
          <p class="text-xs text-catalyst-blue/40 leading-relaxed">Event-driven. No spike, no computation, no energy.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- NEURON MODELS -->
  <section id="neuron-models" class="py-40 px-6 md:px-12">
    <div class="max-w-[1000px] mx-auto text-center">
      <h2 class="reveal text-[clamp(2.5rem,5vw,4rem)] font-bold tracking-tight">Five ways to think.</h2>
      <p class="reveal text-lg text-white/40 mt-6 leading-relaxed max-w-[600px] mx-auto">
        N2 supports five distinct neuron models, each optimised for different types of computation. Choose the right model for your application, or mix them within a single network.
      </p>
      <div class="mt-16 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 reveal-stagger">
        {[
          { name: 'CUBA LIF', desc: 'Current-based leaky integrate-and-fire. Configurable membrane time constant, 8-bit weights, threshold and reset dynamics.', tag: 'Default' },
          { name: 'Izhikevich', desc: '4 parameters (a,b,c,d) produce rich dynamics: regular spiking, chattering, bursting, fast spiking, and more.', tag: 'Complex' },
          { name: 'ALIF', desc: 'Adaptive threshold with configurable time constant. Intrinsic plasticity and homeostatic regulation.', tag: 'Adaptive' },
          { name: 'Sigma-Delta', desc: 'Graded output. Rate-coded. Bridges spiking and analog computation domains.', tag: 'Graded' },
          { name: 'Resonate-and-Fire', desc: 'Complex-valued state. Frequency-selective. Tuned to detect temporal patterns in spike trains.', tag: 'Resonant' },
        ].map((model) => (
          <div class="glass p-6 text-left">
            <div class="flex items-center justify-between mb-3">
              <h3 class="text-sm font-semibold text-white/90">{model.name}</h3>
              <span class="text-[9px] text-catalyst-blue/60 border border-catalyst-blue/20 rounded-full px-2 py-0.5">{model.tag}</span>
            </div>
            <p class="text-xs text-white/40 leading-relaxed">{model.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LEARNING -->
  <section id="learning" class="py-40 px-6 md:px-12">
    <div class="max-w-[1200px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
      <div class="reveal">
        <div class="glass p-6">
          <svg id="stdpSvg" viewBox="0 0 460 280" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
            <line x1="60" y1="140" x2="440" y2="140" stroke="rgba(255,255,255,0.1)" stroke-width="0.5"/>
            <line x1="230" y1="20" x2="230" y2="260" stroke="rgba(255,255,255,0.1)" stroke-width="0.5"/>
            <text x="340" y="60" fill="rgba(59,130,246,0.7)" font-size="12" font-weight="600" font-family="Space Grotesk">Strengthen</text>
            <text x="80" y="230" fill="rgba(239,68,68,0.5)" font-size="12" font-weight="600" font-family="Space Grotesk">Weaken</text>
            <text x="230" y="275" text-anchor="middle" fill="rgba(255,255,255,0.15)" font-size="9" font-family="Space Grotesk">Connections adapt based on timing, activity, and reward</text>
            <g id="stdpCurves"></g>
          </svg>
        </div>
      </div>
      <div class="reveal">
        <h2 class="text-[clamp(2rem,3.5vw,3rem)] font-bold tracking-tight leading-tight">It learns while it runs.</h2>
        <p class="text-lg text-white/40 mt-6 leading-relaxed">
          N2 doesn't need to be retrained in the cloud. It learns in real time, on-chip, using the same mechanism your brain uses &mdash; strengthening connections that matter, weakening ones that don't.
        </p>
        <p class="text-lg text-white/40 mt-4 leading-relaxed">
          A fully programmable microcode engine with 16 general-purpose registers lets you define custom learning rules. 3-factor STDP, reward modulation, eligibility traces, homeostatic regulation &mdash; all executing on silicon.
        </p>
      </div>
    </div>
  </section>

  <!-- DEVELOPER TOOLS -->
  <section class="py-40 px-6 md:px-12">
    <div class="max-w-[1200px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
      <div class="reveal">
        <h2 class="text-[clamp(2rem,3.5vw,3rem)] font-bold tracking-tight leading-tight">Python to silicon.</h2>
        <p class="text-lg text-white/40 mt-6 leading-relaxed">
          Define networks in Python. Simulate on your laptop. Train on GPU. Deploy to real hardware. The same code runs everywhere &mdash; what you test is what you get on silicon.
        </p>
        <a href="https://github.com/catalyst-neuromorphic/catalyst-neurocore" target="_blank" rel="noopener noreferrer" class="btn-pill mt-8 inline-flex">View SDK on GitHub &rarr;</a>
      </div>
      <div class="reveal">
        <div class="glass p-8 overflow-x-auto">
          <div id="sdk-code" class="font-mono text-[clamp(0.75rem,0.85vw,0.85rem)] leading-[2] text-white/40 whitespace-pre"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- VALIDATION -->
  <section class="py-40 px-6 md:px-12">
    <div class="max-w-[800px] mx-auto text-center">
      <h2 class="reveal text-[clamp(2.5rem,5vw,4rem)] font-bold tracking-tight">Proven on real hardware.</h2>
      <p class="reveal text-lg text-white/40 mt-6 leading-relaxed max-w-[600px] mx-auto">
        Not a simulation. Not a model. N2 has been validated on real programmable logic, running real spiking neural networks. Every test passing. Cycle-accurate. Bit-exact.
      </p>
      <div class="reveal mt-12">
        <div class="text-[clamp(4rem,8vw,7rem)] font-bold tracking-tight text-catalyst-green">28/28</div>
        <div class="text-sm text-white/30 mt-2 uppercase tracking-widest">Every test. Passing.</div>
      </div>
    </div>
  </section>

  <!-- COMPARISON -->
  <section id="comparison" class="py-32 px-6 md:px-12">
    <div class="max-w-[1100px] mx-auto">
      <h2 class="reveal text-center text-[clamp(2rem,3.5vw,3rem)] font-bold tracking-tight mb-16">How N2 compares.</h2>
      <div class="glass p-2 overflow-x-auto reveal">
        <table class="w-full border-collapse min-w-[700px]">
          <thead>
            <tr>
              <th class="p-4 text-left text-[11px] uppercase tracking-widest text-white/25 font-medium"></th>
              <th class="p-4 text-left text-[11px] uppercase tracking-widest text-catalyst-blue font-semibold">Catalyst N2</th>
              <th class="p-4 text-left text-[11px] uppercase tracking-widest text-white/25 font-medium">Intel Loihi 2</th>
              <th class="p-4 text-left text-[11px] uppercase tracking-widest text-white/25 font-medium">BrainScaleS-2</th>
              <th class="p-4 text-left text-[11px] uppercase tracking-widest text-white/25 font-medium">IBM TrueNorth</th>
              <th class="p-4 text-left text-[11px] uppercase tracking-widest text-white/25 font-medium">SpiNNaker 2</th>
            </tr>
          </thead>
          <tbody class="text-sm">
            {[
              ['Cores', '128', '128', '2 (analog)', '4,096', '152 (ARM)'],
              ['Neurons per core', '1,024', '1,024', '256', '256', 'Software'],
              ['Total neurons', '131,072', '131,072', '512', '1,048,576', 'Up to 16M'],
              ['Neuron models', '5', '3+', 'Physical', '1 (LIF)', 'Software'],
              ['Weight precision', '8-bit', '8-bit', 'Analog', '1-bit', 'Software'],
              ['Spike types', 'Binary + graded', 'Binary + graded', 'Analog', 'Binary', 'Software'],
              ['On-chip learning', 'Yes (programmable)', 'Yes (programmable)', 'Yes (analog)', '\u2014', 'Yes'],
              ['Learning engine', '16-reg microcode', 'Microcode', 'Analog', '\u2014', 'ARM cores'],
              ['Routing', 'Barrier mesh', 'Mesh', 'Crossbar', 'Multicast', 'Multicast'],
              ['Axonal delays', '1\u201363 timesteps', '1\u201363 timesteps', '\u2014', '\u2014', 'Software'],
              ['Hardware validated', 'FPGA (28/28)', 'ASIC (7nm)', 'ASIC (65nm)', 'ASIC (28nm)', 'ASIC (22nm)'],
              ['Open design', 'Yes', 'No', 'Partial', 'No', 'Partial'],
              ['SDK included', 'neurocore 3.7', 'Lava (limited)', 'PyNN adapter', '\u2014', 'SpiNNTools'],
            ].map(row => (
              <tr class="border-t border-white/[0.04] comp-row">
                <td class="p-4 text-white/50">{row[0]}</td>
                <td class="p-4 text-white font-semibold">{row[1]}</td>
                <td class="p-4 text-white/30">{row[2]}</td>
                <td class="p-4 text-white/25">{row[3]}</td>
                <td class="p-4 text-white/20">{row[4]}</td>
                <td class="p-4 text-white/20">{row[5]}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- TECHNICAL SPECIFICATIONS -->
  <section class="py-32 px-6 md:px-12" id="specs">
    <div class="max-w-[900px] mx-auto">
      <h2 class="reveal text-center text-[clamp(2rem,3.5vw,3rem)] font-bold tracking-tight mb-16">Technical Specifications</h2>

      <div class="reveal space-y-0">
        <details class="spec-group" open>
          <summary class="spec-summary">Compute</summary>
          <div class="spec-content">
            <div class="spec-row"><span>Cores</span><span>128</span></div>
            <div class="spec-row"><span>Neurons per core</span><span>1,024</span></div>
            <div class="spec-row"><span>Total neurons</span><span>131,072</span></div>
            <div class="spec-row"><span>Synapses per core</span><span>131,072 (CSR format)</span></div>
            <div class="spec-row"><span>Neuron models</span><span>CUBA LIF, Izhikevich, ALIF, Sigma-Delta, Resonate-and-Fire</span></div>
            <div class="spec-row"><span>Compartment model</span><span>4-compartment dendritic tree</span></div>
          </div>
        </details>

        <details class="spec-group">
          <summary class="spec-summary">Learning Engine</summary>
          <div class="spec-content">
            <div class="spec-row"><span>Plasticity rules</span><span>3-factor STDP, reward-modulated, homeostatic</span></div>
            <div class="spec-row"><span>Microcode engine</span><span>16 general-purpose registers</span></div>
            <div class="spec-row"><span>Eligibility traces</span><span>7-bit, configurable decay</span></div>
            <div class="spec-row"><span>Reward signals</span><span>Global + per-core reward modulation</span></div>
            <div class="spec-row"><span>Homeostasis</span><span>Proportional error, target rate regulation</span></div>
            <div class="spec-row"><span>Weight precision</span><span>8-bit with stochastic rounding</span></div>
            <div class="spec-row"><span>Per-group plasticity</span><span>Independent learning rules per synapse group</span></div>
            <div class="spec-row"><span>Persistent traces</span><span>5 trace types with configurable time constants</span></div>
          </div>
        </details>

        <details class="spec-group">
          <summary class="spec-summary">Communication</summary>
          <div class="spec-content">
            <div class="spec-row"><span>Routing</span><span>Barrier-synchronized mesh network</span></div>
            <div class="spec-row"><span>Spike types</span><span>Binary spikes + 8-bit graded payloads</span></div>
            <div class="spec-row"><span>Axonal delays</span><span>1&ndash;63 timesteps, per-synapse configurable</span></div>
            <div class="spec-row"><span>Dendrites</span><span>4-compartment multi-compartment model</span></div>
            <div class="spec-row"><span>Convolutional synapses</span><span>Shared weight kernels, stride, padding</span></div>
          </div>
        </details>

        <details class="spec-group">
          <summary class="spec-summary">SDK &amp; Software</summary>
          <div class="spec-content">
            <div class="spec-row"><span>SDK name</span><span>neurocore v3.7.0</span></div>
            <div class="spec-row"><span>Language</span><span>Python</span></div>
            <div class="spec-row"><span>Modules</span><span>88</span></div>
            <div class="spec-row"><span>Features</span><span>155</span></div>
            <div class="spec-row"><span>Tests</span><span>3,091</span></div>
            <div class="spec-row"><span>Backends</span><span>CPU, GPU (CUDA), FPGA</span></div>
            <div class="spec-row"><span>Fixed-point mode</span><span>Hardware-accurate integer quantization</span></div>
            <div class="spec-row"><span>Benchmark</span><span>85.9% SHD (float), 85.4% (quantized)</span></div>
          </div>
        </details>

        <details class="spec-group">
          <summary class="spec-summary">Hardware Validation</summary>
          <div class="spec-content">
            <div class="spec-row"><span>Tests passing</span><span>28/28</span></div>
            <div class="spec-row"><span>Platform</span><span>AWS F2 (Xilinx UltraScale+ VU47P)</span></div>
            <div class="spec-row"><span>Clock frequency</span><span>62.5 MHz</span></div>
            <div class="spec-row"><span>Cores validated</span><span>16</span></div>
            <div class="spec-row"><span>RTL accuracy</span><span>Cycle-accurate, bit-exact vs simulation</span></div>
            <div class="spec-row"><span>Peak throughput</span><span>81,000 spikes / 3.4ms</span></div>
            <div class="spec-row"><span>Cross-core routing</span><span>163,000 spikes validated</span></div>
          </div>
        </details>

        <details class="spec-group">
          <summary class="spec-summary">Intellectual Property</summary>
          <div class="spec-content">
            <div class="spec-row"><span>UK Patent</span><span>Filed February 2026 (full architecture)</span></div>
            <div class="spec-row"><span>Application ref</span><span>~2602902.6</span></div>
            <div class="spec-row"><span>RTL</span><span>Proprietary (BSL 1.1)</span></div>
            <div class="spec-row"><span>SDK</span><span>Open source (GitHub)</span></div>
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- PAPER -->
  <section id="paper" class="py-20 px-6 md:px-12 text-center">
    <div class="glass max-w-[500px] mx-auto p-10 reveal">
      <h3 class="text-xl font-semibold mb-2">Read the N2 paper</h3>
      <p class="text-sm text-white/40 mb-6">18 pages. Full architecture, SDK, and FPGA validation results.</p>
      <a href="/papers/catalyst-n2.pdf" class="btn-pill" target="_blank">View PDF</a>
    </div>
  </section>

  <!-- ENQUIRE -->
  <section class="py-32 px-6 md:px-12">
    <div class="max-w-[700px] mx-auto text-center">
      <div class="glass-accent p-12 reveal">
        <h2 class="text-[clamp(1.8rem,3vw,2.5rem)] font-bold tracking-tight mb-4">Bring N2 to your project.</h2>
        <p class="text-white/40 leading-relaxed mb-8">
          Licensing, research partnerships, and integration enquiries.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="mailto:henry@catalyst-neuromorphic.com" class="btn-primary">Enquire</a>
          <a href="/papers/catalyst-n2.pdf" class="btn-pill" target="_blank">Read the paper</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .zoom-level { transition: opacity 0.4s ease, transform 0.4s ease; }
  .chip-glow {
    filter: drop-shadow(0 0 60px rgba(59,130,246,0.12)) drop-shadow(0 0 120px rgba(59,130,246,0.06));
  }
  .transistor-grid { background: rgba(59,130,246,0.03); border: 1px solid rgba(59,130,246,0.08); }
  .gate-box { background: rgba(59,130,246,0.04); border: 1px solid rgba(59,130,246,0.1); }
  .gate-cell { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); }
  .core-box { background: rgba(59,130,246,0.05); border: 1px solid rgba(59,130,246,0.12); }
  .core-cell { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); }
  .mesh-grid { background: rgba(59,130,246,0.03); border: 1px solid rgba(59,130,246,0.1); }
  .core-active { background: rgba(59,130,246,0.12); border: 1px solid rgba(59,130,246,0.2); }
  .core-dim { background: rgba(59,130,246,0.05); border: 1px solid rgba(59,130,246,0.08); }
  .comp-row:hover { background: rgba(255,255,255,0.02); }

  /* Specs accordion */
  .spec-group { border-top: 1px solid rgba(255,255,255,0.06); }
  .spec-group:last-child { border-bottom: 1px solid rgba(255,255,255,0.06); }
  .spec-summary {
    padding: 1.25rem 0;
    font-size: 0.95rem;
    font-weight: 600;
    color: rgba(255,255,255,0.7);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .spec-summary::-webkit-details-marker { display: none; }
  .spec-summary::after {
    content: '+';
    font-size: 1.25rem;
    font-weight: 300;
    color: rgba(255,255,255,0.25);
    transition: transform 0.2s;
  }
  details[open] .spec-summary::after { content: '\2212'; }
  .spec-content { padding-bottom: 1.25rem; }
  .spec-row {
    display: flex;
    justify-content: space-between;
    padding: 0.5rem 0;
    font-size: 0.85rem;
    border-top: 1px solid rgba(255,255,255,0.03);
  }
  .spec-row span:first-child { color: rgba(255,255,255,0.35); }
  .spec-row span:last-child { color: rgba(255,255,255,0.6); text-align: right; }

  /* Sub-nav active state */
  .sub-nav-link.active { color: rgba(59,130,246,0.8); }
</style>

<script>
  // SDK code block
  (function() {
    var el = document.getElementById('sdk-code');
    if (!el) return;
    var s = function(cls: string, text: string) { return '<span class="' + cls + '">' + text + '</span>'; };
    var w60 = 'text-white/60', w55 = 'text-white/55', w50 = 'text-white/50', w25 = 'text-white/25', blue = 'text-catalyst-blue/70';
    el.innerHTML = s(w60,'import') + ' neurocore ' + s(w60,'as') + ' nc\n\n'
      + s(w25,'# Define a network with adaptive neurons') + '\n'
      + 'net = nc.' + s(blue,'Network') + '(model=' + s(w50,'"adaptive"') + ')\n\n'
      + 'exc = net.' + s(blue,'population') + '(' + s(w55,'64') + ')\n'
      + 'inh = net.' + s(blue,'population') + '(' + s(w55,'16') + ')\n\n'
      + s(w25,'# On-chip learning, reward-modulated') + '\n'
      + 'net.' + s(blue,'connect') + '(exc, exc, learning=' + s(w50,'"reward"') + ')\n\n'
      + s(w25,'# Simulate on GPU, deploy to hardware') + '\n'
      + 'sim = nc.' + s(blue,'Simulator') + '(backend=' + s(w50,'"gpu"') + ')\n'
      + 'result = sim.' + s(blue,'run') + '(timesteps=' + s(w55,'1000') + ')\n'
      + 'result.' + s(blue,'raster_plot') + '()';
  })();

  // Chip zoom scroll animation
  (function() {
    var section = document.getElementById('chip-zoom');
    if (!section) return;
    var levels = document.querySelectorAll('.zoom-level');
    var dots = document.querySelectorAll('.zoom-dot');
    var numLevels = levels.length;

    function updateZoom() {
      var rect = section.getBoundingClientRect();
      var sectionHeight = section.offsetHeight;
      var viewHeight = window.innerHeight;
      var scrolled = -rect.top;
      var scrollRange = sectionHeight - viewHeight;
      var progress = Math.max(0, Math.min(1, scrolled / scrollRange));
      var levelProgress = progress * (numLevels - 1);
      var currentLevel = Math.floor(levelProgress);
      var fraction = levelProgress - currentLevel;

      levels.forEach(function(level, i) {
        var el = level as HTMLElement;
        if (i === currentLevel) {
          el.style.opacity = String(1 - fraction * 0.5);
          el.style.transform = 'scale(' + (1 + fraction * 0.3) + ') rotateY(' + (fraction * 15) + 'deg)';
        } else if (i === currentLevel + 1) {
          el.style.opacity = String(fraction);
          el.style.transform = 'scale(' + (0.7 + fraction * 0.3) + ') rotateY(' + ((1 - fraction) * -15) + 'deg)';
        } else if (i < currentLevel) {
          el.style.opacity = '0';
          el.style.transform = 'scale(1.5)';
        } else {
          el.style.opacity = '0';
          el.style.transform = 'scale(0.5)';
        }
      });

      dots.forEach(function(dot, i) {
        var active = i <= Math.round(levelProgress);
        dot.classList.toggle('bg-catalyst-blue', active);
        dot.classList.toggle('bg-white/15', !active);
      });
    }

    window.addEventListener('scroll', updateZoom, { passive: true });
    updateZoom();
  })();

  // STDP curve
  (function() {
    var g = document.getElementById('stdpCurves');
    if (!g) return;
    var ns = 'http://www.w3.org/2000/svg';
    var tau = 20, Ap = 1.0, Am = 1.2;

    var ltp = 'M230,140';
    for (var dt = 0.5; dt <= 50; dt += 0.5) {
      ltp += ' L' + (230 + dt * 4.2).toFixed(1) + ',' + (140 - Ap * Math.exp(-dt / tau) * 100).toFixed(1);
    }
    var ltpPath = document.createElementNS(ns, 'path');
    ltpPath.setAttribute('d', ltp);
    ltpPath.setAttribute('stroke', 'rgba(59,130,246,0.7)');
    ltpPath.setAttribute('fill', 'none');
    ltpPath.setAttribute('stroke-width', '2');
    g.appendChild(ltpPath);

    var ltpFill = document.createElementNS(ns, 'path');
    ltpFill.setAttribute('d', ltp + ' L440,140 Z');
    ltpFill.setAttribute('fill', 'rgba(59,130,246,0.05)');
    g.appendChild(ltpFill);

    var ltd = 'M230,140';
    for (var dt2 = 0.5; dt2 <= 50; dt2 += 0.5) {
      ltd += ' L' + (230 - dt2 * 3.4).toFixed(1) + ',' + (140 + Am * Math.exp(-dt2 / tau) * 100).toFixed(1);
    }
    var ltdPath = document.createElementNS(ns, 'path');
    ltdPath.setAttribute('d', ltd);
    ltdPath.setAttribute('stroke', 'rgba(239,68,68,0.5)');
    ltdPath.setAttribute('fill', 'none');
    ltdPath.setAttribute('stroke-width', '2');
    g.appendChild(ltdPath);

    var ltdFill = document.createElementNS(ns, 'path');
    ltdFill.setAttribute('d', ltd + ' L60,140 Z');
    ltdFill.setAttribute('fill', 'rgba(239,68,68,0.03)');
    g.appendChild(ltdFill);

    var dot = document.createElementNS(ns, 'circle');
    dot.setAttribute('cx', '230');
    dot.setAttribute('cy', '140');
    dot.setAttribute('r', '3');
    dot.setAttribute('fill', 'rgba(255,255,255,0.4)');
    g.appendChild(dot);
  })();

  // Sticky sub-nav visibility
  (function() {
    var subNav = document.getElementById('sub-nav');
    var hero = document.querySelector('.hero-section');
    if (!subNav || !hero) return;

    new IntersectionObserver(([e]) => {
      if (!e.isIntersecting) {
        subNav.style.opacity = '1';
        subNav.style.pointerEvents = 'auto';
      } else {
        subNav.style.opacity = '0';
        subNav.style.pointerEvents = 'none';
      }
    }, { threshold: 0.05 }).observe(hero);
  })();
</script>
