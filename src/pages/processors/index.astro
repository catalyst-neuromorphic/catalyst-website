        <a href="/console/dashboard">Dashboard</a>
        <a href="/console/keys">API Keys</a>
        <a href="/console/billing">Billing</a>
        <a href="/console/usage">Usage</a>
        <div class="avatar-divider"></div>
        <button id="sign-out-btn">Sign out</button>
      </div>
    </div>
  </div>
</nav>

<!-- ═══ HERO ═══ -->
<section class="hero reveal">
  <p class="hero-eyebrow">Neuromorphic Silicon</p>
  <h1>Four generations.<br>One architecture.</h1>
  <p>Neuromorphic processors designed from the transistor up. Each generation pushes the boundary of what spiking silicon can do.</p>
</section>

<!-- ═══ PRODUCT TILES ═══ -->
<section class="tiles stagger-children">
  {products.map(p => (
    <div class:list={['tile', { disabled: !p.available }]}>
      <div class="tile-chip">
        {p.glowColor && <div class="chip-glow" style={`background:rgb(${p.glowColor});`}></div>}
        {p.image ? (
          <img src={p.image} alt={`Catalyst ${p.name} processor`} loading="lazy" />
        ) : (
          <ChipFloorplan chip={p.chip} />
        )}
      </div>
      <p class="tile-gen">{p.gen}</p>
      <h2 class="tile-name">{p.name}</h2>
      <p class="tile-tagline">{p.tagline}</p>
      <div class="tile-stats">
        {p.stats.map(s => (
          <div class="tile-stat">
            <div class="tile-stat-val">{s.value}</div>
            <div class="tile-stat-label">{s.label}</div>
          </div>
        ))}
      </div>
      <div class="tile-ctas">
        {p.available ? (
          <>
            <a href={p.href} class="btn-learn glow-btn">Learn more</a>
            <a href={p.buyHref} class="btn-buy glow-btn">Access</a>
          </>
        ) : (
          <span class="btn-notify">Coming soon</span>
        )}
      </div>
    </div>
  ))}
</section>

<!-- ═══ QUICK COMPARISON ═══ -->
<section class="comparison reveal">
  <h2>N1 vs N2 vs N3 vs N4</h2>
  <table class="comp-table">
    <thead>
      <tr>
        <th></th>
        <th>N1</th>
        <th>N2</th>
        <th>N3</th>
        <th class="highlight">N4</th>
      </tr>
    </thead>
    <tbody>
      {comparison.map(row => (
        <tr>
          <td>{row.label}</td>
          <td>{row.n1}</td>
          <td>{row.n2}</td>
          <td>{row.n3}</td>
          <td>{row.n4}</td>
        </tr>
      ))}
    </tbody>
  </table>
  <div class="comp-link">
    <a href="/processors/specs">Full competitor comparison →</a>
  </div>
</section>

<!-- ═══ CLOUD API ═══ -->
<section class="cloud-section reveal" id="cloud">
  <h2 class="section-heading">Cloud API</h2>
  <p class="section-sub">Run spiking neural network simulations via REST API. No hardware required. Just send JSON, get spikes.</p>

  <div class="cloud-grid">
    <div class="cloud-card">
      <div class="cloud-num">01</div>
      <h3>Define</h3>
      <p>Describe your network as JSON. Populations, connections, neuron parameters.</p>
    </div>
    <div class="cloud-card">
      <div class="cloud-num">02</div>
      <h3>Simulate</h3>
      <p>Submit a job with stimuli and timesteps. Hardware-accurate dynamics server-side.</p>
    </div>
    <div class="cloud-card">
      <div class="cloud-num">03</div>
      <h3>Analyse</h3>
      <p>Get firing rates, spike trains, and timeseries. Population-indexed for your pipeline.</p>
    </div>
  </div>

  <div class="cloud-ctas">
    <a href="/console/signup" class="btn-buy glow-btn">Get started free</a>
    <a href="/cloud/docs" class="btn-learn glow-btn" target="_blank" rel="noopener noreferrer">API reference</a>
  </div>
</section>

<!-- ═══ PRICING ═══ -->
<section class="pricing-section reveal" id="pricing">
  <h2 class="section-heading">Pricing</h2>
  <p class="section-sub">Subscribe for included compute or buy API credits. Free tier available.</p>

  <div class="pricing-grid">
    <div class="pricing-card">
      <h3>Free</h3>
      <div class="pricing-price">$0<span>/mo</span></div>
      <ul>
        <li>500 compute-sec/week</li>
        <li>N1 processor</li>
        <li>1,024 neurons max</li>
      </ul>
      <a href="/console/signup" class="btn-learn glow-btn">Sign up</a>
    </div>
    <div class="pricing-card featured">
      <h3>Max</h3>
      <div class="pricing-price">$100<span>/mo</span></div>
      <ul>
        <li>7,000 compute-sec/week</li>
        <li>N1 + N2 processors</li>
        <li>131,072 neurons max</li>
      </ul>
      <a href="/console/signup" class="btn-buy glow-btn">Get started</a>
    </div>
    <div class="pricing-card">
      <h3>Ultra</h3>
      <div class="pricing-price">$200<span>/mo</span></div>
      <ul>
        <li>16,000 compute-sec/week</li>
        <li>N1 + N2 processors</li>
        <li>131,072 neurons max</li>
      </ul>
      <a href="/console/signup" class="btn-buy glow-btn">Get started</a>
    </div>
  </div>

  <div class="pricing-credits">
    <p>API credits: <strong>N1 $0.002/sec</strong> &middot; <strong>N2 $0.005/sec</strong> &middot; Buy any amount, $5 minimum, never expire.</p>
  </div>

  <div class="pricing-enterprise">
    <p>Enterprise: custom budgets, dedicated capacity, SLA. <a href="/about#contact">Contact us</a></p>
  </div>

  <div class="cloud-ctas">
    <a href="/cloud/pricing" class="btn-learn glow-btn">Full pricing details</a>
  </div>
</section>

<!-- ═══ FPGA & HARDWARE (Coming Soon) ═══ -->
<section class="hw-section reveal" id="hardware">
  <h2 class="section-heading">Hardware access</h2>
  <p class="section-sub">Run on real FPGA fabric. ASIC tapeout on the roadmap.</p>

  <div class="cloud-grid">
    <div class="cloud-card">
      <h3>FPGA bitstreams</h3>
      <p>Download validated bitstreams for Xilinx UltraScale+ and Kria K26. Deploy on your own hardware.</p>
      <span class="coming-soon">Coming soon</span>
    </div>
    <div class="cloud-card">
      <h3>AWS F2 instances</h3>
      <p>Run on cloud FPGA via AWS F2. Pre-built AMI with drivers and SDK.</p>
      <span class="coming-soon">Coming soon</span>
    </div>
    <div class="cloud-card">
      <h3>ASIC</h3>
      <p>28nm and 7nm tapeout planned. Contact for early access partnerships.</p>
      <span class="coming-soon">Coming soon</span>
    </div>
  </div>
</section>

<!-- ═══ CTA ═══ -->
<section class="cta-section reveal">
  <div class="cta-card">
    <h2>Ready to build?</h2>
    <p>Start with the free tier. 500 compute-seconds/week. No credit card required.</p>
    <div class="cta-btns">
