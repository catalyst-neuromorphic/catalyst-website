---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Processors — Catalyst Neuromorphic" description="Compare Catalyst neuromorphic processors. N2 (Loihi 2 parity) and N1 (Loihi 1 parity).">

  <section class="pt-36 pb-20 px-6 md:px-12 text-center">
    <p class="text-sm text-catalyst-blue font-medium tracking-wider uppercase mb-4">Processors</p>
    <h1 class="text-[clamp(3rem,6vw,5rem)] font-bold tracking-tighter">Two generations of silicon.</h1>
    <p class="text-lg text-white/40 mt-4 max-w-[550px] mx-auto">Choose the right processor for your neuromorphic workload.</p>
  </section>

  <!-- PRODUCT CARDS -->
  <section class="py-20 px-6 md:px-12">
    <div class="max-w-[1100px] mx-auto grid grid-cols-1 md:grid-cols-2 gap-8 reveal-stagger">
      <!-- N2 -->
      <a href="/processors/n2" class="group product-card-n2 rounded-2xl p-8 no-underline transition-all duration-300 hover:border-catalyst-blue/20">
        <div class="w-full aspect-square max-w-[320px] mx-auto mb-6 rounded-xl overflow-hidden">
          <img src="/images/renders/n2-angled.webp" alt="Catalyst N2 die shot" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
        </div>
        <div class="text-center">
          <p class="text-[10px] uppercase tracking-widest text-catalyst-blue/70 mb-2">Second Generation</p>
          <h2 class="text-2xl font-bold tracking-tight">Catalyst N2</h2>
          <p class="text-sm text-white/40 mt-2 mb-4">Full Loihi 2 parity. 5 neuron models. Programmable microcode learning engine. FPGA validated.</p>
          <span class="text-sm text-catalyst-blue">Learn more &rarr;</span>
        </div>
      </a>
      <!-- N1 -->
      <a href="/processors/n1" class="group product-card-n1 rounded-2xl p-8 no-underline transition-all duration-300 hover:border-white/15">
        <div class="w-full aspect-square max-w-[320px] mx-auto mb-6 rounded-xl overflow-hidden">
          <img src="/images/renders/n1-top.webp" alt="Catalyst N1 die shot" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
        </div>
        <div class="text-center">
          <p class="text-[10px] uppercase tracking-widest text-white/30 mb-2">First Generation</p>
          <h2 class="text-2xl font-bold tracking-tight">Catalyst N1</h2>
          <p class="text-sm text-white/40 mt-2 mb-4">Full Loihi 1 parity. The foundation of the Catalyst platform.</p>
          <span class="text-sm text-white/50">Learn more &rarr;</span>
        </div>
      </a>
    </div>
  </section>

  <!-- COMPARISON TABLE -->
  <section class="py-32 px-6 md:px-12">
    <div class="max-w-[800px] mx-auto">
      <h2 class="reveal text-center text-[clamp(2rem,3.5vw,2.5rem)] font-bold tracking-tight mb-12">Side by side.</h2>
      <div class="glass p-2 overflow-x-auto reveal">
        <table class="w-full border-collapse">
          <thead>
            <tr>
              <th class="p-4 text-left text-[11px] uppercase tracking-widest text-white/25 font-medium"></th>
              <th class="p-4 text-center text-[11px] uppercase tracking-widest text-white/30 font-medium">N1</th>
              <th class="p-4 text-center text-[11px] uppercase tracking-widest text-catalyst-blue font-semibold">N2</th>
            </tr>
          </thead>
          <tbody class="text-sm">
            {[
              ['Parity target', 'Intel Loihi 1', 'Intel Loihi 2'],
              ['Cores', '128', '128'],
              ['Total neurons', '131,072', '131,072'],
              ['Neuron models', '1 (LIF)', '5'],
              ['Learning engine', '14-opcode ISA', '16-register microcode'],
              ['Weight precision', '8-bit', '8-bit + stochastic rounding'],
              ['Graded spikes', '8-bit', '8-bit'],
              ['Axonal delays', '1\u201363', '1\u201363'],
              ['Dendritic compartments', '4', '4'],
              ['Hardware validated', '\u2014', 'FPGA 28/28'],
              ['SDK tests', '96', '3,091'],
              ['SDK backends', 'CPU', 'CPU, GPU, FPGA'],
              ['Paper', '13 pages (DOI)', '18 pages'],
            ].map(row => (
              <tr class="border-t border-white/[0.04]">
                <td class="p-4 text-white/50">{row[0]}</td>
                <td class="p-4 text-center text-white/30">{row[1]}</td>
                <td class="p-4 text-center text-white font-medium">{row[2]}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .product-card-n2 {
    background: linear-gradient(180deg, rgba(59,130,246,0.03) 0%, transparent 100%);
    border: 1px solid rgba(59,130,246,0.08);
  }
  .product-card-n1 {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
  }
</style>
