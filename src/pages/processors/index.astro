---
import ChipFloorplan from '../../components/ChipFloorplan.astro';

const products = [
  {
    chip: 'n1' as const,
    gen: 'First Generation',
    name: 'N1',
    tagline: 'Loihi 1 parity. Where it began.',
    image: '/images/renders/chip-n1.webp',
    glowColor: '34,197,94',
    stats: [
      { label: 'Neurons', value: '131,072' },
      { label: 'Neuron model', value: 'CUBA LIF' },
      { label: 'Parity', value: 'Loihi 1' },
    ],
    href: '/processors/n1',
    buyHref: '/processors/buy',
    available: true,
  },
  {
    chip: 'n2' as const,
    gen: 'Second Generation',
    name: 'N2',
    tagline: 'Loihi 2 parity. Programmable everything.',
    image: '/images/renders/chip-n2.webp',
    glowColor: '168,85,247',
    stats: [
      { label: 'Neurons', value: '131,072' },
      { label: 'Neuron models', value: '5' },
      { label: 'Parity', value: 'Loihi 2' },
    ],
    href: '/processors/n2',
    buyHref: '/processors/buy',
    available: true,
  },
  {
    chip: 'n3' as const,
    gen: 'Third Generation',
    name: 'N3',
    tagline: 'Hybrid ANN/SNN. Hardware virtualization. FPGA validated.',
    image: '/images/renders/chip-n3.webp',
    glowColor: '239,68,68',
    stats: [
      { label: 'Neurons', value: '524K\u20131M' },
      { label: 'Compute', value: 'ANN/SNN' },
      { label: 'Memory', value: '4-level' },
    ],
    href: '/processors/n3',
    buyHref: '/processors/n3',
    available: true,
  },
  {
    chip: 'n4' as const,
    gen: 'Fourth Generation',
    name: 'N4',
    tagline: '512-core dual-chiplet. 4.19 million neurons. Patent filed.',
    image: '/images/renders/chip-n3.webp',
    glowColor: '59,130,246',
    stats: [
      { label: 'Neurons', value: '4.19M' },
      { label: 'Cores', value: '512' },
      { label: 'Memory', value: '48 GB HBM3E' },
    ],
    href: '/research',
    buyHref: '/research',
    available: false,
  },
];

const comparison = [
  { label: 'Cores', n1: '128', n2: '128', n3: '128 (16 tiles)', n4: '512 (dual chiplet)' },
  { label: 'Total neurons', n1: '131,072', n2: '131,072', n3: '524K\u20131M', n4: '4.19M' },
  { label: 'Neuron models', n1: '1 (CUBA LIF)', n2: '5 (programmable)', n3: '7+ (programmable + custom)', n4: '8 (50-opcode microcode)' },
  { label: 'Weight precision', n1: 'Fixed 8-bit', n2: 'Variable 1\u201316-bit', n3: 'Variable 1\u201316-bit', n4: 'Variable 1\u201316-bit' },
  { label: 'Eligibility traces', n1: '2', n2: '5', n3: '6', n4: '8' },
  { label: 'Learning engine', n1: '14-opcode ISA', n2: '16-register microcode', n3: '16 \u00d7 28-opcode (per-tile)', n4: '50-opcode (per-core)' },
  { label: 'Spike payloads', n1: 'Binary + 8-bit', n2: 'Binary + 8/16/24-bit', n3: 'Binary + 8/16/24-bit + compression', n4: 'Binary + graded + compressed' },
  { label: 'ANN mode', n1: '\u2014', n2: '\u2014', n3: 'INT8 MAC', n4: 'INT8/INT16 MAC' },
  { label: 'Virtualization', n1: '\u2014', n2: '\u2014', n3: 'NeurOS (680+ networks)', n4: 'NeurOS v2' },
  { label: 'Memory hierarchy', n1: '1 level', n2: '1 level', n3: '4 levels (L1\u2013L4)', n4: 'HBM3E 48 GB' },
  { label: 'Synapse formats', n1: '3', n2: '4', n3: '4 + compression', n4: '10' },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Processors — Catalyst Neuromorphic</title>
<meta name="description" content="Four generations of neuromorphic processors. Compare N1, N2, N3, and N4." />
<link rel="canonical" href="https://catalyst-neuromorphic.com/processors" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta property="og:title" content="Processors — Catalyst Neuromorphic" />
<meta property="og:description" content="Four generations of neuromorphic processors. N4 coming soon." />
<meta property="og:type" content="website" />
<meta property="og:url" content="https://catalyst-neuromorphic.com/processors" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{
    background:#050507;
    color:#fff;
    font-family:'Plus Jakarta Sans',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
    -webkit-font-smoothing:antialiased;
    overflow-x:hidden;
  }
  body::after{
    content:'';position:fixed;inset:0;pointer-events:none;z-index:9999;opacity:.035;
    background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat:repeat;background-size:256px;
  }

  /* ═══ NAV ═══ */
  .nav{
    position:fixed;top:0;left:0;right:0;z-index:100;
    display:flex;align-items:center;justify-content:space-between;
    padding:30px 56px;transition:all .6s ease;
  }
  .nav.scrolled{
    background:rgba(5,5,7,0.55);
    backdrop-filter:blur(24px) saturate(180%);
    -webkit-backdrop-filter:blur(24px) saturate(180%);
    padding:20px 56px;
  }
  .nav.scrolled::after{opacity:1}
  .nav::after{
    content:'';position:absolute;bottom:-20px;left:0;right:0;height:20px;
    background:linear-gradient(180deg,rgba(5,5,7,0.4),transparent);
    opacity:0;transition:opacity .6s ease;pointer-events:none;
  }
  .nav-logo{
    font-family:'Space Grotesk',system-ui,sans-serif;
    font-size:1.9rem;font-weight:700;color:#fff;
    letter-spacing:-0.02em;text-decoration:none;
  }
  .nav-links{display:flex;align-items:center;gap:50px}
  .nav-links a{
    font-size:1.2rem;font-weight:500;color:rgba(255,255,255,0.6);
    text-decoration:none;transition:color .25s;
  }
  .nav-links a:hover{color:#fff}
  .nav-links a.active{color:#fff}
  .auth-area{position:relative}
  .avatar-btn{width:34px;height:34px;border-radius:50%;background:rgba(59,130,246,0.15);border:1px solid rgba(59,130,246,0.25);color:#60A5FA;cursor:pointer;display:none;align-items:center;justify-content:center;transition:background .2s}
  .avatar-btn:hover{background:rgba(59,130,246,0.25)}
  .avatar-dropdown{position:absolute;top:calc(100% + 12px);right:0;background:rgba(15,15,20,0.92);backdrop-filter:blur(24px) saturate(180%);border:1px solid rgba(255,255,255,0.08);border-radius:14px;padding:6px;min-width:180px;opacity:0;visibility:hidden;transform:translateY(-6px);transition:opacity .2s,visibility .2s,transform .2s;z-index:200}
  .avatar-dropdown.open{opacity:1;visibility:visible;transform:translateY(0)}
  .avatar-dropdown a,.avatar-dropdown button{display:block;width:100%;padding:9px 14px;border-radius:8px;font-family:'Plus Jakarta Sans',sans-serif;font-size:.85rem;font-weight:500;color:rgba(255,255,255,0.6);text-decoration:none;text-align:left;background:none;border:none;cursor:pointer;transition:background .15s,color .15s}
  .avatar-dropdown a:hover,.avatar-dropdown button:hover{background:rgba(255,255,255,0.06);color:#fff}
  .avatar-divider{height:1px;background:rgba(255,255,255,0.06);margin:4px 0}

  /* ═══ CONTENT ABOVE FOG ═══ */
  .page-content{position:relative;z-index:1}

  /* ═══ HERO ═══ */
  .hero{
    padding:180px 40px 80px;
    text-align:center;
  }
  .hero-eyebrow{
    font-size:.75rem;font-weight:600;
    text-transform:uppercase;letter-spacing:.15em;
    color:rgba(59,130,246,0.7);
    margin-bottom:20px;
  }
  .hero h1{
    font-family:'Space Grotesk',system-ui,sans-serif;
    font-size:clamp(3rem,7vw,5.5rem);font-weight:700;
    letter-spacing:-0.03em;line-height:1.05;
    margin-bottom:20px;
  }
  .hero p{
    font-size:clamp(1rem,1.8vw,1.25rem);
    color:rgba(255,255,255,0.45);
    max-width:540px;margin:0 auto;line-height:1.6;
  }

  /* ═══ PRODUCT TILES ═══ */
  .tiles{
    max-width:1200px;margin:0 auto;
    padding:40px 32px 100px;
    display:grid;grid-template-columns:repeat(3,1fr);gap:28px;
  }
  .tile{
    position:relative;border-radius:24px;overflow:hidden;
    padding:40px 32px 36px;
    display:flex;flex-direction:column;
    background:linear-gradient(165deg,rgba(255,255,255,0.06) 0%,rgba(255,255,255,0.025) 50%,rgba(255,255,255,0.015) 100%);
    backdrop-filter:blur(28px) saturate(180%);
    -webkit-backdrop-filter:blur(28px) saturate(180%);
    border:1px solid transparent;
    box-shadow:0 8px 32px rgba(0,0,0,0.4),inset 0 1px 0 rgba(255,255,255,0.1),inset 0 -1px 0 rgba(255,255,255,0.02);
    transition:transform .4s ease,box-shadow .4s ease;
  }
  .tile::before{
    content:'';position:absolute;inset:0;border-radius:24px;padding:1px;
    background:linear-gradient(135deg,rgba(59,130,246,0.18) 0%,rgba(59,130,246,0.04) 30%,rgba(59,130,246,0.02) 50%,rgba(59,130,246,0.04) 70%,rgba(59,130,246,0.15) 100%);
    -webkit-mask:linear-gradient(#fff 0 0) content-box,linear-gradient(#fff 0 0);
    -webkit-mask-composite:xor;mask-composite:exclude;
    pointer-events:none;z-index:5;opacity:.4;transition:opacity .4s;
  }
  .tile:hover{
    transform:translateY(-4px);
    box-shadow:0 16px 48px rgba(0,0,0,0.5),inset 0 1px 0 rgba(255,255,255,0.14);
  }
  .tile:hover::before{opacity:.8}
  .tile.disabled{opacity:.6;pointer-events:none;filter:saturate(0.3)}
  .tile-chip{display:flex;justify-content:center;align-items:center;margin-bottom:28px;position:relative;height:240px}
  .tile-chip svg{max-height:220px;width:auto;position:relative;z-index:2}
  .tile-chip img{max-height:220px;width:auto;object-fit:contain;position:relative;z-index:2}
  .chip-glow{
    position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
    width:200px;height:280px;border-radius:50%;
    filter:blur(60px);opacity:0.35;z-index:1;pointer-events:none;
  }
  .tile-gen{
    font-size:.65rem;font-weight:600;text-transform:uppercase;
    letter-spacing:.1em;color:rgba(59,130,246,0.7);margin-bottom:8px;
  }
  .tile-name{
    font-family:'Space Grotesk',system-ui,sans-serif;
    font-size:2.2rem;font-weight:700;letter-spacing:-0.02em;margin-bottom:6px;
  }
  .tile-tagline{
    font-size:.92rem;color:rgba(255,255,255,0.4);margin-bottom:24px;line-height:1.5;
    min-height:2.8em;
  }
  .tile-stats{
    display:flex;gap:20px;margin-bottom:28px;
    padding-bottom:20px;border-bottom:1px solid rgba(255,255,255,0.06);
  }
  .tile-ctas{margin-top:auto}
  .tile-stat{flex:1}
  .tile-stat-val{
    font-family:'Space Grotesk',system-ui;
    font-size:1.05rem;font-weight:600;color:rgba(255,255,255,0.85);
  }
  .tile-stat-label{font-size:.68rem;color:rgba(255,255,255,0.3);margin-top:2px}
  .tile-ctas{display:flex;gap:12px}
  .btn-learn,.btn-buy,.btn-notify{
    flex:1;display:inline-flex;align-items:center;justify-content:center;gap:6px;
    font-size:.88rem;font-weight:600;padding:12px 20px;border-radius:12px;
    text-decoration:none;transition:all .3s;
  }
  .btn-learn{
    color:rgba(255,255,255,0.8);background:rgba(255,255,255,0.06);
    border:1px solid rgba(255,255,255,0.1);
  }
  .btn-learn:hover{background:rgba(255,255,255,0.1);color:#fff;border-color:rgba(255,255,255,0.2)}
  .btn-buy{color:#fff;background:#3B82F6;border:1px solid rgba(59,130,246,0.5)}
  .btn-buy:hover{background:#2563EB;box-shadow:0 6px 24px rgba(59,130,246,0.3)}
  .btn-notify{
    color:rgba(255,255,255,0.35);background:rgba(255,255,255,0.03);
    border:1px solid rgba(255,255,255,0.06);cursor:default;
  }

  /* ═══ COMPARISON ═══ */
  .comparison{max-width:900px;margin:0 auto;padding:40px 32px 100px}
  .comparison h2{
    font-family:'Space Grotesk',system-ui,sans-serif;
    font-size:clamp(1.8rem,3.5vw,2.8rem);font-weight:700;
    letter-spacing:-0.02em;text-align:center;margin-bottom:48px;
  }
  .comp-table{
    width:100%;border-collapse:collapse;
    background:rgba(255,255,255,0.02);border-radius:16px;overflow:hidden;
    border:1px solid rgba(255,255,255,0.06);
  }
  .comp-table th{
    padding:16px 20px;text-align:left;font-size:.7rem;font-weight:600;
    text-transform:uppercase;letter-spacing:.08em;color:rgba(255,255,255,0.25);
    border-bottom:1px solid rgba(255,255,255,0.06);
  }
  .comp-table th.highlight{color:rgba(59,130,246,0.8)}
  .comp-table td{
    padding:14px 20px;font-size:.9rem;border-bottom:1px solid rgba(255,255,255,0.03);
  }
  .comp-table td:first-child{color:rgba(255,255,255,0.5);font-weight:500}
  .comp-table td:nth-child(2){color:rgba(255,255,255,0.4)}
  .comp-table td:nth-child(3){color:rgba(255,255,255,0.9);font-weight:600}
  .comp-table tr:last-child td{border-bottom:none}
  .comp-table tr:hover td{background:rgba(255,255,255,0.02)}
  .comp-link{text-align:center;margin-top:28px}
  .comp-link a{font-size:.88rem;color:rgba(59,130,246,0.7);text-decoration:none;transition:color .25s}
  .comp-link a:hover{color:#60A5FA}

  /* ═══ CTA ═══ */
  .cta-section{max-width:700px;margin:0 auto;padding:40px 32px 120px;text-align:center}
  .cta-card{
    padding:56px 48px;border-radius:24px;
    background:rgba(59,130,246,0.04);border:1px solid rgba(59,130,246,0.12);
    backdrop-filter:blur(40px) saturate(1.2);
    -webkit-backdrop-filter:blur(40px) saturate(1.2);
  }
  .cta-card h2{
    font-family:'Space Grotesk',system-ui,sans-serif;
    font-size:clamp(1.6rem,3vw,2.2rem);font-weight:700;
    letter-spacing:-0.02em;margin-bottom:12px;
  }
  .cta-card p{font-size:1rem;color:rgba(255,255,255,0.4);margin-bottom:32px;line-height:1.6}
  .cta-btns{display:flex;gap:14px;justify-content:center;flex-wrap:wrap}
  .cta-btns .btn-buy,.cta-btns .btn-learn{flex:unset;padding:14px 32px;border-radius:100px}

  /* ═══ GLOW BUTTONS ═══ */
  .glow-btn{position:relative;overflow:hidden;transition:box-shadow .4s ease}
  .glow-spot{
    position:absolute;top:50%;transform:translateY(-50%);
    width:200px;height:100%;display:flex;align-items:center;justify-content:center;
    z-index:0;pointer-events:none;opacity:0;will-change:transform,opacity;
  }
  .glow-spot-circle{
    position:absolute;width:120px;height:120px;border-radius:50%;
    background:radial-gradient(50% 50% at 50% 50%,rgba(255,255,255,0.90) 3.5%,rgba(96,165,250,0.70) 26.5%,rgba(147,197,253,0.50) 37.5%,rgba(59,130,246,0.25) 49%,rgba(37,99,235,0) 92.5%);
  }
  .glow-spot-wide{
    position:absolute;width:200px;height:100px;
    background:radial-gradient(43.3% 44.23% at 50% 49.51%,rgba(255,255,255,0.70) 29%,rgba(191,219,254,0.50) 48.5%,rgba(147,197,253,0.25) 60.71%,rgba(214,211,210,0) 100%);
    filter:blur(5px);
  }
  .glow-btn.glow-on{box-shadow:0 0 25px rgba(59,130,246,0.25),0 0 50px rgba(59,130,246,0.08)}

  /* ═══ FOOTER ═══ */
  .site-footer{border-top:1px solid rgba(255,255,255,0.06);padding:64px 40px 32px}
  .footer-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:40px;max-width:1100px;margin:0 auto}
  .footer-col h4{
    font-family:'Space Grotesk',sans-serif;font-size:.8rem;font-weight:600;
    text-transform:uppercase;letter-spacing:.08em;color:rgba(255,255,255,0.35);margin-bottom:20px;
  }
  .footer-col a{display:block;font-size:.88rem;color:rgba(255,255,255,0.5);text-decoration:none;margin-bottom:10px;transition:color .25s}
  .footer-col a:hover{color:#fff}
  .footer-support{max-width:1100px;margin:40px auto 0;text-align:center;font-size:.85rem;color:rgba(255,255,255,0.3)}
  .footer-support a{color:rgba(59,130,246,0.7);text-decoration:none;transition:color .25s}
  .footer-support a:hover{color:#60A5FA}
  .footer-legal{display:flex;align-items:center;gap:8px}
  .footer-legal a{color:rgba(255,255,255,0.35);text-decoration:none;transition:color .25s}
  .footer-legal a:hover{color:rgba(255,255,255,0.6)}
  .footer-bottom{
    max-width:1100px;margin:24px auto 0;padding-top:24px;
    border-top:1px solid rgba(255,255,255,0.04);
    display:flex;justify-content:space-between;align-items:center;
    font-size:.78rem;color:rgba(255,255,255,0.25);
  }

  /* ═══ ANIMATIONS ═══ */
  .reveal{opacity:0;transform:translateY(30px);transition:none}
  .reveal.visible{opacity:1;transform:translateY(0);transition:opacity .8s ease,transform .8s ease}
  .stagger-children > *{opacity:0;transform:translateY(20px);transition:none}
  .stagger-children.visible > *{opacity:1;transform:translateY(0);transition:opacity .7s ease,transform .7s ease}
  .stagger-children.visible > *:nth-child(1){transition-delay:.05s}
  .stagger-children.visible > *:nth-child(2){transition-delay:.15s}
  .stagger-children.visible > *:nth-child(3){transition-delay:.25s}

  /* ═══ MOBILE ═══ */
  @media(max-width:900px){
    .nav{padding:20px 24px}
    .nav.scrolled{padding:16px 24px}
    .nav-logo{font-size:1.5rem}
    .nav-links{gap:28px}
    .nav-links a{font-size:1rem}
    .tiles{grid-template-columns:1fr;max-width:480px}
    .hero{padding:140px 24px 60px}
    .comparison{padding:40px 20px 80px}
    .comp-table th,.comp-table td{padding:10px 14px}
    .footer-grid{grid-template-columns:1fr 1fr}
    .footer-bottom{flex-direction:column;gap:8px;text-align:center}
  }
  @media(max-width:600px){
    .nav-links{display:none}
    .tile-stats{flex-direction:column;gap:10px}
    .tile-ctas{flex-direction:column}
    .cta-btns{flex-direction:column;align-items:center}
  }
  /* ═══ FOG CANVAS ═══ */
  #sub-fog-canvas{
    position:fixed;top:0;left:0;width:100%;height:60vh;
    z-index:0;pointer-events:none;opacity:0.55;
    -webkit-mask-image:linear-gradient(to bottom,black 30%,transparent 100%);
    mask-image:linear-gradient(to bottom,black 30%,transparent 100%);
  }
  @media(max-width:640px){#sub-fog-canvas{display:none}}
  @media(prefers-reduced-motion:reduce){#sub-fog-canvas{display:none}}

  /* ═══ CLOUD / PRICING / HARDWARE SECTIONS ═══ */
  .section-heading{
    font-family:'Space Grotesk',sans-serif;
    font-size:clamp(2rem,4vw,3rem);font-weight:700;letter-spacing:-.03em;
    text-align:center;margin-bottom:12px;
  }
  .section-sub{
    text-align:center;color:rgba(255,255,255,0.4);
    font-size:.95rem;line-height:1.7;max-width:600px;margin:0 auto 48px;
  }
  .cloud-section,.pricing-section,.hw-section{
    max-width:1000px;margin:0 auto;padding:80px 32px;
  }
  .cloud-grid{
    display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-bottom:32px;
  }
  .cloud-card{
    background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);
    border-radius:16px;padding:28px;position:relative;
  }
  .cloud-card h3{font-family:'Space Grotesk',sans-serif;font-size:1.1rem;font-weight:600;margin-bottom:8px}
  .cloud-card p{font-size:.88rem;color:rgba(255,255,255,0.4);line-height:1.6}
  .cloud-num{font-family:'Space Grotesk',sans-serif;font-size:2rem;font-weight:700;color:rgba(59,130,246,0.4);margin-bottom:12px}
  .cloud-ctas{display:flex;gap:16px;justify-content:center;margin-top:32px}
  .coming-soon{
    display:inline-block;margin-top:14px;
    font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.08em;
    color:rgba(255,255,255,0.25);
    padding:4px 10px;border:1px solid rgba(255,255,255,0.08);border-radius:6px;
  }

  /* pricing */
  .pricing-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-bottom:24px}
  .pricing-card{
    background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);
    border-radius:16px;padding:32px;text-align:center;
  }
  .pricing-card.featured{border-color:rgba(59,130,246,0.3);background:rgba(59,130,246,0.04)}
  .pricing-card h3{font-family:'Space Grotesk',sans-serif;font-size:1.2rem;font-weight:600;margin-bottom:8px}
  .pricing-price{font-family:'Space Grotesk',sans-serif;font-size:2.5rem;font-weight:700;margin-bottom:20px}
  .pricing-price span{font-size:.9rem;font-weight:400;color:rgba(255,255,255,0.35)}
  .pricing-card ul{list-style:none;margin-bottom:24px}
  .pricing-card li{font-size:.85rem;color:rgba(255,255,255,0.45);padding:6px 0;border-bottom:1px solid rgba(255,255,255,0.04)}
  .pricing-card li:last-child{border-bottom:none}
  .pricing-credits{text-align:center;font-size:.88rem;color:rgba(255,255,255,0.4);margin-bottom:12px}
  .pricing-enterprise{text-align:center;font-size:.88rem;color:rgba(255,255,255,0.35);margin-bottom:0}
  .pricing-enterprise a{color:#60A5FA;text-decoration:none}
  .pricing-enterprise a:hover{text-decoration:underline}

  @media(max-width:768px){
    .cloud-grid,.pricing-grid{grid-template-columns:1fr}
    .cloud-ctas{flex-direction:column;align-items:center}
  }
</style>
