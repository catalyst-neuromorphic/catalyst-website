---
import ChipFloorplan from '../../components/ChipFloorplan.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>N3 — Catalyst Neuromorphic Processor</title>
<meta name="description" content="128-core neuromorphic SoC with hybrid ANN/SNN computing, hardware virtualization, and on-chip continual learning. FPGA validated." />
<link rel="canonical" href="https://catalyst-neuromorphic.com/processors/n3" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta property="og:title" content="N3 — Catalyst Neuromorphic Processor" />
<meta property="og:description" content="128-core neuromorphic SoC with hybrid ANN/SNN, hardware virtualization, and on-chip continual learning." />
<meta property="og:type" content="website" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{
    background:#050507;color:#fff;
    font-family:'Plus Jakarta Sans',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
    -webkit-font-smoothing:antialiased;overflow-x:hidden;
  }
  body::after{
    content:'';position:fixed;inset:0;pointer-events:none;z-index:9999;opacity:.035;
    background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat:repeat;background-size:256px;
  }

  /* NAV */
  .nav{
    position:fixed;top:0;left:0;right:0;z-index:100;
    display:flex;align-items:center;justify-content:space-between;
    padding:30px 56px;transition:all .6s ease;
  }
  .nav.scrolled{
    background:rgba(5,5,7,0.55);
    backdrop-filter:blur(24px) saturate(180%);
    -webkit-backdrop-filter:blur(24px) saturate(180%);
    padding:20px 56px;
  }
  .nav.scrolled::after{opacity:1}
  .nav::after{
    content:'';position:absolute;bottom:-20px;left:0;right:0;height:20px;
    background:linear-gradient(180deg,rgba(5,5,7,0.4),transparent);
    opacity:0;transition:opacity .6s ease;pointer-events:none;
  }
  .nav-logo{
    font-family:'Space Grotesk',system-ui,sans-serif;
    font-size:1.9rem;font-weight:700;color:#fff;
    letter-spacing:-0.02em;text-decoration:none;
  }
  .nav-links{display:flex;align-items:center;gap:50px}
  .nav-links a{
    font-size:1.2rem;font-weight:500;color:rgba(255,255,255,0.6);
    text-decoration:none;transition:color .25s;
  }
  .nav-links a:hover{color:#fff}
  .auth-area{position:relative}
  .avatar-btn{width:34px;height:34px;border-radius:50%;background:rgba(59,130,246,0.15);border:1px solid rgba(59,130,246,0.25);color:#60A5FA;cursor:pointer;display:none;align-items:center;justify-content:center;transition:background .2s}
  .avatar-btn:hover{background:rgba(59,130,246,0.25)}
  .avatar-dropdown{position:absolute;top:calc(100% + 12px);right:0;background:rgba(15,15,20,0.92);backdrop-filter:blur(24px) saturate(180%);border:1px solid rgba(255,255,255,0.08);border-radius:14px;padding:6px;min-width:180px;opacity:0;visibility:hidden;transform:translateY(-6px);transition:opacity .2s,visibility .2s,transform .2s;z-index:200}
  .avatar-dropdown.open{opacity:1;visibility:visible;transform:translateY(0)}
  .avatar-dropdown a,.avatar-dropdown button{display:block;width:100%;padding:9px 14px;border-radius:8px;font-family:'Plus Jakarta Sans',sans-serif;font-size:.85rem;font-weight:500;color:rgba(255,255,255,0.6);text-decoration:none;text-align:left;background:none;border:none;cursor:pointer;transition:background .15s,color .15s}
  .avatar-dropdown a:hover,.avatar-dropdown button:hover{background:rgba(255,255,255,0.06);color:#fff}
  .avatar-divider{height:1px;background:rgba(255,255,255,0.06);margin:4px 0}

  /* SUB-NAV */
  .sub-nav{
    position:fixed;top:0;left:0;right:0;z-index:90;
    display:flex;align-items:center;justify-content:center;gap:32px;
    padding:14px 24px;
    background:rgba(5,5,7,0.85);
    backdrop-filter:blur(20px);
    -webkit-backdrop-filter:blur(20px);
    border-bottom:1px solid rgba(255,255,255,0.04);
    opacity:0;transform:translateY(-100%);
    transition:opacity .3s,transform .3s;
    pointer-events:none;
  }
  .sub-nav.visible{opacity:1;transform:translateY(0);pointer-events:auto}
  .sub-nav a{
    font-size:.78rem;font-weight:500;
    color:rgba(255,255,255,0.35);
    text-decoration:none;transition:color .25s;
    white-space:nowrap;
  }
  .sub-nav a:hover,.sub-nav a.active{color:rgba(255,255,255,0.8)}

  /* HERO */
  .hero{
    min-height:100vh;display:flex;flex-direction:column;
    align-items:center;justify-content:center;
    text-align:center;padding:100px 40px 60px;
    position:relative;
  }
  .hero-chip{margin-bottom:32px}
  .hero-chip svg{width:340px;height:auto}
  .wt-chip svg{width:420px;height:auto;transition:opacity .4s}
  .hero h1{
    font-family:'Space Grotesk',system-ui,sans-serif;
    font-size:clamp(5rem,12vw,10rem);font-weight:700;
    letter-spacing:-0.04em;line-height:0.9;
  }
  .hero-sub{
    font-size:clamp(1rem,1.8vw,1.3rem);
    color:rgba(255,255,255,0.4);margin-top:16px;
    max-width:560px;line-height:1.6;
  }
  .hero-badge{
    display:inline-flex;align-items:center;gap:8px;
    margin-top:28px;padding:8px 20px;border-radius:100px;
    background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.2);
    font-size:.82rem;font-weight:600;color:rgba(34,197,94,0.9);
  }
  .hero-badge .dot{
    width:6px;height:6px;border-radius:50%;
    background:rgba(34,197,94,0.9);
    animation:pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot{0%,100%{opacity:1}50%{opacity:.4}}
  .hero-ctas{display:flex;gap:14px;margin-top:24px}
  .hero-scroll{
    position:absolute;bottom:40px;left:50%;transform:translateX(-50%);
    width:24px;height:40px;border-radius:12px;
    border:1px solid rgba(255,255,255,0.15);
    display:flex;justify-content:center;padding-top:8px;
  }
  .hero-scroll span{
    width:3px;height:8px;border-radius:2px;
    background:rgba(255,255,255,0.3);
    animation:scroll-pulse 2s ease-in-out infinite;
  }
  @keyframes scroll-pulse{0%,100%{transform:translateY(0);opacity:.3}50%{transform:translateY(8px);opacity:.8}}

  /* WALKTHROUGH */
  .walkthrough{position:relative;height:600vh}
  .walkthrough-sticky{
    position:sticky;top:0;height:100vh;
    display:flex;align-items:center;
    max-width:1200px;margin:0 auto;
    padding:0 48px;gap:60px;
  }
  .wt-text{flex:1;min-width:0}
  .wt-chip{flex:0 0 auto;position:relative}
  .wt-chip svg{width:420px;height:auto;transition:opacity .4s}
  .wt-step{
    position:absolute;top:50%;left:0;right:0;
    transform:translateY(-50%);
    opacity:0;transition:opacity .5s ease;
    pointer-events:none;
  }
  .wt-step.active{opacity:1;pointer-events:auto}
  .wt-step-eyebrow{
    font-size:.7rem;font-weight:600;
    text-transform:uppercase;letter-spacing:.12em;
    color:rgba(59,130,246,0.7);margin-bottom:12px;
  }
  .wt-step h2{
    font-family:'Space Grotesk',system-ui,sans-serif;
    font-size:clamp(1.8rem,3vw,2.6rem);font-weight:700;
    letter-spacing:-0.02em;line-height:1.1;margin-bottom:16px;
  }
  .wt-step p{
    font-size:1rem;color:rgba(255,255,255,0.45);
    line-height:1.7;max-width:420px;
  }
  .wt-dots{
    position:absolute;right:24px;top:50%;transform:translateY(-50%);
    display:flex;flex-direction:column;gap:10px;
  }
  .wt-dot{
    width:6px;height:6px;border-radius:50%;
    background:rgba(255,255,255,0.12);
    transition:all .3s;
  }
  .wt-dot.active{
    background:rgba(59,130,246,0.8);
    box-shadow:0 0 8px rgba(59,130,246,0.4);
  }
  .chip-wt [data-region]{transition:opacity .5s ease,filter .5s ease}
  .chip-wt [data-region].dim{opacity:.12;filter:saturate(0.2)}
  .chip-wt [data-region].active{opacity:1;filter:saturate(1.3) brightness(1.2)}

  /* STATS */
  .stats-section{
    max-width:1100px;margin:0 auto;
    padding:120px 40px;
  }
  .stats-category{margin-bottom:48px}
  .stats-category:last-child{margin-bottom:0}
  .stats-category-label{
    font-size:.65rem;font-weight:600;text-transform:uppercase;
    letter-spacing:.12em;color:rgba(59,130,246,0.6);margin-bottom:20px;
  }
  .stats-grid{
    display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:32px;
  }
  .stat{text-align:left}
  .stat-num{
    font-family:'Space Grotesk',system-ui;
    font-size:clamp(1.8rem,3.5vw,2.6rem);font-weight:700;
    letter-spacing:-0.03em;
    background:linear-gradient(135deg,#fff 0%,rgba(255,255,255,0.7) 100%);
    -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  }
  .stat-label{
    font-size:.75rem;color:rgba(255,255,255,0.3);
    margin-top:6px;text-transform:uppercase;
    letter-spacing:.05em;font-weight:500;
  }

  /* WHAT'S NEW */
  .whats-new{max-width:1000px;margin:0 auto;padding:80px 40px}
  .whats-new h2{
    font-family:'Space Grotesk',system-ui;
    font-size:clamp(2rem,4vw,3rem);font-weight:700;
    letter-spacing:-0.02em;text-align:center;margin-bottom:48px;
  }
  .feature-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:20px}
  .feature-card{
    padding:28px 24px;border-radius:16px;
    background:rgba(255,255,255,0.03);
    border:1px solid rgba(255,255,255,0.06);
    transition:border-color .3s,background .3s;
  }
  .feature-card:hover{border-color:rgba(59,130,246,0.15);background:rgba(59,130,246,0.03)}
  .feature-card h3{font-size:.95rem;font-weight:600;margin-bottom:8px}
  .feature-card p{font-size:.82rem;color:rgba(255,255,255,0.35);line-height:1.6}
  .feature-card .tag{
    display:inline-block;font-size:.65rem;font-weight:600;
    text-transform:uppercase;letter-spacing:.08em;
    padding:3px 8px;border-radius:4px;margin-bottom:12px;
    background:rgba(59,130,246,0.1);color:rgba(59,130,246,0.8);
  }
  .feature-card .tag.green{background:rgba(34,197,94,0.1);color:rgba(34,197,94,0.8)}

  /* SDK */
  .sdk-section{
    max-width:1000px;margin:0 auto;padding:80px 40px;
    display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;
  }
  .sdk-text h2{
    font-family:'Space Grotesk',system-ui;
    font-size:clamp(1.8rem,3.5vw,2.5rem);font-weight:700;
    letter-spacing:-0.02em;margin-bottom:12px;
  }
  .sdk-text p{font-size:1rem;color:rgba(255,255,255,0.4);line-height:1.6;margin-bottom:20px}
  .sdk-text .install{
    font-family:'JetBrains Mono',monospace;font-size:.85rem;
    color:rgba(59,130,246,0.8);background:rgba(59,130,246,0.06);
    padding:8px 16px;border-radius:8px;display:inline-block;
    border:1px solid rgba(59,130,246,0.12);
  }
  .code-block{
    border-radius:16px;overflow:hidden;
    background:rgba(255,255,255,0.03);
    border:1px solid rgba(255,255,255,0.06);
  }
  .code-header{
    padding:12px 20px;border-bottom:1px solid rgba(255,255,255,0.04);
    display:flex;gap:6px;
  }
  .code-dot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,0.08)}
  .code-body{
    padding:20px;font-family:'JetBrains Mono',monospace;
    font-size:.78rem;line-height:1.8;color:rgba(255,255,255,0.6);
    overflow-x:auto;
  }
  .code-body .kw{color:#c084fc}
  .code-body .fn{color:#60a5fa}
  .code-body .str{color:#86efac}
  .code-body .num{color:#fbbf24}
  .code-body .cm{color:rgba(255,255,255,0.25)}

  /* COMPARISON TABLE */
  .comparison{max-width:1100px;margin:0 auto;padding:100px 40px}
  .comparison h2{
    font-family:'Space Grotesk',system-ui;
    font-size:clamp(2rem,4vw,3rem);font-weight:700;
    letter-spacing:-0.02em;text-align:center;margin-bottom:48px;
  }
  .comp-wrap{
    border-radius:16px;overflow:hidden;
    border:1px solid rgba(255,255,255,0.06);
    overflow-x:auto;
  }
  .comp-table{width:100%;border-collapse:collapse;min-width:700px}
  .comp-table th{
    padding:16px 18px;text-align:left;
    font-size:.65rem;font-weight:600;text-transform:uppercase;
    letter-spacing:.08em;color:rgba(255,255,255,0.25);
    border-bottom:1px solid rgba(255,255,255,0.06);
    background:rgba(255,255,255,0.02);
  }
  .comp-table th.hl{color:rgba(59,130,246,0.8)}
  .comp-table td{
    padding:14px 18px;font-size:.85rem;
    border-bottom:1px solid rgba(255,255,255,0.03);
  }
  .comp-table td:first-child{color:rgba(255,255,255,0.5);font-weight:500}
  .comp-table .us{color:rgba(255,255,255,0.9);font-weight:600}
  .comp-table .them{color:rgba(255,255,255,0.25)}
  .comp-table tr:last-child td{border-bottom:none}
  .comp-table tr:hover td{background:rgba(255,255,255,0.015)}

  /* SPECS ACCORDION */
  .specs{max-width:900px;margin:0 auto;padding:100px 40px}
  .specs h2{
    font-family:'Space Grotesk',system-ui;
    font-size:clamp(2rem,4vw,3rem);font-weight:700;
    letter-spacing:-0.02em;text-align:center;margin-bottom:48px;
  }
  details.spec-group{
    border-bottom:1px solid rgba(255,255,255,0.04);
  }
  details.spec-group summary{
    padding:18px 0;cursor:pointer;
    font-size:1rem;font-weight:600;
    color:rgba(255,255,255,0.7);
    list-style:none;display:flex;justify-content:space-between;align-items:center;
  }
  details.spec-group summary::-webkit-details-marker{display:none}
  details.spec-group summary::after{
    content:'+';font-size:1.2rem;color:rgba(255,255,255,0.25);
    transition:transform .2s;
  }
  details.spec-group[open] summary::after{content:'\2212'}
  .spec-row{
    display:flex;justify-content:space-between;
    padding:10px 0;font-size:.88rem;
    border-top:1px solid rgba(255,255,255,0.02);
  }
  .spec-row span:first-child{color:rgba(255,255,255,0.4)}
  .spec-row span:last-child{color:rgba(255,255,255,0.75);font-weight:500;text-align:right}

  /* PAPER CTA */
  .paper-cta{
    max-width:600px;margin:0 auto;padding:60px 40px 80px;text-align:center;
  }
  .paper-card{
    padding:48px 40px;border-radius:24px;
    background:rgba(255,255,255,0.03);
    border:1px solid rgba(255,255,255,0.06);
  }
  .paper-card h3{font-size:1.2rem;font-weight:600;margin-bottom:8px}
  .paper-card p{font-size:.88rem;color:rgba(255,255,255,0.35);margin-bottom:24px;line-height:1.5}
  .paper-card .coming{
    display:inline-flex;align-items:center;gap:8px;
    font-size:.88rem;font-weight:500;color:rgba(255,255,255,0.3);
  }

  /* ENQUIRE CTA */
  .enquire{max-width:700px;margin:0 auto;padding:40px 40px 120px;text-align:center}
  .enquire-card{
    padding:56px 48px;border-radius:24px;
    background:rgba(59,130,246,0.04);
    border:1px solid rgba(59,130,246,0.12);
  }
  .enquire-card h2{
    font-family:'Space Grotesk',system-ui;
    font-size:clamp(1.6rem,3vw,2.2rem);font-weight:700;
    letter-spacing:-0.02em;margin-bottom:12px;
  }
  .enquire-card p{font-size:1rem;color:rgba(255,255,255,0.4);margin-bottom:32px;line-height:1.6}
  .enquire-btns{display:flex;gap:14px;justify-content:center;flex-wrap:wrap}

  /* BUTTONS */
  .btn{
    display:inline-flex;align-items:center;gap:8px;
    font-size:.9rem;font-weight:600;padding:14px 28px;
    border-radius:100px;text-decoration:none;transition:all .3s;
  }
  .btn-primary{
    color:#fff;background:linear-gradient(135deg,#3B82F6,#2563EB);
    box-shadow:0 4px 16px rgba(59,130,246,0.3);
  }
  .btn-primary:hover{box-shadow:0 6px 24px rgba(59,130,246,0.45);transform:translateY(-1px)}
  .btn-pill{
    color:rgba(255,255,255,0.7);background:rgba(255,255,255,0.06);
    border:1px solid rgba(255,255,255,0.1);
  }
  .btn-pill:hover{background:rgba(255,255,255,0.1);color:#fff;border-color:rgba(255,255,255,0.2)}

  /* GLOW BUTTONS */
  .glow-btn{position:relative;overflow:hidden;transition:box-shadow .4s ease}
  .glow-spot{
    position:absolute;top:50%;transform:translateY(-50%);
    width:200px;height:100%;display:flex;align-items:center;justify-content:center;
    z-index:0;pointer-events:none;opacity:0;will-change:transform,opacity;
  }
  .glow-spot-circle{
    position:absolute;width:120px;height:120px;border-radius:50%;
    background:radial-gradient(50% 50% at 50% 50%,rgba(255,255,255,0.90) 3.5%,rgba(96,165,250,0.70) 26.5%,rgba(147,197,253,0.50) 37.5%,rgba(59,130,246,0.25) 49%,rgba(37,99,235,0) 92.5%);
  }
  .glow-spot-wide{
    position:absolute;width:200px;height:100px;
    background:radial-gradient(43.3% 44.23% at 50% 49.51%,rgba(255,255,255,0.70) 29%,rgba(191,219,254,0.50) 48.5%,rgba(147,197,253,0.25) 60.71%,rgba(214,211,210,0) 100%);
    filter:blur(5px);
  }
  .glow-btn.glow-on{box-shadow:0 0 25px rgba(59,130,246,0.25),0 0 50px rgba(59,130,246,0.08)}

  /* FOOTER */
  .site-footer{border-top:1px solid rgba(255,255,255,0.06);padding:64px 40px 32px}
  .footer-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:40px;max-width:1100px;margin:0 auto}
  .footer-col h4{
    font-family:'Space Grotesk',sans-serif;font-size:.8rem;font-weight:600;
    text-transform:uppercase;letter-spacing:.08em;color:rgba(255,255,255,0.35);margin-bottom:20px;
  }
  .footer-col a{display:block;font-size:.88rem;color:rgba(255,255,255,0.5);text-decoration:none;margin-bottom:10px;transition:color .25s}
  .footer-col a:hover{color:#fff}
  .footer-support{max-width:1100px;margin:40px auto 0;text-align:center;font-size:.85rem;color:rgba(255,255,255,0.3)}
  .footer-support a{color:rgba(59,130,246,0.7);text-decoration:none;transition:color .25s}
  .footer-support a:hover{color:#60A5FA}
  .footer-legal{display:flex;align-items:center;gap:8px}
  .footer-legal a{color:rgba(255,255,255,0.35);text-decoration:none;transition:color .25s}
  .footer-legal a:hover{color:rgba(255,255,255,0.6)}
  .footer-bottom{
    max-width:1100px;margin:24px auto 0;padding-top:24px;
    border-top:1px solid rgba(255,255,255,0.04);
    display:flex;justify-content:space-between;align-items:center;
    font-size:.78rem;color:rgba(255,255,255,0.25);
  }

  /* ANIMATIONS */
  .reveal{opacity:0;transform:translateY(30px);transition:none}
  .reveal.visible{opacity:1;transform:translateY(0);transition:opacity .8s ease,transform .8s ease}

  /* MOBILE */
  @media(max-width:900px){
    .nav{padding:20px 24px}
    .nav.scrolled{padding:16px 24px}
    .nav-logo{font-size:1.5rem}
    .nav-links{gap:28px}
    .nav-links a{font-size:1rem}
    .hero-chip svg{width:240px}
    .walkthrough{height:auto}
    .walkthrough-sticky{
      position:relative;flex-direction:column;
      padding:80px 24px;gap:40px;height:auto;
    }
    .wt-chip svg{width:280px}
    .wt-step{position:relative;transform:none;opacity:1;margin-bottom:60px}
    .wt-dots{display:none}
    .stats-section{gap:40px;padding:80px 24px}
    .feature-grid{grid-template-columns:1fr}
    .sdk-section{grid-template-columns:1fr;padding:60px 24px}
    .comparison{padding:60px 20px}
    .specs{padding:60px 20px}
    .sub-nav{display:none}
    .footer-grid{grid-template-columns:1fr 1fr}
    .footer-bottom{flex-direction:column;gap:8px;text-align:center}
  }
  @media(max-width:600px){
