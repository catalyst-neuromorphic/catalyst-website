---
import BaseLayout from '../../layouts/BaseLayout.astro';
// V8 — FULL-VIEWPORT CINEMATIC: SpaceX mission style. One idea per screen. Keynote feel.
---

<BaseLayout title="About — Catalyst Neuromorphic" description="Building neuromorphic processors to challenge the way intelligence is computed." hasFog={true}>

  <!-- SCROLL INDICATOR DOTS (decorative, CSS only) -->
  <div class="v8-scroll-dots" aria-hidden="true">
    <span class="v8-dot"></span>
    <span class="v8-dot"></span>
    <span class="v8-dot"></span>
    <span class="v8-dot"></span>
    <span class="v8-dot"></span>
    <span class="v8-dot"></span>
    <span class="v8-dot"></span>
  </div>

  <!-- SECTION 1: Hero — full viewport -->
  <section class="v8-screen v8-screen--full" style="position:relative;z-index:1;">
    <div class="v8-center">
      <h1 class="v8-hero-h1 reveal">AI has a hardware problem.</h1>
      <p class="v8-hero-sub reveal">We're building the processors to fix it.</p>
    </div>
  </section>

  <!-- SECTION 2: The brain comparison — single powerful paragraph -->
  <section class="v8-screen v8-screen--full" style="position:relative;z-index:1;">
    <div class="v8-center">
      <div class="v8-narrow reveal">
        <p class="v8-statement">The human brain does all of this on 20 watts. It learns continuously. It processes information in real-time. It runs at the edge, on-device, with no internet connection required. The gap between biological intelligence and artificial intelligence isn't a software problem. It's a hardware problem.</p>
      </div>
    </div>
  </section>

  <!-- SECTION 3: Neuromorphic processors -->
  <section class="v8-screen v8-screen--full" style="position:relative;z-index:1;">
    <div class="v8-center">
      <div class="v8-narrow">
        <h2 class="v8-h2 reveal">Neuromorphic processors.</h2>
        <p class="v8-body reveal">Neuromorphic chips compute the way neurons do. They're event-driven &mdash; they only consume energy when there's something to process. They can learn on the hardware itself, not just run pre-trained models. They operate at the edge, on-device, without cloud dependency. And they do it at a fraction of the power cost.</p>
      </div>
    </div>
  </section>

  <!-- SECTION 4: The open alternative -->
  <section class="v8-screen v8-screen--full" style="position:relative;z-index:1;">
    <div class="v8-center">
      <div class="v8-narrow reveal">
        <p class="v8-statement">Catalyst is building the open alternative. Full processor designs, published research, and a cloud platform anyone can use today. We're not asking for permission to compete with billion-dollar companies. We're just doing it.</p>
      </div>
    </div>
  </section>

  <!-- FOUNDER — small centered block between sections -->
  <section class="v8-interlude" style="position:relative;z-index:1;">
    <div class="v8-center-block reveal">
      <p class="v8-founder"><strong class="v8-founder-name">Henry Shulayev Barnes</strong> &mdash; engineering student at the University of Aberdeen. Started Catalyst because the neuromorphic hardware that should exist doesn't, and the hardware that does exist isn't accessible. Currently a member of Techscaler, Scotland's tech startup community.</p>
    </div>
  </section>

  <!-- SECTION 5: Where we are -->
  <section class="v8-screen v8-screen--full" style="position:relative;z-index:1;">
    <div class="v8-center">
      <div class="v8-narrow">
        <h2 class="v8-h2 reveal">Where we are.</h2>
        <p class="v8-body reveal">We're early. Two processor generations are designed, built in software, and validated on real hardware. Both have published papers you can read today. A cloud API is live &mdash; you can run a neuromorphic network right now, without buying anything.</p>
        <p class="v8-body reveal">We're raising funding and building toward manufactured silicon. That's the goal: a physical chip you can hold, running real neuromorphic intelligence. We're not there yet. But the architecture is complete, tested, and protected by patent.</p>
      </div>
    </div>
  </section>

  <!-- SECTION 6: Trust — vertical stack with arrow links -->
  <section class="v8-screen v8-screen--short" style="position:relative;z-index:1;">
    <div class="v8-center">
      <div class="v8-trust-stack reveal-stagger">
        <a href="/research" class="v8-trust-line">
          <span class="v8-trust-text">Read the papers</span>
          <span class="v8-trust-detail">Zenodo DOIs, open access</span>
          <span class="v8-trust-arrow">&rarr;</span>
        </a>
        <a href="https://api.catalyst-neuromorphic.com" target="_blank" rel="noopener noreferrer" class="v8-trust-line">
          <span class="v8-trust-text">Try the cloud</span>
          <span class="v8-trust-detail">API live, free tier</span>
          <span class="v8-trust-arrow">&rarr;</span>
        </a>
        <a href="/processors" class="v8-trust-line">
          <span class="v8-trust-text">Check the hardware</span>
          <span class="v8-trust-detail">Real FPGA boards</span>
          <span class="v8-trust-arrow">&rarr;</span>
        </a>
        <a href="https://github.com/catalyst-neuromorphic" target="_blank" rel="noopener noreferrer" class="v8-trust-line">
          <span class="v8-trust-text">Join the community</span>
          <span class="v8-trust-detail">Open GitHub, growing backers</span>
          <span class="v8-trust-arrow">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- IP — small text at bottom -->
  <section class="v8-ip-section" style="position:relative;z-index:1;">
    <div class="v8-ip reveal">
      <span class="v8-ip-item"><span class="v8-ip-label">UK Patents</span> Filed Feb 2026</span>
      <span class="v8-ip-sep">&middot;</span>
      <span class="v8-ip-item"><span class="v8-ip-label">RTL</span> BSL 1.1 &mdash; proprietary</span>
      <span class="v8-ip-sep">&middot;</span>
      <span class="v8-ip-item"><span class="v8-ip-label">SDK</span> BSL 1.1</span>
      <span class="v8-ip-sep">&middot;</span>
      <span class="v8-ip-item"><span class="v8-ip-label">Papers</span> Open access Zenodo</span>
      <span class="v8-ip-sep">&middot;</span>
      <span class="v8-ip-item"><span class="v8-ip-label">API Client</span> MIT &mdash; open source</span>
    </div>
  </section>

  <!-- GET IN TOUCH -->
  <section class="connect-section" style="position:relative;z-index:1;">
    <h2 style="font-family:'Space Grotesk',sans-serif; font-size:clamp(2.4rem,5vw,3.6rem); font-weight:700; letter-spacing:-0.035em; line-height:1.08; text-align:center; margin-bottom:18px;">Get in touch.</h2>
    <p class="connect-email"><a href="mailto:henry@catalyst-neuromorphic.com">henry@catalyst-neuromorphic.com</a></p>
    <div class="connect-grid">
      <a href="https://github.com/catalyst-neuromorphic" target="_blank" rel="noopener noreferrer" class="connect-card"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65S8.93 17.38 9 18v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg><span class="connect-label">GitHub</span><span class="connect-sub">Source &amp; contributions</span></a>
      <a href="/research" class="connect-card"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg><span class="connect-label">Research</span><span class="connect-sub">Papers &amp; benchmarks</span></a>
    </div>
  </section>

  <style is:global>
    /* =============================================
       V8 — Full-Viewport Cinematic (SpaceX style)
       One idea per screen. Keynote presentation feel.
       ============================================= */

    /* Scroll indicator dots — right side, fixed */
    .v8-scroll-dots {
      position: fixed;
      right: 28px;
      top: 50%;
      transform: translateY(-50%);
      display: flex;
      flex-direction: column;
      gap: 14px;
      z-index: 50;
    }
    .v8-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.12);
      border: 1px solid rgba(255, 255, 255, 0.08);
      transition: background 0.4s, transform 0.3s;
    }
    .v8-dot:first-child {
      background: rgba(59, 130, 246, 0.5);
      border-color: rgba(59, 130, 246, 0.3);
    }

    /* Full-viewport screen */
    .v8-screen--full {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 80px 32px;
    }
    .v8-screen--short {
      min-height: 80vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 80px 32px;
    }

    /* Centered container */
    .v8-center {
      max-width: 960px;
      width: 100%;
      text-align: center;
    }

    /* Narrow constraint for body text */
    .v8-narrow {
      max-width: 600px;
      margin: 0 auto;
    }

    /* Hero */
    .v8-hero-h1 {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(3rem, 7vw, 5.5rem);
      font-weight: 400;
      letter-spacing: -0.04em;
      line-height: 1.05;
      color: #fff;
    }
    .v8-hero-sub {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: clamp(1.1rem, 2.5vw, 1.4rem);
      font-weight: 400;
      color: rgba(255, 255, 255, 0.3);
      margin-top: 32px;
      line-height: 1.6;
    }

    /* Statement paragraph — the powerful standalone quotes */
    .v8-statement {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: clamp(1.15rem, 2.5vw, 1.5rem);
      line-height: 1.8;
      color: rgba(255, 255, 255, 0.45);
      text-align: center;
    }

    /* Section heading */
    .v8-h2 {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 600;
      letter-spacing: -0.04em;
      line-height: 1.08;
      color: #fff;
      margin-bottom: 32px;
    }

    /* Body text */
    .v8-body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: clamp(1rem, 2vw, 1.15rem);
      line-height: 1.85;
      color: rgba(255, 255, 255, 0.4);
      margin-bottom: 24px;
      text-align: center;
    }
    .v8-body:last-child {
      margin-bottom: 0;
    }

    /* Founder interlude */
    .v8-interlude {
      padding: 80px 32px;
      position: relative;
      z-index: 1;
    }
    .v8-center-block {
      max-width: 520px;
      margin: 0 auto;
      text-align: center;
    }
    .v8-founder {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.95rem;
      line-height: 1.8;
      color: rgba(255, 255, 255, 0.3);
    }
    .v8-founder-name {
      color: rgba(255, 255, 255, 0.6);
      font-weight: 600;
    }

    /* Trust stack — vertical lines with arrows */
    .v8-trust-stack {
      display: flex;
      flex-direction: column;
      gap: 0;
      max-width: 560px;
      margin: 0 auto;
      text-align: left;
    }
    .v8-trust-line {
      display: flex;
      align-items: center;
      padding: 24px 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      text-decoration: none;
      color: #fff;
      transition: opacity 0.3s;
    }
    .v8-trust-line:first-child {
      border-top: 1px solid rgba(255, 255, 255, 0.06);
    }
    .v8-trust-line:hover {
      opacity: 0.7;
    }
    .v8-trust-text {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 1.05rem;
      font-weight: 600;
      letter-spacing: -0.01em;
      color: rgba(255, 255, 255, 0.85);
      flex-shrink: 0;
    }
    .v8-trust-detail {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.82rem;
      color: rgba(255, 255, 255, 0.25);
      margin-left: auto;
      padding-left: 24px;
      white-space: nowrap;
    }
    .v8-trust-arrow {
      font-size: 1.1rem;
      color: rgba(59, 130, 246, 0.5);
      margin-left: 16px;
      flex-shrink: 0;
      transition: transform 0.3s, color 0.3s;
    }
    .v8-trust-line:hover .v8-trust-arrow {
      transform: translateX(4px);
      color: rgba(59, 130, 246, 0.8);
    }

    /* IP section */
    .v8-ip-section {
      padding: 40px 32px 20px;
    }
    .v8-ip {
      text-align: center;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.78rem;
      line-height: 2.2;
      color: rgba(255, 255, 255, 0.25);
    }
    .v8-ip-label {
      color: rgba(255, 255, 255, 0.45);
      font-weight: 600;
    }
    .v8-ip-sep {
      margin: 0 12px;
      color: rgba(255, 255, 255, 0.08);
    }

    /* Responsive */
    @media (max-width: 768px) {
      .v8-screen--full {
        min-height: 60vh;
        padding: 60px 24px;
      }
      .v8-screen--short {
        min-height: 50vh;
        padding: 60px 24px;
      }
      .v8-interlude {
        padding: 60px 24px;
      }

      /* Hide scroll dots on mobile */
      .v8-scroll-dots {
        display: none;
      }

      .v8-trust-detail {
        display: none;
      }
      .v8-trust-text {
        font-size: 0.95rem;
      }

      .v8-ip-sep {
        display: none;
      }
      .v8-ip-item {
        display: block;
        margin-bottom: 2px;
      }
    }

    /* Connect section */
    .connect-section{max-width:1100px;margin:0 auto;padding:80px 32px 100px}.connect-email{font-family:'Space Grotesk',sans-serif;font-size:clamp(1.4rem,3vw,2.2rem);font-weight:600;letter-spacing:-0.02em;text-align:center;margin-top:16px;margin-bottom:56px}.connect-email a{color:rgba(59,130,246,0.8);text-decoration:none;transition:color 0.3s}.connect-email a:hover{color:#60A5FA}.connect-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}.connect-card{display:flex;flex-direction:column;align-items:center;text-align:center;padding:36px 24px;border-radius:20px;text-decoration:none;color:#fff;background:linear-gradient(165deg,rgba(255,255,255,0.12) 0%,rgba(255,255,255,0.05) 35%,rgba(255,255,255,0.025) 100%);backdrop-filter:blur(28px) saturate(190%) brightness(1.06);-webkit-backdrop-filter:blur(28px) saturate(190%) brightness(1.06);border:1px solid transparent;box-shadow:0 8px 32px rgba(0,0,0,0.45),inset 0 1px 0 rgba(255,255,255,0.14),inset 0 -1px 0 rgba(255,255,255,0.02);position:relative;overflow:hidden;transition:box-shadow 0.5s,transform 0.3s}.connect-card:hover{transform:translateY(-3px);box-shadow:0 12px 48px rgba(0,0,0,0.55),inset 0 1px 0 rgba(255,255,255,0.18),inset 0 -1px 0 rgba(255,255,255,0.03)}.connect-card::before{content:'';position:absolute;inset:0;border-radius:20px;padding:1px;background:linear-gradient(135deg,rgba(59,130,246,0.22) 0%,rgba(59,130,246,0.06) 25%,rgba(59,130,246,0.02) 50%,rgba(59,130,246,0.06) 75%,rgba(59,130,246,0.18) 100%);-webkit-mask:linear-gradient(#fff 0 0) content-box,linear-gradient(#fff 0 0);-webkit-mask-composite:xor;mask-composite:exclude;pointer-events:none;z-index:5;opacity:0.55;transition:opacity 0.4s}.connect-card:hover::before{opacity:1}.connect-card svg{color:#60A5FA;margin-bottom:16px;position:relative;z-index:2}.connect-label{font-family:'Space Grotesk',sans-serif;font-size:1.05rem;font-weight:600;margin-bottom:6px;position:relative;z-index:2}.connect-sub{font-size:0.78rem;color:rgba(255,255,255,0.4);position:relative;z-index:2}@media(max-width:640px){.connect-grid{grid-template-columns:1fr}}
  </style>

</BaseLayout>
