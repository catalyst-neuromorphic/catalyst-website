---
import BaseLayout from '../../layouts/BaseLayout.astro';

const tiers = [
  {
    name: 'Free',
    deposit: '£0',
    description: 'For exploration and small experiments.',
    features: [
      '10 jobs per day',
      '1,024 neurons max',
      '1,000 timesteps max',
      '30s max runtime',
      'Community support',
    ],
    cta: 'Get started free',
    ctaHref: '/console/signup',
    highlight: false,
  },
  {
    name: 'Researcher',
    deposit: '£5+',
    description: 'For academic research and coursework.',
    features: [
      '100 jobs per day',
      '32,768 neurons max',
      '100,000 timesteps max',
      '5 min max runtime',
      'Email support',
    ],
    cta: 'Add credits',
    ctaHref: '/console/billing',
    highlight: true,
  },
  {
    name: 'Startup',
    deposit: '£50+',
    description: 'For product development and benchmarking.',
    features: [
      '500 jobs per day',
      '131,072 neurons max',
      '1M timesteps max',
      '30 min max runtime',
      'Priority support',
    ],
    cta: 'Add credits',
    ctaHref: '/console/billing',
    highlight: false,
  },
  {
    name: 'Enterprise',
    deposit: '£200+',
    description: 'For production workloads and dedicated capacity.',
    features: [
      'Unlimited jobs',
      '131,072 neurons max',
      '10M timesteps max',
      '1 hour max runtime',
      'Dedicated support',
    ],
    cta: 'Add credits',
    ctaHref: '/console/billing',
    highlight: false,
  },
];

const creditPacks = [
  { amount: 5, label: '£5' },
  { amount: 20, label: '£20' },
  { amount: 50, label: '£50' },
  { amount: 100, label: '£100' },
  { amount: 200, label: '£200' },
];
---

<BaseLayout title="Pricing — Catalyst Cloud" description="Simple, transparent pricing for neuromorphic compute. Prepaid credits, no subscriptions.">

  <!-- Header -->
  <section class="pt-36 pb-12 px-6 md:px-12 text-center">
    <p class="text-sm text-catalyst-blue font-medium tracking-wider uppercase mb-4">Pricing</p>
    <h1 class="text-[clamp(2.5rem,5vw,4rem)] font-bold tracking-tighter">
      Pay as you go.
    </h1>
    <p class="text-lg text-white/40 mt-4 max-w-[550px] mx-auto">
      Start free. Add credits when you need more. Your tier advances automatically as you deposit.
    </p>
  </section>

  <!-- Pricing Grid -->
  <section class="py-16 px-6 md:px-12">
    <div class="max-w-[1200px] mx-auto grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {tiers.map(tier => (
        <div class={`reveal rounded-xl p-6 flex flex-col ${tier.highlight ? 'glass-accent ring-1 ring-catalyst-blue/30' : 'glass'}`}>
          <div class="mb-6">
            <h3 class="text-lg font-semibold">{tier.name}</h3>
            <div class="mt-3">
              <span class="text-3xl font-bold">{tier.deposit}</span>
              <span class="text-sm text-white/40 ml-1">cumulative deposit</span>
            </div>
            <p class="text-sm text-white/40 mt-2">{tier.description}</p>
          </div>
          <ul class="flex-1 space-y-3 mb-6">
            {tier.features.map(f => (
              <li class="flex items-start gap-2 text-sm text-white/60">
                <span class="text-catalyst-blue mt-0.5 flex-shrink-0">&#10003;</span>
                {f}
              </li>
            ))}
          </ul>
          <a href={tier.ctaHref} class={`text-center py-2.5 rounded-lg text-sm font-medium transition-all duration-200 no-underline ${tier.highlight ? 'bg-catalyst-blue text-white hover:bg-catalyst-blue/80' : 'border border-white/10 text-white/70 hover:text-white hover:border-white/20'}`}>
            {tier.cta}
          </a>
        </div>
      ))}
    </div>
  </section>

  <!-- Credit Packs -->
  <section class="py-16 px-6 md:px-12">
    <div class="max-w-[800px] mx-auto text-center">
      <h2 class="reveal text-[clamp(2rem,3.5vw,2.5rem)] font-bold tracking-tight mb-4">Add credits</h2>
      <p class="text-white/40 mb-8">Credits never expire. Compute rate: £0.005/sec (£18/hr).</p>
      <div class="reveal flex justify-center gap-4 flex-wrap">
        {creditPacks.map(pack => (
          <a href="/console/billing" class="glass hover:glass-accent px-6 py-3 rounded-lg text-lg font-bold no-underline text-green-400 transition-all duration-200">
            {pack.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Compute Pricing -->
  <section class="py-32 px-6 md:px-12">
    <div class="max-w-[800px] mx-auto text-center">
      <h2 class="reveal text-[clamp(2rem,3.5vw,2.5rem)] font-bold tracking-tight mb-8">How it works</h2>
      <div class="reveal glass rounded-xl p-8 text-left">
        <div class="grid md:grid-cols-3 gap-6 mb-8">
          <div>
            <div class="text-catalyst-blue text-2xl font-bold mb-2">1.</div>
            <h4 class="font-semibold text-sm mb-1">Sign up free</h4>
            <p class="text-sm text-white/40">Create an account and get 10 free jobs per day. No credit card needed.</p>
          </div>
          <div>
            <div class="text-catalyst-blue text-2xl font-bold mb-2">2.</div>
            <h4 class="font-semibold text-sm mb-1">Add credits</h4>
            <p class="text-sm text-white/40">Buy credit packs when you need more. Your tier advances with cumulative deposit.</p>
          </div>
          <div>
            <div class="text-catalyst-blue text-2xl font-bold mb-2">3.</div>
            <h4 class="font-semibold text-sm mb-1">Run simulations</h4>
            <p class="text-sm text-white/40">Credits are deducted per second of compute. Unused credits never expire.</p>
          </div>
        </div>
        <div class="grid md:grid-cols-2 gap-6 border-t border-white/5 pt-6">
          <div>
            <h4 class="font-semibold text-sm mb-3">Example: Small experiment</h4>
            <div class="text-sm text-white/40 space-y-1">
              <p>100 neurons, 1,000 timesteps</p>
              <p>Compute: ~0.05 seconds</p>
              <p>Cost: £0.00025</p>
              <p class="text-white/60 font-medium mt-2">Free tier: £0.00</p>
            </div>
          </div>
          <div>
            <h4 class="font-semibold text-sm mb-3">Example: Full research run</h4>
            <div class="text-sm text-white/40 space-y-1">
              <p>32K neurons, 100K timesteps, 50 trials</p>
              <p>Compute: ~300 seconds total</p>
              <p>Cost: £1.50</p>
              <p class="text-white/60 font-medium mt-2">Less than a coffee.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-32 px-6 md:px-12">
    <div class="max-w-[700px] mx-auto">
      <h2 class="reveal text-[clamp(2rem,3.5vw,2.5rem)] font-bold tracking-tight text-center mb-12">Questions</h2>
      <div class="space-y-6">
        <div class="reveal">
          <h3 class="font-semibold mb-2">Is the free tier actually free?</h3>
          <p class="text-sm text-white/40 leading-relaxed">Yes. 10 jobs per day, up to 1,024 neurons, forever. No credit card required.</p>
        </div>
        <div class="reveal">
          <h3 class="font-semibold mb-2">Do credits expire?</h3>
          <p class="text-sm text-white/40 leading-relaxed">No. Credits stay on your account until you use them. There are no monthly fees or subscriptions.</p>
        </div>
        <div class="reveal">
          <h3 class="font-semibold mb-2">How does tier advancement work?</h3>
          <p class="text-sm text-white/40 leading-relaxed">Your tier is based on how much you've deposited in total, not per month. Deposit £5 total and you're a Researcher forever. Tiers never downgrade.</p>
        </div>
        <div class="reveal">
          <h3 class="font-semibold mb-2">What neuromorphic model do you run?</h3>
          <p class="text-sm text-white/40 leading-relaxed">Hardware-accurate Loihi 2 parity. Leak-integrate-fire neurons with 4 dendritic compartments, configurable thresholds, refractory periods, synaptic delays, and multiple learning rules including STDP and 3-factor reward modulation.</p>
        </div>
        <div class="reveal">
          <h3 class="font-semibold mb-2">What's the latency?</h3>
          <p class="text-sm text-white/40 leading-relaxed">Small simulations complete in under a second. Larger ones scale linearly with neuron count and timesteps. Results are available via polling.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-6 md:px-12 text-center">
    <a href="/console/signup" class="reveal btn-primary inline-flex px-10 py-3 text-sm">Create free account &rarr;</a>
  </section>

</BaseLayout>
