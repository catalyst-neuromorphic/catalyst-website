---
import BaseLayout from '../../layouts/BaseLayout.astro';

const tiers = [
  {
    name: 'Free',
    price: '0',
    period: 'forever',
    description: 'For exploration and small experiments.',
    features: [
      '10 jobs per day',
      '1,024 neurons max',
      '1,000 timesteps max',
      '30s max runtime',
      'Community support',
    ],
    cta: 'Get started',
    ctaHref: '/cloud/docs',
    highlight: false,
  },
  {
    name: 'Researcher',
    price: '0',
    period: 'per month + compute',
    description: 'For academic research and coursework.',
    features: [
      '100 jobs per day',
      '32,768 neurons max',
      '100,000 timesteps max',
      '5 min max runtime',
      'Email support',
      'Compute: £18/hr',
    ],
    cta: 'Sign up',
    ctaHref: '/cloud/docs',
    highlight: true,
  },
  {
    name: 'Startup',
    price: '49',
    period: 'per month + compute',
    description: 'For product development and benchmarking.',
    features: [
      '500 jobs per day',
      '131,072 neurons max',
      '1M timesteps max',
      '30 min max runtime',
      'Priority support',
      'Compute: £14.40/hr',
    ],
    cta: 'Sign up',
    ctaHref: '/cloud/docs',
    highlight: false,
  },
  {
    name: 'Enterprise',
    price: '199',
    period: 'per month + compute',
    description: 'For production workloads and dedicated capacity.',
    features: [
      'Unlimited jobs',
      '131,072 neurons max',
      '10M timesteps max',
      '1 hour max runtime',
      'Dedicated support',
      'Compute: £10.80/hr',
    ],
    cta: 'Contact us',
    ctaHref: 'mailto:henry@catalyst-neuromorphic.com',
    highlight: false,
  },
];
---

<BaseLayout title="Pricing — Catalyst Cloud" description="Simple, transparent pricing for neuromorphic compute.">

  <!-- Header -->
  <section class="pt-36 pb-12 px-6 md:px-12 text-center">
    <p class="text-sm text-catalyst-blue font-medium tracking-wider uppercase mb-4">Pricing</p>
    <h1 class="text-[clamp(2.5rem,5vw,4rem)] font-bold tracking-tighter">
      Simple, transparent pricing.
    </h1>
    <p class="text-lg text-white/40 mt-4 max-w-[500px] mx-auto">
      Start free. Pay only for what you compute.
    </p>
  </section>

  <!-- Pricing Grid -->
  <section class="py-16 px-6 md:px-12">
    <div class="max-w-[1200px] mx-auto grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {tiers.map(tier => (
        <div class={`reveal rounded-xl p-6 flex flex-col ${tier.highlight ? 'glass-accent ring-1 ring-catalyst-blue/30' : 'glass'}`}>
          <div class="mb-6">
            <h3 class="text-lg font-semibold">{tier.name}</h3>
            <div class="mt-3">
              <span class="text-4xl font-bold">{tier.price === '0' ? 'Free' : `£${tier.price}`}</span>
              {tier.price !== '0' && <span class="text-sm text-white/40 ml-1">/{tier.period}</span>}
            </div>
            <p class="text-sm text-white/40 mt-2">{tier.description}</p>
          </div>
          <ul class="flex-1 space-y-3 mb-6">
            {tier.features.map(f => (
              <li class="flex items-start gap-2 text-sm text-white/60">
                <span class="text-catalyst-blue mt-0.5 flex-shrink-0">&#10003;</span>
                {f}
              </li>
            ))}
          </ul>
          <a href={tier.ctaHref} class={`text-center py-2.5 rounded-lg text-sm font-medium transition-all duration-200 no-underline ${tier.highlight ? 'bg-catalyst-blue text-white hover:bg-catalyst-blue/80' : 'border border-white/10 text-white/70 hover:text-white hover:border-white/20'}`}>
            {tier.cta}
          </a>
        </div>
      ))}
    </div>
  </section>

  <!-- Compute Pricing -->
  <section class="py-32 px-6 md:px-12">
    <div class="max-w-[800px] mx-auto text-center">
      <h2 class="reveal text-[clamp(2rem,3.5vw,2.5rem)] font-bold tracking-tight mb-8">How compute pricing works</h2>
      <div class="reveal glass rounded-xl p-8 text-left">
        <p class="text-white/60 leading-relaxed mb-6">
          You're billed for actual simulation time, not wall-clock time. A 1,000-neuron network running 10,000 timesteps might take 0.5 seconds of compute.
        </p>
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <h4 class="font-semibold text-sm mb-3">Example: Small experiment</h4>
            <div class="text-sm text-white/40 space-y-1">
              <p>100 neurons, 1,000 timesteps</p>
              <p>Compute: ~0.05 seconds</p>
              <p>Cost: £0.00025</p>
              <p class="text-white/60 font-medium mt-2">Free tier: £0.00</p>
            </div>
          </div>
          <div>
            <h4 class="font-semibold text-sm mb-3">Example: Full research run</h4>
            <div class="text-sm text-white/40 space-y-1">
              <p>32K neurons, 100K timesteps, 50 trials</p>
              <p>Compute: ~300 seconds total</p>
              <p>Cost: £1.50 (Researcher tier)</p>
              <p class="text-white/60 font-medium mt-2">Less than a coffee.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-32 px-6 md:px-12">
    <div class="max-w-[700px] mx-auto">
      <h2 class="reveal text-[clamp(2rem,3.5vw,2.5rem)] font-bold tracking-tight text-center mb-12">Questions</h2>
      <div class="space-y-6">
        <div class="reveal">
          <h3 class="font-semibold mb-2">Is the free tier actually free?</h3>
          <p class="text-sm text-white/40 leading-relaxed">Yes. 10 jobs per day, up to 1,024 neurons, forever. No credit card required.</p>
        </div>
        <div class="reveal">
          <h3 class="font-semibold mb-2">What neuromorphic model do you run?</h3>
          <p class="text-sm text-white/40 leading-relaxed">Hardware-accurate Loihi 2 parity. Leak-integrate-fire neurons with 4 dendritic compartments, configurable thresholds, refractory periods, synaptic delays, and multiple learning rules including STDP and 3-factor reward modulation.</p>
        </div>
        <div class="reveal">
          <h3 class="font-semibold mb-2">Can I export my network?</h3>
          <p class="text-sm text-white/40 leading-relaxed">You can re-submit the same JSON definition at any time. The network definition is yours. The simulation engine runs server-side.</p>
        </div>
        <div class="reveal">
          <h3 class="font-semibold mb-2">What's the latency?</h3>
          <p class="text-sm text-white/40 leading-relaxed">Small simulations complete in under a second. Larger ones scale linearly with neuron count and timesteps. Results are available via polling.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-6 md:px-12 text-center">
    <a href="/cloud/docs" class="reveal btn-primary inline-flex px-10 py-3 text-sm">Get started free &rarr;</a>
  </section>

</BaseLayout>
