          <span class="text-xs text-white/30">Auth required</span>
        </div>
        <p class="text-sm text-white/40">Generate TOTP secret and QR code provisioning URI.</p>
      </div>

      <div class="reveal mb-8">
        <div class="flex items-center gap-3 mb-2">
          <span class="px-2 py-0.5 rounded text-xs font-mono font-bold bg-green-500/20 text-green-400">POST</span>
          <code class="text-sm font-mono text-white/70">/v1/auth/totp/verify-setup</code>
          <span class="text-xs text-white/30">Auth required</span>
        </div>
