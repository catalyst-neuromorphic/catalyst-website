      <div class="reveal mb-8">
        <p class="text-sm text-white/50 font-semibold mb-3">OAuth (GitHub &amp; Google)</p>
        <div class="glass rounded-lg p-3 text-xs space-y-1">
          <code class="text-white/50 block">GET /v1/auth/github → Redirect to GitHub OAuth</code>
          <code class="text-white/50 block">GET /v1/auth/github/callback → Handle GitHub callback</code>
          <code class="text-white/50 block">GET /v1/auth/google → Redirect to Google OAuth</code>
          <code class="text-white/50 block">GET /v1/auth/google/callback → Handle Google callback</code>
          <code class="text-white/50 block">GET /v1/auth/github/link → Link GitHub to existing account (auth required)</code>
          <code class="text-white/50 block">GET /v1/auth/google/link → Link Google to existing account (auth required)</code>
        </div>
      </div>

      <!-- Device Code Flow -->
      <div class="reveal mb-8">
        <p class="text-sm text-white/50 font-semibold mb-3">Device code flow (for headless devices)</p>
        <div class="glass rounded-lg p-3 text-xs space-y-1">
          <code class="text-white/50 block">POST /v1/auth/device-code → Request device code + verification URL</code>
          <code class="text-white/50 block">POST /v1/auth/device-code/authorize → User authorizes device (auth required)</code>
          <code class="text-white/50 block">POST /v1/auth/device-code/exchange → Exchange device code for session token</code>
        </div>
      </div>

      <!-- ═══════════════ TOTP ═══════════════ -->
      <h3 class="reveal text-lg font-semibold mt-16 mb-6 border-b border-white/10 pb-2">Two-Factor Authentication (TOTP)</h3>

      <div class="reveal mb-8">
        <div class="flex items-center gap-3 mb-2">
