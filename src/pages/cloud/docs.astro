---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Code examples defined here to avoid JSX brace escaping issues
const signupCurl = `# 1. Create an account at the Console:
#    https://catalyst-neuromorphic.com/console/signup
#
# 2. Create an API key in the Console dashboard:
#    https://catalyst-neuromorphic.com/console/keys
#
# 3. Or use the CLI:
#    catalyst auth login
#    (Opens browser for login)

# Test your key:
curl https://api.catalyst-neuromorphic.com/v1/auth/me \\
  -H "X-API-Key: cn_live_..."

# Response:
# &#123;
#   "user_id": "user_...",
#   "email": "you@lab.edu",
#   "tier": "free",
#   "plan": "free",
#   "credits_balance": 0.0,
#   "extra_usage_enabled": false
# &#125;`;

const signupPython = `import requests

# Get your API key from the Console:
# https://catalyst-neuromorphic.com/console/keys
API_KEY = "cn_live_..."

# Verify it works
headers = &#123;"X-API-Key": API_KEY&#125;
r = requests.get("https://api.catalyst-neuromorphic.com/v1/auth/me",
    headers=headers)

me = r.json()
print(f"Email: &#123;me['email']&#125;")
print(f"Tier: &#123;me['tier']&#125;")
print(f"Credits: $&#123;me['credits_balance']:.2f&#125;")`;

const signupJs = `// Get your API key from the Console:
// https://catalyst-neuromorphic.com/console/keys
const API_KEY = "cn_live_...";

const res = await fetch("https://api.catalyst-neuromorphic.com/v1/auth/me", &#123;
  headers: &#123; "X-API-Key": API_KEY &#125;
&#125;);

const me = await res.json();
console.log("Tier:", me.tier, "Credits:", me.credits_balance);`;

const networkCurl = `curl -X POST https://api.catalyst-neuromorphic.com/v1/networks \\
  -H "Content-Type: application/json" \\
  -H "X-API-Key: cn_live_..." \\
  -d '&#123;
    "populations": [
      &#123;"label": "excitatory", "size": 100, "params": &#123;"threshold": 1000, "leak": 10&#125;&#125;,
      &#123;"label": "inhibitory", "size": 25, "params": &#123;"threshold": 800, "leak": 5&#125;&#125;
    ],
    "connections": [
      &#123;"source": "excitatory", "target": "inhibitory", "topology": "random_sparse",
       "p": 0.2, "weight": 600&#125;,
      &#123;"source": "inhibitory", "target": "excitatory", "weight": -400&#125;
    ]
  &#125;'

# Response:
# &#123;"network_id": "net_...", "total_neurons": 125, "populations": 2, "connections": 2&#125;`;

const networkPython = `headers = &#123;"X-API-Key": API_KEY, "Content-Type": "application/json"&#125;

network = &#123;
    "populations": [
        &#123;"label": "excitatory", "size": 100, "params": &#123;"threshold": 1000, "leak": 10&#125;&#125;,
        &#123;"label": "inhibitory", "size": 25, "params": &#123;"threshold": 800, "leak": 5&#125;&#125;,
    ],
    "connections": [
        &#123;"source": "excitatory", "target": "inhibitory",
         "topology": "random_sparse", "p": 0.2, "weight": 600&#125;,
        &#123;"source": "inhibitory", "target": "excitatory", "weight": -400&#125;,
    ],
&#125;

r = requests.post("https://api.catalyst-neuromorphic.com/v1/networks",
    json=network, headers=headers)

net_id = r.json()["network_id"]`;

const networkJs = `const headers = &#123;
  "X-API-Key": api_key,
  "Content-Type": "application/json"
&#125;;

const res = await fetch("https://api.catalyst-neuromorphic.com/v1/networks", &#123;
  method: "POST", headers,
  body: JSON.stringify(&#123;
    populations: [
      &#123; label: "excitatory", size: 100, params: &#123; threshold: 1000, leak: 10 &#125; &#125;,
      &#123; label: "inhibitory", size: 25, params: &#123; threshold: 800, leak: 5 &#125; &#125;
    ],
    connections: [
      &#123; source: "excitatory", target: "inhibitory",
        topology: "random_sparse", p: 0.2, weight: 600 &#125;,
      &#123; source: "inhibitory", target: "excitatory", weight: -400 &#125;
    ]
  &#125;)
&#125;);

const &#123; network_id &#125; = await res.json();`;

const jobCurl = `curl -X POST https://api.catalyst-neuromorphic.com/v1/jobs \\
  -H "Content-Type: application/json" \\
  -H "X-API-Key: cn_live_..." \\
  -d '&#123;
    "network_id": "net_...",
    "timesteps": 1000,
    "stimuli": [
      &#123;"population": "excitatory", "neurons": [0,1,2,3,4], "current": 8000&#125;
    ]
  &#125;'

# Response: &#123;"job_id": "job_...", "status": "queued"&#125;

# Poll for results:
curl https://api.catalyst-neuromorphic.com/v1/jobs/job_... \\
  -H "X-API-Key: cn_live_..."

# When status is "completed":
# &#123;
#   "status": "completed",
#   "result": &#123;
#     "total_spikes": 847,
#     "firing_rates": &#123;"excitatory": 0.0052, "inhibitory": 0.0128&#125;,
#     "spike_count_timeseries": [5, 12, 3, ...]
#   &#125;,
#   "compute_seconds": 0.34
# &#125;`;

const jobPython = `import time

# Submit job
r = requests.post("https://api.catalyst-neuromorphic.com/v1/jobs",
    json=&#123;
        "network_id": net_id,
        "timesteps": 1000,
        "stimuli": [&#123;"population": "excitatory", "neurons": [0,1,2,3,4], "current": 8000&#125;],
    &#125;,
    headers=headers)

job_id = r.json()["job_id"]

# Poll for completion
while True:
    r = requests.get(f"https://api.catalyst-neuromorphic.com/v1/jobs/&#123;job_id&#125;",
        headers=headers)
    job = r.json()
    if job["status"] in ("completed", "failed"):
        break
    time.sleep(1)

print(f"Spikes: &#123;job['result']['total_spikes']&#125;")
print(f"Rates: &#123;job['result']['firing_rates']&#125;")
print(f"Compute: &#123;job['compute_seconds']&#125;s")`;

const jobJs = `// Submit job
let res = await fetch("https://api.catalyst-neuromorphic.com/v1/jobs", &#123;
  method: "POST", headers,
  body: JSON.stringify(&#123;
    network_id,
    timesteps: 1000,
    stimuli: [&#123; population: "excitatory", neurons: [0,1,2,3,4], current: 8000 &#125;]
  &#125;)
&#125;);

const &#123; job_id &#125; = await res.json();

// Poll for completion
let job;
do &#123;
  await new Promise(r =&gt; setTimeout(r, 1000));
  res = await fetch(\`https://api.catalyst-neuromorphic.com/v1/jobs/\${job_id}\`, &#123; headers &#125;);
  job = await res.json();
&#125; while (job.status !== "completed" &amp;&amp; job.status !== "failed");

console.log("Spikes:", job.result.total_spikes);
console.log("Rates:", job.result.firing_rates);`;

const spikesCurl = `curl https://api.catalyst-neuromorphic.com/v1/jobs/job_.../spikes \\
  -H "X-API-Key: cn_live_..."

# Response:
# &#123;
#   "spike_trains": &#123;
#     "excitatory": &#123;"0": [12, 45, 78], "1": [13, 47], "4": [11, 44, 77, 110]&#125;,
#     "inhibitory": &#123;"0": [14, 48], "3": [15, 49, 82]&#125;
#   &#125;
# &#125;`;

const spikesPython = `r = requests.get(f"https://api.catalyst-neuromorphic.com/v1/jobs/&#123;job_id&#125;/spikes",
    headers=headers)

spikes = r.json()["spike_trains"]

# Plot raster
import matplotlib.pyplot as plt

fig, ax = plt.subplots(figsize=(10, 4))
y = 0
for pop, neurons in spikes.items():
    for nid, times in sorted(neurons.items(), key=lambda x: int(x[0])):
        ax.scatter(times, [y] * len(times), s=1, c='white')
        y += 1
ax.set_xlabel("Timestep")
ax.set_ylabel("Neuron")
plt.savefig("raster.png", dpi=150)
print("Saved raster.png")`;

const spikesResponse = `&#123;"spike_trains": &#123;"excitatory": &#123;"0": [12, 45], "1": [13]&#125;, "inhibitory": &#123;"0": [14, 48]&#125;&#125;&#125;`;
---

<BaseLayout title="API Docs — Catalyst Cloud" description="Complete API reference for Catalyst Cloud neuromorphic compute.">

  <!-- Header -->
  <section class="pt-36 pb-12 px-6 md:px-12 text-center">
    <p class="text-sm text-catalyst-blue font-medium tracking-wider uppercase mb-4">Documentation</p>
    <h1 class="text-[clamp(2.5rem,5vw,4rem)] font-bold tracking-tighter">API Reference</h1>
    <p class="text-lg text-white/40 mt-4 max-w-[550px] mx-auto">
      Everything you need to run neuromorphic simulations from any language.
    </p>
    <p class="text-sm text-white/30 mt-3">
      Base URL: <code class="text-white/50 font-mono bg-white/5 px-2 py-0.5 rounded">https://api.catalyst-neuromorphic.com</code>
    </p>
  </section>

  <!-- Python SDK -->
  <section class="py-16 px-6 md:px-12">
    <div class="max-w-[800px] mx-auto">
      <div class="reveal glass-accent rounded-xl p-6 mb-6">
        <h3 class="font-semibold mb-3">Python SDK (recommended)</h3>
        <pre class="text-sm font-mono text-catalyst-blue mb-3"><code>pip install catalyst-cloud</code></pre>
        <pre class="text-sm font-mono text-white/60 leading-relaxed"><code set:html={`import catalyst_cloud as cc

client = cc.Client("cn_live_...")
net = client.create_network(
    populations=[&#123;"label": "input", "size": 100, "params": &#123;"threshold": 1000&#125;&#125;],
    connections=[],
)
job = client.simulate(net["network_id"], timesteps=500,
    stimuli=[&#123;"population": "input", "current": 5000&#125;])
print(f"Spikes: &#123;job['result']['total_spikes']&#125;")`} /></pre>
        <p class="text-xs text-white/30 mt-3">
          <a href="https://pypi.org/project/catalyst-cloud/" target="_blank" class="text-catalyst-blue hover:underline">PyPI</a> &middot;
          <a href="https://github.com/catalyst-neuromorphic/catalyst-cloud-python" target="_blank" class="text-catalyst-blue hover:underline">GitHub</a> &middot;
          <a href="https://huggingface.co/spaces/Catalyst-Neuromorphic/catalyst-cloud" target="_blank" class="text-catalyst-blue hover:underline">Interactive demo</a>
        </p>
      </div>
    </div>
  </section>

  <!-- Quick Start -->
  <section class="py-16 px-6 md:px-12">
    <div class="max-w-[800px] mx-auto">
      <h2 class="reveal text-2xl font-bold mb-8">Quick start (REST API)</h2>

      <!-- Step 1: Signup -->
      <div class="reveal mb-10">
        <h3 class="text-lg font-semibold mb-2">1. Sign up and get an API key</h3>
        <p class="text-sm text-white/40 mb-4">Create an account at the <a href="/console/signup" class="text-catalyst-blue hover:underline">Console</a>, verify your email, then create an API key from the dashboard. Free, no credit card required.</p>
        <div class="code-tabs glass rounded-xl overflow-hidden" data-group="signup">
          <div class="flex border-b border-white/5">
            <button class="tab-btn active px-4 py-2.5 text-xs font-mono" data-lang="curl">curl</button>
            <button class="tab-btn px-4 py-2.5 text-xs font-mono" data-lang="python">Python</button>
            <button class="tab-btn px-4 py-2.5 text-xs font-mono" data-lang="js">JavaScript</button>
          </div>
          <pre class="tab-content p-5 text-sm font-mono text-white/70 leading-relaxed" data-lang="curl"><code set:html={signupCurl} /></pre>
          <pre class="tab-content p-5 text-sm font-mono text-white/70 leading-relaxed hidden" data-lang="python"><code set:html={signupPython} /></pre>
          <pre class="tab-content p-5 text-sm font-mono text-white/70 leading-relaxed hidden" data-lang="js"><code set:html={signupJs} /></pre>
        </div>
      </div>

      <!-- Step 2: Create Network -->
      <div class="reveal mb-10">
        <h3 class="text-lg font-semibold mb-2">2. Define a network</h3>
        <p class="text-sm text-white/40 mb-4">Populations of spiking neurons with connections between them.</p>
        <div class="code-tabs glass rounded-xl overflow-hidden" data-group="network">
          <div class="flex border-b border-white/5">
            <button class="tab-btn active px-4 py-2.5 text-xs font-mono" data-lang="curl">curl</button>
            <button class="tab-btn px-4 py-2.5 text-xs font-mono" data-lang="python">Python</button>
            <button class="tab-btn px-4 py-2.5 text-xs font-mono" data-lang="js">JavaScript</button>
          </div>
          <pre class="tab-content p-5 text-sm font-mono text-white/70 leading-relaxed" data-lang="curl"><code set:html={networkCurl} /></pre>
          <pre class="tab-content p-5 text-sm font-mono text-white/70 leading-relaxed hidden" data-lang="python"><code set:html={networkPython} /></pre>
          <pre class="tab-content p-5 text-sm font-mono text-white/70 leading-relaxed hidden" data-lang="js"><code set:html={networkJs} /></pre>
        </div>
      </div>

      <!-- Step 3: Submit Job -->
      <div class="reveal mb-10">
        <h3 class="text-lg font-semibold mb-2">3. Run a simulation</h3>
        <p class="text-sm text-white/40 mb-4">Submit a job with stimuli. It runs asynchronously and you poll for results.</p>
        <div class="code-tabs glass rounded-xl overflow-hidden" data-group="job">
          <div class="flex border-b border-white/5">
            <button class="tab-btn active px-4 py-2.5 text-xs font-mono" data-lang="curl">curl</button>
            <button class="tab-btn px-4 py-2.5 text-xs font-mono" data-lang="python">Python</button>
            <button class="tab-btn px-4 py-2.5 text-xs font-mono" data-lang="js">JavaScript</button>
          </div>
          <pre class="tab-content p-5 text-sm font-mono text-white/70 leading-relaxed" data-lang="curl"><code set:html={jobCurl} /></pre>
          <pre class="tab-content p-5 text-sm font-mono text-white/70 leading-relaxed hidden" data-lang="python"><code set:html={jobPython} /></pre>
          <pre class="tab-content p-5 text-sm font-mono text-white/70 leading-relaxed hidden" data-lang="js"><code set:html={jobJs} /></pre>
        </div>
      </div>

      <!-- Step 4: Spike Trains -->
      <div class="reveal mb-10">
        <h3 class="text-lg font-semibold mb-2">4. Get spike trains</h3>
        <p class="text-sm text-white/40 mb-4">Full per-neuron spike times, indexed by population label and local neuron index.</p>
        <div class="code-tabs glass rounded-xl overflow-hidden" data-group="spikes">
          <div class="flex border-b border-white/5">
            <button class="tab-btn active px-4 py-2.5 text-xs font-mono" data-lang="curl">curl</button>
            <button class="tab-btn px-4 py-2.5 text-xs font-mono" data-lang="python">Python</button>
          </div>
          <pre class="tab-content p-5 text-sm font-mono text-white/70 leading-relaxed" data-lang="curl"><code set:html={spikesCurl} /></pre>
          <pre class="tab-content p-5 text-sm font-mono text-white/70 leading-relaxed hidden" data-lang="python"><code set:html={spikesPython} /></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- Full Endpoint Reference -->
  <section class="py-32 px-6 md:px-12">
    <div class="max-w-[800px] mx-auto">
      <h2 class="reveal text-2xl font-bold mb-12">Endpoint reference</h2>

      <!-- Authentication Methods -->
      <div class="reveal mb-10">
        <h3 class="text-lg font-semibold mb-4">Authentication</h3>
        <p class="text-sm text-white/40 mb-4">Two auth methods are supported. Include one header on each request:</p>
        <div class="glass rounded-lg p-4 text-sm mb-4">
          <table class="w-full text-sm">
            <tbody>
              <tr class="border-b border-white/5"><td class="py-1.5 font-mono text-white/60">X-API-Key: cn_live_...</td><td class="py-1.5 text-white/40">For scripts, CI/CD, and the Python SDK</td></tr>
              <tr><td class="py-1.5 font-mono text-white/60">Authorization: Bearer cat_sess_...</td><td class="py-1.5 text-white/40">For CLI and web console sessions</td></tr>
            </tbody>
          </table>
        </div>
        <p class="text-sm text-white/30 mb-6">API keys are created in the <a href="/console/keys" class="text-catalyst-blue hover:underline">Console</a>. Session tokens are obtained via <code class="font-mono text-white/40">catalyst auth login</code>.</p>
        <p class="text-sm text-white/40 mb-3">HMAC signing is optional but recommended for API keys. Include <code class="font-mono text-white/50">X-Signature</code> and <code class="font-mono text-white/50">X-Timestamp</code> headers with HMAC-SHA256 of the request body.</p>
      </div>

      <!-- ═══════════════ AUTH ═══════════════ -->
      <h3 class="reveal text-lg font-semibold mt-16 mb-6 border-b border-white/10 pb-2">Auth</h3>

      <div class="reveal mb-8">
        <div class="flex items-center gap-3 mb-2">
          <span class="px-2 py-0.5 rounded text-xs font-mono font-bold bg-green-500/20 text-green-400">POST</span>
          <code class="text-sm font-mono text-white/70">/v1/auth/signup</code>
        </div>
        <p class="text-sm text-white/40 mb-2">Create a new account. Returns session token.</p>
        <div class="glass rounded-lg p-3 text-xs"><code class="text-white/50">Body: email, password (min 8 chars, not breached)</code></div>
      </div>

      <div class="reveal mb-8">
        <div class="flex items-center gap-3 mb-2">
          <span class="px-2 py-0.5 rounded text-xs font-mono font-bold bg-green-500/20 text-green-400">POST</span>
          <code class="text-sm font-mono text-white/70">/v1/auth/login</code>
        </div>
        <p class="text-sm text-white/40 mb-2">Email/password login. Returns session token (or 2FA challenge if TOTP enabled).</p>
        <div class="glass rounded-lg p-3 text-xs"><code class="text-white/50">Body: email, password</code></div>
      </div>

      <div class="reveal mb-8">
        <div class="flex items-center gap-3 mb-2">
          <span class="px-2 py-0.5 rounded text-xs font-mono font-bold bg-green-500/20 text-green-400">POST</span>
          <code class="text-sm font-mono text-white/70">/v1/auth/logout</code>
          <span class="text-xs text-white/30">Auth required</span>
        </div>
        <p class="text-sm text-white/40">Revoke current session token.</p>
      </div>

      <div class="reveal mb-8">
        <div class="flex items-center gap-3 mb-2">
          <span class="px-2 py-0.5 rounded text-xs font-mono font-bold bg-green-500/20 text-green-400">POST</span>
          <code class="text-sm font-mono text-white/70">/v1/auth/verify-2fa</code>
        </div>
        <p class="text-sm text-white/40 mb-2">Complete 2FA challenge from login. Accepts TOTP code or backup code.</p>
        <div class="glass rounded-lg p-3 text-xs"><code class="text-white/50">Body: user_id, code</code></div>
      </div>

      <div class="reveal mb-8">
        <div class="flex items-center gap-3 mb-2">
          <span class="px-2 py-0.5 rounded text-xs font-mono font-bold bg-blue-500/20 text-blue-400">GET</span>
          <code class="text-sm font-mono text-white/70">/v1/auth/me</code>
          <span class="text-xs text-white/30">Auth required</span>
        </div>
        <p class="text-sm text-white/40">Get your account info, tier, credit balance, and verification status.</p>
      </div>

      <div class="reveal mb-8">
        <div class="flex items-center gap-3 mb-2">
          <span class="px-2 py-0.5 rounded text-xs font-mono font-bold bg-green-500/20 text-green-400">POST</span>
          <code class="text-sm font-mono text-white/70">/v1/auth/refresh</code>
          <span class="text-xs text-white/30">Auth required</span>
        </div>
        <p class="text-sm text-white/40">Refresh session token (extends expiry).</p>
      </div>

      <div class="reveal mb-8">
        <div class="flex items-center gap-3 mb-2">
          <span class="px-2 py-0.5 rounded text-xs font-mono font-bold bg-green-500/20 text-green-400">POST</span>
          <code class="text-sm font-mono text-white/70">/v1/auth/cli-token</code>
          <span class="text-xs text-white/30">Auth required</span>
        </div>
        <p class="text-sm text-white/40">Issue a long-lived CLI session token.</p>
      </div>

      <div class="reveal mb-8">
        <div class="flex items-center gap-3 mb-2">
          <span class="px-2 py-0.5 rounded text-xs font-mono font-bold bg-yellow-500/20 text-yellow-400">PUT</span>
          <code class="text-sm font-mono text-white/70">/v1/auth/profile</code>
          <span class="text-xs text-white/30">Auth required</span>
        </div>
        <p class="text-sm text-white/40 mb-2">Update display name or notification preferences.</p>
        <div class="glass rounded-lg p-3 text-xs"><code class="text-white/50">Body: display_name, email_notifications</code></div>
      </div>

      <div class="reveal mb-8">
        <div class="flex items-center gap-3 mb-2">
          <span class="px-2 py-0.5 rounded text-xs font-mono font-bold bg-green-500/20 text-green-400">POST</span>
          <code class="text-sm font-mono text-white/70">/v1/auth/verify-email</code>
        </div>
        <p class="text-sm text-white/40 mb-2">Verify email address with code sent to inbox.</p>
        <div class="glass rounded-lg p-3 text-xs"><code class="text-white/50">Body: email, code</code></div>
      </div>

      <div class="reveal mb-8">
        <div class="flex items-center gap-3 mb-2">
          <span class="px-2 py-0.5 rounded text-xs font-mono font-bold bg-green-500/20 text-green-400">POST</span>
          <code class="text-sm font-mono text-white/70">/v1/auth/resend-verification</code>
          <span class="text-xs text-white/30">Auth required</span>
        </div>
        <p class="text-sm text-white/40">Resend email verification code.</p>
      </div>

      <div class="reveal mb-8">
        <div class="flex items-center gap-3 mb-2">
          <span class="px-2 py-0.5 rounded text-xs font-mono font-bold bg-green-500/20 text-green-400">POST</span>
          <code class="text-sm font-mono text-white/70">/v1/auth/forgot-password</code>
        </div>
        <p class="text-sm text-white/40 mb-2">Send password reset email.</p>
        <div class="glass rounded-lg p-3 text-xs"><code class="text-white/50">Body: email</code></div>
      </div>

      <div class="reveal mb-8">
        <div class="flex items-center gap-3 mb-2">
          <span class="px-2 py-0.5 rounded text-xs font-mono font-bold bg-green-500/20 text-green-400">POST</span>
          <code class="text-sm font-mono text-white/70">/v1/auth/reset-password</code>
        </div>
        <p class="text-sm text-white/40 mb-2">Reset password with token from email.</p>
        <div class="glass rounded-lg p-3 text-xs"><code class="text-white/50">Body: token, new_password</code></div>
      </div>

      <div class="reveal mb-8">
        <div class="flex items-center gap-3 mb-2">
          <span class="px-2 py-0.5 rounded text-xs font-mono font-bold bg-blue-500/20 text-blue-400">GET</span>
