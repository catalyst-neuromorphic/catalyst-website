          <code class="text-sm font-mono text-white/70">/v1/auth/totp/disable</code>
          <span class="text-xs text-white/30">Auth required</span>
        </div>
        <p class="text-sm text-white/40 mb-2">Disable 2FA. Requires current TOTP code for security.</p>
        <div class="glass rounded-lg p-3 text-xs"><code class="text-white/50">Body: code</code></div>
      </div>

      <div class="reveal mb-8">
        <div class="flex items-center gap-3 mb-2">
          <span class="px-2 py-0.5 rounded text-xs font-mono font-bold bg-blue-500/20 text-blue-400">GET</span>
          <code class="text-sm font-mono text-white/70">/v1/auth/totp/status</code>
          <span class="text-xs text-white/30">Auth required</span>
