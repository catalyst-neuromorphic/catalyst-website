---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Benchmarks — Catalyst Neuromorphic" description="Catalyst neuromorphic processor benchmark results vs Intel Loihi, BrainChip Akida, and SpiNNaker 2 across SHD, SSC, N-MNIST, DVS Gesture, and GSC.">
  <main style="padding-top:140px; min-height:100vh;">
    <div style="max-width:1100px; margin:0 auto; padding:0 24px 120px;">

      <!-- Header -->
      <div class="reveal" style="text-align:center; margin-bottom:80px;">
        <p style="font-family:'Space Grotesk',sans-serif; font-size:0.95rem; font-weight:600; color:#60A5FA; letter-spacing:0.08em; text-transform:uppercase; margin-bottom:16px;">Benchmarks</p>
        <h1 style="font-family:'Space Grotesk',sans-serif; font-size:clamp(2.2rem,5vw,3.6rem); font-weight:700; color:#fff; line-height:1.1; margin-bottom:24px;">
          Catalyst vs the Competition
        </h1>
        <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:1.15rem; color:rgba(255,255,255,0.55); max-width:700px; margin:0 auto; line-height:1.7;">
          Standard neuromorphic benchmark suite. Fully reproducible. Every result deployable to Catalyst FPGA hardware.
        </p>
      </div>

      <!-- N3 Results (Latest) -->
      <div class="reveal" style="margin-bottom:80px;">
        <h2 style="font-family:'Space Grotesk',sans-serif; font-size:1.5rem; font-weight:600; color:#fff; margin-bottom:8px;">Catalyst N3 <span style="font-size:0.85rem; font-weight:500; color:rgba(255,255,255,0.35); margin-left:8px;">Latest</span></h2>
        <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:rgba(255,255,255,0.4); margin-bottom:24px;">N3 benchmark results on the standard spiking audio and vision benchmarks.</p>
        <div style="overflow-x:auto; border-radius:16px; border:1px solid rgba(255,255,255,0.06); background:rgba(15,15,20,0.6);">
          <table style="width:100%; border-collapse:collapse; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.95rem;">
            <thead>
              <tr style="border-bottom:1px solid rgba(255,255,255,0.08);">
                <th style="padding:16px 20px; text-align:left; color:rgba(255,255,255,0.4); font-weight:500; font-size:0.85rem; text-transform:uppercase; letter-spacing:0.05em;">Benchmark</th>
                <th style="padding:16px 20px; text-align:left; color:rgba(255,255,255,0.4); font-weight:500; font-size:0.85rem; text-transform:uppercase; letter-spacing:0.05em;">Classes</th>
                <th style="padding:16px 20px; text-align:left; color:rgba(255,255,255,0.4); font-weight:500; font-size:0.85rem; text-transform:uppercase; letter-spacing:0.05em;">Architecture</th>
                <th style="padding:16px 20px; text-align:left; color:rgba(255,255,255,0.4); font-weight:500; font-size:0.85rem; text-transform:uppercase; letter-spacing:0.05em;">Float Acc</th>
                <th style="padding:16px 20px; text-align:left; color:rgba(255,255,255,0.4); font-weight:500; font-size:0.85rem; text-transform:uppercase; letter-spacing:0.05em;">Status</th>
              </tr>
            </thead>
            <tbody>
              <tr style="border-bottom:1px solid rgba(255,255,255,0.04);">
                <td style="padding:14px 20px; color:#fff; font-weight:600;">SHD</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.6);">20</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.6); font-family:'JetBrains Mono',monospace; font-size:0.85rem;">700→1536→20 (rec, adLIF)</td>
                <td style="padding:14px 20px; color:#60A5FA; font-weight:600;">91.0%</td>
                <td style="padding:14px 20px;"><span style="background:rgba(34,197,94,0.15); color:#22C55E; padding:4px 12px; border-radius:20px; font-size:0.8rem; font-weight:500;">Published</span></td>
              </tr>
              <tr style="border-bottom:1px solid rgba(255,255,255,0.04);">
                <td style="padding:14px 20px; color:#fff; font-weight:600;">SSC</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.6);">35</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.6); font-family:'JetBrains Mono',monospace; font-size:0.85rem;">700→1024→512→35 (rec, adLIF)</td>
                <td style="padding:14px 20px; color:#60A5FA; font-weight:600;">76.4%</td>
                <td style="padding:14px 20px;"><span style="background:rgba(34,197,94,0.15); color:#22C55E; padding:4px 12px; border-radius:20px; font-size:0.8rem; font-weight:500;">Published</span></td>
              </tr>
              <tr style="border-bottom:1px solid rgba(255,255,255,0.04);">
                <td style="padding:14px 20px; color:#fff; font-weight:600;">N-MNIST</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.6);">10</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.6); font-family:'JetBrains Mono',monospace; font-size:0.85rem;">34×34×2→Conv+LIF→10</td>
                <td style="padding:14px 20px; color:#60A5FA; font-weight:600;">99.2%</td>
                <td style="padding:14px 20px;"><span style="background:rgba(34,197,94,0.15); color:#22C55E; padding:4px 12px; border-radius:20px; font-size:0.8rem; font-weight:500;">Published</span></td>
              </tr>
              <tr>
                <td style="padding:14px 20px; color:#fff; font-weight:600;">GSC-35</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.6);">35</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.6); font-family:'JetBrains Mono',monospace; font-size:0.85rem;">Delay+rec adLIF+BN</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.4);">Training</td>
                <td style="padding:14px 20px;"><span style="background:rgba(234,179,8,0.15); color:#EAB308; padding:4px 12px; border-radius:20px; font-size:0.8rem; font-weight:500;">In progress</span></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- N2 Results -->
      <div class="reveal" style="margin-bottom:80px;">
        <h2 style="font-family:'Space Grotesk',sans-serif; font-size:1.5rem; font-weight:600; color:#fff; margin-bottom:8px;">Catalyst N2</h2>
        <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:rgba(255,255,255,0.4); margin-bottom:24px;">All N2 models deploy to Catalyst FPGA hardware via int16 weight quantization.</p>
        <div style="overflow-x:auto; border-radius:16px; border:1px solid rgba(255,255,255,0.06); background:rgba(15,15,20,0.6);">
          <table style="width:100%; border-collapse:collapse; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.95rem;">
            <thead>
              <tr style="border-bottom:1px solid rgba(255,255,255,0.08);">
                <th style="padding:16px 20px; text-align:left; color:rgba(255,255,255,0.4); font-weight:500; font-size:0.85rem; text-transform:uppercase; letter-spacing:0.05em;">Benchmark</th>
                <th style="padding:16px 20px; text-align:left; color:rgba(255,255,255,0.4); font-weight:500; font-size:0.85rem; text-transform:uppercase; letter-spacing:0.05em;">Classes</th>
                <th style="padding:16px 20px; text-align:left; color:rgba(255,255,255,0.4); font-weight:500; font-size:0.85rem; text-transform:uppercase; letter-spacing:0.05em;">Architecture</th>
                <th style="padding:16px 20px; text-align:left; color:rgba(255,255,255,0.4); font-weight:500; font-size:0.85rem; text-transform:uppercase; letter-spacing:0.05em;">Float Acc</th>
                <th style="padding:16px 20px; text-align:left; color:rgba(255,255,255,0.4); font-weight:500; font-size:0.85rem; text-transform:uppercase; letter-spacing:0.05em;">Quantized</th>
              </tr>
            </thead>
            <tbody>
              <tr style="border-bottom:1px solid rgba(255,255,255,0.04);">
                <td style="padding:14px 20px; color:#fff; font-weight:600;">SHD (adLIF)</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.6);">20</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.6); font-family:'JetBrains Mono',monospace; font-size:0.85rem;">700→1024→20 (rec, adLIF)</td>
                <td style="padding:14px 20px; color:#60A5FA; font-weight:600;">90.7%</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.4);">—</td>
              </tr>
              <tr style="border-bottom:1px solid rgba(255,255,255,0.04);">
                <td style="padding:14px 20px; color:#fff; font-weight:600;">SHD (LIF baseline)</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.6);">20</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.6); font-family:'JetBrains Mono',monospace; font-size:0.85rem;">700→512→20 (rec, LIF)</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.5);">85.9%</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.5);">85.4%</td>
              </tr>
              <tr style="border-bottom:1px solid rgba(255,255,255,0.04);">
                <td style="padding:14px 20px; color:#fff; font-weight:600;">SSC</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.6);">35</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.6); font-family:'JetBrains Mono',monospace; font-size:0.85rem;">700→1024→512→35 (rec, adLIF)</td>
                <td style="padding:14px 20px; color:#60A5FA; font-weight:600;">72.1%</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.4);">—</td>
              </tr>
              <tr style="border-bottom:1px solid rgba(255,255,255,0.04);">
                <td style="padding:14px 20px; color:#fff; font-weight:600;">N-MNIST</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.6);">10</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.6); font-family:'JetBrains Mono',monospace; font-size:0.85rem;">34×34×2→Conv+LIF→10</td>
                <td style="padding:14px 20px; color:#60A5FA; font-weight:600;">99.2%</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.4);">—</td>
              </tr>
              <tr style="border-bottom:1px solid rgba(255,255,255,0.04);">
                <td style="padding:14px 20px; color:#fff; font-weight:600;">GSC KWS</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.6);">12</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.6); font-family:'JetBrains Mono',monospace; font-size:0.85rem;">40→512→12 (S2S encoding)</td>
                <td style="padding:14px 20px; color:#60A5FA; font-weight:600;">88.0%</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.4);">—</td>
              </tr>
              <tr>
                <td style="padding:14px 20px; color:#fff; font-weight:600;">DVS Gesture</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.6);">11</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.6); font-family:'JetBrains Mono',monospace; font-size:0.85rem;">128×128→Conv+LIF→11</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.4);">—</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.4);">—</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Competitive comparison -->
      <div class="reveal" style="margin-bottom:80px;">
        <h2 style="font-family:'Space Grotesk',sans-serif; font-size:1.5rem; font-weight:600; color:#fff; margin-bottom:24px;">Competitive Context</h2>
        <div style="overflow-x:auto; border-radius:16px; border:1px solid rgba(255,255,255,0.06); background:rgba(15,15,20,0.6);">
          <table style="width:100%; border-collapse:collapse; font-family:'Plus Jakarta Sans',sans-serif; font-size:0.95rem;">
            <thead>
              <tr style="border-bottom:1px solid rgba(255,255,255,0.08);">
                <th style="padding:16px 20px; text-align:left; color:rgba(255,255,255,0.4); font-weight:500; font-size:0.85rem; text-transform:uppercase; letter-spacing:0.05em;">Benchmark</th>
                <th style="padding:16px 20px; text-align:left; color:#60A5FA; font-weight:600; font-size:0.85rem; text-transform:uppercase; letter-spacing:0.05em;">Catalyst N3</th>
                <th style="padding:16px 20px; text-align:left; color:rgba(96,165,250,0.6); font-weight:500; font-size:0.85rem; text-transform:uppercase; letter-spacing:0.05em;">Catalyst N2</th>
                <th style="padding:16px 20px; text-align:left; color:rgba(255,255,255,0.4); font-weight:500; font-size:0.85rem; text-transform:uppercase; letter-spacing:0.05em;">Loihi 1</th>
                <th style="padding:16px 20px; text-align:left; color:rgba(255,255,255,0.4); font-weight:500; font-size:0.85rem; text-transform:uppercase; letter-spacing:0.05em;">Loihi 2</th>
                <th style="padding:16px 20px; text-align:left; color:rgba(255,255,255,0.4); font-weight:500; font-size:0.85rem; text-transform:uppercase; letter-spacing:0.05em;">Akida 2</th>
                <th style="padding:16px 20px; text-align:left; color:rgba(255,255,255,0.4); font-weight:500; font-size:0.85rem; text-transform:uppercase; letter-spacing:0.05em;">SpiNNaker 2</th>
              </tr>
            </thead>
            <tbody>
              <tr style="border-bottom:1px solid rgba(255,255,255,0.04);">
                <td style="padding:14px 20px; color:#fff; font-weight:600;">SHD</td>
                <td style="padding:14px 20px; color:#60A5FA; font-weight:600;">91.0%</td>
                <td style="padding:14px 20px; color:rgba(96,165,250,0.7); font-weight:500;">90.7%</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.6);">89.0%</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.6);">90.9%</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.3);">—</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.3);">—</td>
              </tr>
              <tr style="border-bottom:1px solid rgba(255,255,255,0.04);">
                <td style="padding:14px 20px; color:#fff; font-weight:600;">SSC</td>
                <td style="padding:14px 20px; color:#60A5FA; font-weight:600;">76.4%</td>
                <td style="padding:14px 20px; color:rgba(96,165,250,0.7); font-weight:500;">72.1%</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.3);">—</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.6);">69.8%</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.3);">—</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.3);">—</td>
              </tr>
              <tr style="border-bottom:1px solid rgba(255,255,255,0.04);">
                <td style="padding:14px 20px; color:#fff; font-weight:600;">N-MNIST</td>
                <td style="padding:14px 20px; color:#60A5FA; font-weight:600;">99.2%</td>
                <td style="padding:14px 20px; color:rgba(96,165,250,0.7); font-weight:500;">99.2%</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.6);">99.5%</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.3);">—</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.3);">—</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.3);">—</td>
              </tr>
              <tr>
                <td style="padding:14px 20px; color:#fff; font-weight:600;">GSC KWS</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.4);">Training</td>
                <td style="padding:14px 20px; color:rgba(96,165,250,0.7); font-weight:500;">88.0%</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.3);">—</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.3);">—</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.6);">92.8%</td>
                <td style="padding:14px 20px; color:rgba(255,255,255,0.6);">91.1%</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.85rem; color:rgba(255,255,255,0.35); margin-top:12px;">
          Sources: Intel Labs (Loihi), BrainChip (Akida), SpiNNaker Project. All results from published papers.
        </p>
      </div>

      <!-- Methodology -->
      <div class="reveal" style="margin-bottom:80px;">
        <h2 style="font-family:'Space Grotesk',sans-serif; font-size:1.5rem; font-weight:600; color:#fff; margin-bottom:24px;">Methodology</h2>
        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(280px, 1fr)); gap:24px;">
          <div style="border-radius:16px; border:1px solid rgba(255,255,255,0.06); background:rgba(15,15,20,0.6); padding:28px;">
            <h3 style="font-family:'Space Grotesk',sans-serif; font-size:1.1rem; font-weight:600; color:#fff; margin-bottom:12px;">Training</h3>
            <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:rgba(255,255,255,0.5); line-height:1.6;">
              Surrogate gradient BPTT with fast-sigmoid surrogate. AdamW optimizer, cosine annealing LR, gradient clipping at 1.0. Event-drop augmentation for regularization.
            </p>
          </div>
          <div style="border-radius:16px; border:1px solid rgba(255,255,255,0.06); background:rgba(15,15,20,0.6); padding:28px;">
            <h3 style="font-family:'Space Grotesk',sans-serif; font-size:1.1rem; font-weight:600; color:#fff; margin-bottom:12px;">Quantization</h3>
            <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:rgba(255,255,255,0.5); line-height:1.6;">
              Float32 → int16 weight quantization. Membrane decay mapped to 12-bit fixed-point. Typical accuracy loss: &lt;1%. Scale: w_hw = round(w_float * threshold_hw / threshold_float).
            </p>
          </div>
          <div style="border-radius:16px; border:1px solid rgba(255,255,255,0.06); background:rgba(15,15,20,0.6); padding:28px;">
            <h3 style="font-family:'Space Grotesk',sans-serif; font-size:1.1rem; font-weight:600; color:#fff; margin-bottom:12px;">Deployment</h3>
            <p style="font-family:'Plus Jakarta Sans',sans-serif; font-size:0.9rem; color:rgba(255,255,255,0.5); line-height:1.6;">
              Quantized weights loaded into Neurocore SDK Network. Deployed to Catalyst FPGA via USB/UART or AWS F2 cloud instance. Same test set evaluated on hardware.
            </p>
          </div>
        </div>
      </div>

      <!-- Reproduce -->
      <div class="reveal" style="margin-bottom:80px;">
        <h2 style="font-family:'Space Grotesk',sans-serif; font-size:1.5rem; font-weight:600; color:#fff; margin-bottom:24px;">Reproduce Everything</h2>
        <div style="border-radius:16px; border:1px solid rgba(255,255,255,0.06); background:rgba(15,15,20,0.8); padding:32px; font-family:'JetBrains Mono',monospace; font-size:0.9rem; color:rgba(255,255,255,0.7); line-height:1.8; overflow-x:auto;">
          <span style="color:rgba(255,255,255,0.35);"># Clone the benchmark repo</span><br/>
          git clone https://github.com/catalyst-neuromorphic/catalyst-benchmarks.git<br/>
          cd catalyst-benchmarks<br/>
          pip install -e .<br/>
          <br/>
          <span style="color:rgba(255,255,255,0.35);"># Train any benchmark (auto-downloads data)</span><br/>
          python shd/train.py --neuron adlif --hidden 1536 --epochs 200 --device cuda:0 --amp<br/>
          python ssc/train.py --hidden1 1024 --hidden2 768 --recurrent2 --epochs 70 --device cuda:0 --amp<br/>
          <br/>
          <span style="color:rgba(255,255,255,0.35);"># Evaluate quantized accuracy</span><br/>
          python shd/deploy.py --checkpoint shd_model.pt<br/>
          <br/>
          <span style="color:rgba(255,255,255,0.35);"># Full hyperparameter sweep</span><br/>
          python sweep.py --benchmark shd --device cuda:0
        </div>
        <div style="margin-top:24px; display:flex; gap:16px; flex-wrap:wrap;">
          <a href="https://github.com/catalyst-neuromorphic/catalyst-benchmarks" style="display:inline-flex; align-items:center; gap:8px; padding:12px 24px; border-radius:12px; background:#60A5FA; color:#fff; text-decoration:none; font-family:'Plus Jakarta Sans',sans-serif; font-weight:600; font-size:0.95rem;">
            View on GitHub
          </a>
          <a href="https://huggingface.co/Catalyst-Neuromorphic" style="display:inline-flex; align-items:center; gap:8px; padding:12px 24px; border-radius:12px; border:1px solid rgba(255,255,255,0.12); color:rgba(255,255,255,0.7); text-decoration:none; font-family:'Plus Jakarta Sans',sans-serif; font-weight:600; font-size:0.95rem;">
            Models on HuggingFace
          </a>
          <a href="/cloud" style="display:inline-flex; align-items:center; gap:8px; padding:12px 24px; border-radius:12px; border:1px solid rgba(255,255,255,0.12); color:rgba(255,255,255,0.7); text-decoration:none; font-family:'Plus Jakarta Sans',sans-serif; font-weight:600; font-size:0.95rem;">
            Try the Cloud API
          </a>
        </div>
      </div>

    </div>
  </main>
</BaseLayout>
