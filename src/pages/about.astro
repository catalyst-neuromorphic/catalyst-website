---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About — Catalyst Neuromorphic" description="A chip design company based in the United Kingdom.">

  <section class="pt-32 pb-20 px-6 md:px-12 text-center">
    <h1 class="text-[clamp(3rem,6vw,5rem)] font-bold tracking-tighter">About</h1>
    <p class="text-lg text-white/40 mt-4">A chip design company based in the United Kingdom.</p>
  </section>

  <!-- MISSION -->
  <section class="py-20 px-6 md:px-12">
    <div class="max-w-[700px] mx-auto text-center">
      <div class="glass-strong p-14 reveal">
        <h2 class="text-[clamp(1.6rem,2.5vw,2.2rem)] font-bold tracking-tight leading-tight mb-6">
          Building neuromorphic processors that match &mdash; and challenge &mdash; the industry's best.
        </h2>
        <p class="text-white/40 leading-relaxed">
          Catalyst Neuromorphic designs open neuromorphic computing hardware. Our processors achieve feature parity with the latest commercial chips, validated on real hardware, with a complete Python SDK and open design philosophy.
        </p>
      </div>
    </div>
  </section>

  <!-- MILESTONES -->
  <section class="py-20 px-6 md:px-12">
    <div class="max-w-[700px] mx-auto">
      <div class="space-y-5">
        {[
          { date: '2026', title: 'Catalyst N1', desc: '128-core neuromorphic processor. Full parity with Intel Loihi 1. UK patent filed.' },
          { date: '2026', title: 'Catalyst N2', desc: 'Second generation. Five neuron models, programmable learning, 3,091 tests.' },
          { date: '2026', title: 'Hardware Validation', desc: 'Every test passing on real programmable logic. Cycle-accurate. Bit-exact.' },
          { date: '2026', title: 'Open Design', desc: 'SDK released on GitHub. Papers published. Seeking partnerships and investment.' },
        ].map((item, i) => (
          <div class="glass p-7 flex gap-6 items-start reveal">
            <div class="text-sm text-white/20 font-mono shrink-0 pt-1">{item.date}</div>
            <div>
              <h3 class="text-base font-semibold">{item.title}</h3>
              <p class="text-sm text-white/35 mt-1">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- IP -->
  <section class="py-20 px-6 md:px-12">
    <div class="max-w-[600px] mx-auto text-center reveal">
      <h2 class="text-2xl font-bold tracking-tight mb-4">UK patent filed.</h2>
      <p class="text-white/40 leading-relaxed">
        Full architecture protected. Licensing enquiries welcome.
      </p>
    </div>
  </section>

  <!-- FUNDING -->
  <section class="py-32 px-6 md:px-12">
    <div class="max-w-[700px] mx-auto text-center">
      <div class="glass-accent p-12 reveal">
        <h2 class="text-[clamp(1.8rem,3vw,2.5rem)] font-bold tracking-tight mb-4">We're actively seeking support.</h2>
        <p class="text-white/40 leading-relaxed mb-8">
          Grants, research partnerships, investment, and commercial licensing. Help us bring neuromorphic computing from prototype to silicon.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="https://ko-fi.com/catalystneuromorphic" target="_blank" rel="noopener noreferrer" class="btn-primary">Support on Ko-fi</a>
          <a href="https://github.com/Mr-wabbit/neurocore" target="_blank" rel="noopener noreferrer" class="btn-pill">View on GitHub</a>
          <a href="mailto:henry@catalyst-neuromorphic.com" class="btn-pill">Get in touch</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
