    line-height: 1.7;
    margin-bottom: 1rem;
  }
  .prose-legal ul {
    color: rgba(255,255,255,0.5);
    font-size: 0.925rem;
    line-height: 1.7;
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }
  .prose-legal li {
    margin-bottom: 0.35rem;
    list-style-type: disc;
  }
  .prose-legal a {
    color: #3B82F6;
    text-decoration: none;
  }
  .prose-legal a:hover { text-decoration: underline; }
  .prose-legal strong { color: rgba(255,255,255,0.7); }
</style>
