---
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/600.css';
import '../../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Verify Email — Catalyst Console</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@400;600;700&display=swap" rel="stylesheet" />
  <style>
    .auth-glow {
      position: fixed;
      top: 30%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(59,130,246,0.08) 0%, rgba(59,130,246,0.02) 40%, transparent 70%);
      pointer-events: none;
      z-index: 0;
    }
    .auth-wrapper {
      position: relative;
      z-index: 1;
    }
    .code-input {
      width: 100%;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 0.75rem;
      padding: 0.75rem 1rem;
      font-size: 1.5rem;
      font-family: 'Space Grotesk', monospace;
      color: #fff;
      text-align: center;
      letter-spacing: 0.5em;
      outline: none;
      transition: border-color 0.2s;
    }
    .code-input:focus {
      border-color: rgba(59,130,246,0.5);
    }
    .code-input::placeholder {
      color: rgba(255,255,255,0.15);
      letter-spacing: 0.3em;
    }
    .auth-submit {
      width: 100%;
      background: linear-gradient(135deg, #3B82F6, #2563EB);
      color: #fff;
      font-weight: 600;
      border-radius: 0.75rem;
      padding: 0.625rem 1rem;
      font-size: 0.875rem;
      border: none;
      cursor: pointer;
      transition: all 0.2s;
      box-shadow: 0 4px 16px rgba(59,130,246,0.25);
    }
    .auth-submit:hover {
      box-shadow: 0 6px 24px rgba(59,130,246,0.4);
      transform: translateY(-1px);
    }
    .auth-submit:disabled {
      opacity: 0.5;
      transform: none;
      box-shadow: none;
    }
  </style>
</head>
<body class="bg-surface text-white min-h-screen flex items-center justify-center" style="font-family:'Plus Jakarta Sans','Space Grotesk',system-ui,sans-serif;">
  <div class="auth-glow"></div>

  <div class="auth-wrapper w-full max-w-sm mx-auto px-6">
    <div class="text-center mb-8">
      <a href="/" style="font-family:'Space Grotesk',system-ui,sans-serif; font-size:1.9rem; font-weight:700; color:#fff; letter-spacing:-0.02em; text-decoration:none;">Catalyst</a>
      <p class="text-white/30 text-sm mt-1">Console</p>
    </div>

    <div class="card-glass" style="padding:clamp(1.5rem,3vw,2rem);">
      <div style="position:relative;z-index:2;">
        <h1 class="text-lg font-semibold mb-2">Verify your email</h1>
        <p id="subtitle" class="text-white/40 text-sm mb-6">Sending a verification code to your email...</p>

        <div id="error" class="hidden bg-red-500/10 border border-red-500/20 text-red-400 text-sm rounded-lg px-4 py-3 mb-4"></div>
        <div id="success" class="hidden bg-green-500/10 border border-green-500/20 text-green-400 text-sm rounded-lg px-4 py-3 mb-4"></div>

        <form id="verify-form" class="space-y-4">
          <div>
            <input type="text" id="code" name="code" required maxlength="6" pattern="[0-9]{6}" inputmode="numeric" autocomplete="one-time-code" class="code-input" placeholder="000000" />
          </div>
          <button type="submit" id="submit-btn" class="auth-submit">Verify</button>
        </form>

        <div class="flex items-center justify-between mt-4">
          <button id="resend-btn" class="text-catalyst-blue text-sm hover:underline disabled:opacity-30 disabled:no-underline" disabled>
            Sending...
          </button>
          <a href="/console/dashboard" class="text-white/30 text-sm hover:text-white/50">Skip for now</a>
        </div>
      </div>
    </div>
  </div>

  <script is:inline src="/js/verify-email.js"></script>
</body>
</html>
