---
import ConsoleLayout from '../../layouts/ConsoleLayout.astro';
---

<ConsoleLayout title="Login Successful" active="">
  <div class="text-center py-16">
    <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-green-500/10 border border-green-500/20 mb-6">
      <svg class="w-8 h-8 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
      </svg>
    </div>
    <h1 class="text-xl font-semibold text-white mb-2">CLI Authenticated</h1>
    <p class="text-white/40 text-sm mb-8">Your Catalyst CLI is now logged in. You can close this tab.</p>
    <a href="/console/dashboard" class="text-catalyst-blue hover:text-catalyst-blue/80 text-sm transition-colors">
      Go to Dashboard &rarr;
    </a>
  </div>
</ConsoleLayout>
