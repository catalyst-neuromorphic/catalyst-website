---
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/600.css';
import '../../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sign up — Catalyst Console</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="bg-[#0a0a0a] text-white min-h-screen flex items-center justify-center">
  <div class="w-full max-w-sm mx-auto px-6">
    <div class="text-center mb-8">
      <a href="/" class="text-catalyst-blue font-bold text-2xl tracking-tight">CATALYST</a>
      <p class="text-white/30 text-sm mt-1">Console</p>
    </div>

    <div class="bg-[#111] border border-white/10 rounded-xl p-6">
      <h1 class="text-lg font-semibold mb-6">Create an account</h1>

      <div id="error" class="hidden bg-red-500/10 border border-red-500/20 text-red-400 text-sm rounded-lg px-4 py-3 mb-4"></div>

      <!-- OAuth buttons -->
      <div class="space-y-3 mb-6">
        <button id="github-btn" class="w-full flex items-center justify-center gap-2 bg-[#1a1a1a] hover:bg-[#222] border border-white/10 rounded-lg px-4 py-2.5 text-sm transition-colors">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          Sign up with GitHub
        </button>
        <button id="google-btn" class="w-full flex items-center justify-center gap-2 bg-[#1a1a1a] hover:bg-[#222] border border-white/10 rounded-lg px-4 py-2.5 text-sm transition-colors">
          <svg width="20" height="20" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          Sign up with Google
        </button>
      </div>

      <div class="flex items-center gap-3 mb-6">
        <div class="flex-1 border-t border-white/10"></div>
        <span class="text-white/20 text-xs">or</span>
        <div class="flex-1 border-t border-white/10"></div>
      </div>

      <form id="signup-form" class="space-y-4">
        <div>
          <label for="email" class="block text-sm text-white/60 mb-1">Email</label>
          <input type="email" id="email" name="email" required
            class="w-full bg-[#1a1a1a] border border-white/10 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-catalyst-blue/50" />
        </div>
        <div>
          <label for="password" class="block text-sm text-white/60 mb-1">Password</label>
          <input type="password" id="password" name="password" required minlength="8"
            class="w-full bg-[#1a1a1a] border border-white/10 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-catalyst-blue/50" />
          <p class="text-white/20 text-xs mt-1">Minimum 8 characters</p>
        </div>
        <div>
          <label for="confirm" class="block text-sm text-white/60 mb-1">Confirm password</label>
          <input type="password" id="confirm" name="confirm" required minlength="8"
            class="w-full bg-[#1a1a1a] border border-white/10 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-catalyst-blue/50" />
        </div>
        <button type="submit" id="submit-btn"
          class="w-full bg-catalyst-blue hover:bg-catalyst-blue/90 text-white font-medium rounded-lg px-4 py-2.5 text-sm transition-colors">
          Create account
        </button>
      </form>

      <p class="text-white/30 text-sm mt-4 text-center">Free tier includes 500 compute-seconds/week.</p>

      <p class="text-center text-white/30 text-sm mt-4">
        Already have an account? <a href="/console/login" class="text-catalyst-blue hover:underline">Log in</a>
      </p>
    </div>
  </div>

  <script>
    const API = 'https://api.catalyst-neuromorphic.com';
    const CALLBACK_URL = `${window.location.origin}/console/oauth-callback`;

    if (localStorage.getItem('catalyst_token')) {
      window.location.href = '/console/dashboard';
    }

    // OAuth buttons
    document.getElementById('github-btn')?.addEventListener('click', () => {
      window.location.href = `${API}/v1/auth/github?redirect_uri=${encodeURIComponent(CALLBACK_URL)}`;
    });

    document.getElementById('google-btn')?.addEventListener('click', () => {
      window.location.href = `${API}/v1/auth/google?redirect_uri=${encodeURIComponent(CALLBACK_URL)}`;
    });

    // Email/password form
    document.getElementById('signup-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const errorEl = document.getElementById('error')!;
      const btn = document.getElementById('submit-btn') as HTMLButtonElement;
      const email = (document.getElementById('email') as HTMLInputElement).value;
      const password = (document.getElementById('password') as HTMLInputElement).value;
      const confirm = (document.getElementById('confirm') as HTMLInputElement).value;

      if (password !== confirm) {
        errorEl.textContent = 'Passwords do not match.';
        errorEl.classList.remove('hidden');
        return;
      }

      errorEl.classList.add('hidden');
      btn.textContent = 'Creating account...';
      btn.disabled = true;

      try {
        const res = await fetch(`${API}/v1/auth/signup`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password }),
        });

        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          throw new Error(data.detail || 'Signup failed');
        }

        const data = await res.json();
        localStorage.setItem('catalyst_token', data.access_token);
        localStorage.setItem('catalyst_refresh_token', data.refresh_token);
        window.location.href = '/console/dashboard';
      } catch (err: any) {
        errorEl.textContent = err.message;
        errorEl.classList.remove('hidden');
        btn.textContent = 'Create account';
        btn.disabled = false;
      }
    });
  </script>
</body>
</html>
