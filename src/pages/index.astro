<script type="importmap">{"imports":{"three":"https://cdn.jsdelivr.net/npm/three@0.172.0/build/three.module.js","three/addons/":"https://cdn.jsdelivr.net/npm/three@0.172.0/examples/jsm/"}}</script>
<!-- Fonts: Space Grotesk (headings/logo) + Plus Jakarta Sans (body) -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
  html{scroll-behavior:smooth}

  body{
    background:#050507;
    color:#fff;
    font-family:'Plus Jakarta Sans',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
    -webkit-font-smoothing:antialiased;
    overflow-x:hidden;
  }

  /* noise — use will-change to promote to own compositor layer, avoids repaint on scroll */
  body::after{
    content:'';position:fixed;inset:0;pointer-events:none;z-index:9999;opacity:.035;
    will-change:transform;
    background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat:repeat;background-size:256px;
  }

  /* ═══════════════════════════════════
     NAV
     ═══════════════════════════════════ */
  .nav{
    position:fixed;top:0;left:0;right:0;z-index:100;
    display:flex;align-items:center;justify-content:space-between;
    padding:30px 56px;
    transition:background .6s ease, backdrop-filter .6s ease, -webkit-backdrop-filter .6s ease;
  }
  .nav::after{
    content:'';position:absolute;bottom:-20px;left:0;right:0;height:20px;
    background:linear-gradient(180deg,rgba(5,5,7,0.4),transparent);
    opacity:0;transition:opacity .6s ease;pointer-events:none;
  }
  .nav.scrolled{
    background:rgba(5,5,7,0.55);
    backdrop-filter:blur(24px) saturate(180%);
    -webkit-backdrop-filter:blur(24px) saturate(180%);
  }
  .nav.scrolled::after{opacity:1}
  .nav-logo{
    font-family:'Space Grotesk',system-ui,sans-serif;
    font-size:1.9rem;font-weight:700;color:#fff;
    letter-spacing:-0.02em;text-decoration:none;
  }
  .nav-links{display:flex;align-items:center;gap:50px}
  .nav-links a{
    font-family:'Plus Jakarta Sans',sans-serif;
    font-size:1.2rem;font-weight:500;color:rgba(255,255,255,0.6);
    text-decoration:none;transition:color .25s;
  }
  .nav-links a:hover{color:#fff}

  /* ═══════════════════════════════════
     HERO
     ═══════════════════════════════════ */
  #hero-canvas { position:fixed; top:0; left:0; width:100%; height:100%; z-index:0; }
  .hero { height:100vh; position:relative; z-index:1; display:flex; align-items:center; justify-content:center; flex-direction:column; }
  .hero h1 { font-family:'Space Grotesk',system-ui,sans-serif; font-size:clamp(4rem,10vw,8rem); font-weight:700; color:white; letter-spacing:-0.03em; text-shadow:0 0 80px rgba(59,130,246,0.3),0 0 160px rgba(59,130,246,0.1); }
  .hero p { color:rgba(255,255,255,0.4); font-size:1.1rem; margin-top:16px; text-align:center; font-family:'Plus Jakarta Sans',system-ui,sans-serif; }
  .hero-ctas { display:flex; gap:16px; margin-top:36px; }
  .hero-ctas a { display:inline-flex; align-items:center; gap:8px; padding:14px 32px; border-radius:999px; font-family:'Plus Jakarta Sans',sans-serif; font-size:.95rem; font-weight:600; text-decoration:none; transition:all .3s; position:relative;z-index:1; }
  .hero-ctas .primary { background:linear-gradient(135deg,#3B82F6,#2563EB); color:#fff; box-shadow:0 4px 20px rgba(59,130,246,0.35); }
  .hero-ctas .primary:hover { box-shadow:0 8px 32px rgba(59,130,246,0.5); transform:translateY(-1px); }
  .hero-ctas .secondary { border:1px solid rgba(255,255,255,0.15); color:rgba(255,255,255,0.7); background:rgba(255,255,255,0.04); }
  .hero-ctas .secondary:hover { background:rgba(255,255,255,0.08); color:#fff; }

  /* ═══════════════════════════════════
     SECTION WRAPPER
     ═══════════════════════════════════ */
  /* frosted glass background for content over hero */
  .frost{
    position:relative;z-index:1;
    background:rgba(5,5,7,0.65);
    backdrop-filter:blur(40px) saturate(150%);
    -webkit-backdrop-filter:blur(40px) saturate(150%);
    /* Soft fade-in at top — masks the entire frost effect (bg + blur) */
    -webkit-mask-image:linear-gradient(to bottom, transparent, black 220px);
    mask-image:linear-gradient(to bottom, transparent, black 220px);
  }

  .section{
    position:relative;z-index:1;
    max-width:820px;
    margin:0 auto;
    padding:80px 40px 60px;
  }
  .section:first-child{ padding-top:220px; }
  .section + .section{ border-top:1px solid rgba(255,255,255,0.05); }

  .pillar-stack,.app-section{position:relative}

  .sh{
    font-family:'Space Grotesk','Plus Jakarta Sans',sans-serif;
    font-size:clamp(1.8rem,3.5vw,2.4rem);
    font-weight:700;letter-spacing:-.025em;
    line-height:1.15;text-align:left;
    margin-bottom:24px;
    color:rgba(255,255,255,0.92);
  }
  .ss{
    font-size:1.05rem;color:rgba(255,255,255,0.45);
    text-align:left;max-width:740px;
    margin:0 0 20px;line-height:1.85;
    font-weight:400;
  }
  .section-tag{
    display:inline-block;
    font-family:'Plus Jakarta Sans',sans-serif;
    font-size:.75rem;font-weight:600;
    color:rgba(59,130,246,0.7);letter-spacing:.05em;
    text-transform:uppercase;
    margin-bottom:12px;
  }
  .section-links{
    margin-top:8px;
  }
  .section-links a{
    color:rgba(59,130,246,0.8);font-weight:500;font-size:.95rem;
    text-decoration:none;
  }
  .section-links a:hover{ text-decoration:underline;color:#3B82F6; }

  .spec-row{
    display:flex;flex-wrap:wrap;gap:10px;
    margin-bottom:24px;
  }
  .spec-pill{
    display:inline-block;
    padding:6px 14px;
    border-radius:6px;
    background:rgba(255,255,255,0.04);
    border:1px solid rgba(255,255,255,0.07);
    font-family:'Space Grotesk','Plus Jakarta Sans',sans-serif;
    font-size:.85rem;font-weight:600;
    color:rgba(255,255,255,0.75);
    letter-spacing:-.01em;
  }

  /* heading/subheading reveal */
  .text-anim{
    opacity:0;transform:translateY(28px);
    transition:opacity .9s cubic-bezier(.16,1,.3,1),transform .9s cubic-bezier(.16,1,.3,1);
  }
  .text-anim.in{opacity:1;transform:none}
  .text-anim.d1{transition-delay:.08s}

  @media(max-width:900px){
    .nav-links{gap:16px}
    .nav-links a:nth-child(3),
    .nav-links a:nth-child(4){display:none}
    .section{padding:60px 24px 40px}
    .section:first-child{padding-top:180px}
  }
  .btn{
    display:inline-flex;align-items:center;gap:6px;
    padding:12px 28px;border-radius:999px;
    font-family:'Plus Jakarta Sans',sans-serif;
    font-size:.88rem;font-weight:600;text-decoration:none;
    transition:all .3s;position:relative;z-index:2;
  }
  .btn-blue{background:linear-gradient(135deg,#3B82F6,#2563EB);color:#fff;box-shadow:0 4px 16px rgba(59,130,246,0.3)}
  .btn-blue:hover{box-shadow:0 6px 24px rgba(59,130,246,0.45);transform:translateY(-1px)}
  .btn-ghost{border:1px solid rgba(255,255,255,0.15);color:rgba(255,255,255,0.7);background:rgba(255,255,255,0.04)}
  .btn-ghost:hover{background:rgba(255,255,255,0.08);color:#fff}

  /* ── GLOW BUTTONS — Huly-style internal spotlight ── */
  .glow-btn{
    position:relative;overflow:hidden;
  }
  .glow-spot{
    position:absolute;top:50%;
    transform:translateY(-50%);
    width:200px;height:100%;
    display:flex;align-items:center;justify-content:center;
    z-index:0;pointer-events:none;
    opacity:0;
    will-change:transform,opacity;
  }
  .glow-spot-circle{
    position:absolute;width:120px;height:120px;border-radius:50%;
    background:radial-gradient(50% 50% at 50% 50%,
      rgba(255,255,255,0.90) 3.5%,
      rgba(96,165,250,0.70) 26.5%,
      rgba(147,197,253,0.50) 37.5%,
      rgba(59,130,246,0.25) 49%,
      rgba(37,99,235,0) 92.5%
    );
  }
  .glow-spot-wide{
    position:absolute;width:200px;height:100px;
    background:radial-gradient(43.3% 44.23% at 50% 49.51%,
      rgba(255,255,255,0.70) 29%,
      rgba(191,219,254,0.50) 48.5%,
      rgba(147,197,253,0.25) 60.71%,
      rgba(214,211,210,0) 100%
    );
    filter:blur(5px);
  }
  /* external glow — uses box-shadow since child is clipped by overflow:hidden */
  .glow-btn{
    transition:box-shadow .4s ease;
  }
  .glow-btn.glow-on{
    box-shadow:
      0 0 25px rgba(59,130,246,0.25),
      0 0 50px rgba(59,130,246,0.08);
  }

  /* ═══════════════════════════════════
     FOOTER
     ═══════════════════════════════════ */
  .site-footer{
    position:relative;z-index:1;
    border-top:1px solid rgba(255,255,255,0.06);
    padding:32px 40px;
  }
  .footer-bottom{
    max-width:1100px;margin:24px auto 0;
    padding-top:24px;border-top:1px solid rgba(255,255,255,0.04);
    display:flex;justify-content:space-between;align-items:center;
    font-size:.78rem;color:rgba(255,255,255,0.25);
  }
  .footer-legal{display:flex;align-items:center;gap:8px;}
  .footer-legal a{color:rgba(255,255,255,0.35);text-decoration:none;transition:color .25s;}
  .footer-legal a:hover{color:rgba(255,255,255,0.6);}

</style>
</head>
<body>

<!-- Nav -->
<nav class="nav" id="main-nav">
  <a href="#" class="nav-logo">Catalyst</a>
  <div class="nav-links">
    <a href="#processors">Processors</a>
    <a href="#research">Research</a>
    <a href="#contact">Contact</a>
    <a href="https://github.com/catalyst-neuromorphic">GitHub</a>
  </div>
</nav>

<!-- Hero Canvas (Three.js renders here) -->
<canvas id="hero-canvas"></canvas>

<!-- Hero Content -->
<section class="hero">
  <h1>Catalyst</h1>
  <p>Neuromorphic processors for edge inference.</p>
  <div class="hero-ctas">
    <a href="https://github.com/catalyst-neuromorphic" class="primary">View on GitHub &rarr;</a>
    <a href="#contact" class="secondary">Get in touch</a>
  </div>
</section>

<!-- Frost wrapper — frosted glass over Three.js hero -->
<div class="frost">

<section class="section">
  <p class="ss text-anim d1">
    We design spiking neural network processors from scratch in Verilog and validate them on real FPGA hardware. Event-driven cores that fire only on input, learn on-chip through programmable plasticity rules, and run at a fraction of the power of conventional accelerators. Four generations designed. Two open sourced.
  </p>
</section>

<section class="section" id="processors">
  <span class="section-tag text-anim">Open Source &middot; Apache 2.0</span>
  <h2 class="sh text-anim">N1</h2>
  <div class="spec-row text-anim d1">
    <span class="spec-pill">128 cores</span>
    <span class="spec-pill">131,072 neurons</span>
    <span class="spec-pill">62.5 MHz FPGA</span>
    <span class="spec-pill">STDP learning</span>
    <span class="spec-pill">RISC-V cluster</span>
  </div>
  <p class="ss text-anim d1">
    Loihi 1 feature parity. 14-opcode microcode learning engine, barrier-synchronised mesh network-on-chip with multi-chip serial links, triple RV32IMF RISC-V cluster. Validated on AWS F2 (VU47P) and Kria K26.
  </p>
  <div class="section-links text-anim d2"><a href="https://github.com/catalyst-neuromorphic/catalyst-n1">GitHub</a> &nbsp;&middot;&nbsp; <a href="https://doi.org/10.5281/zenodo.18727094">Paper</a></div>
</section>

<section class="section">
  <span class="section-tag text-anim">Open Source &middot; Apache 2.0</span>
  <h2 class="sh text-anim">N2</h2>
  <div class="spec-row text-anim d1">
    <span class="spec-pill">128 cores</span>
    <span class="spec-pill">4-compartment dendrites</span>
    <span class="spec-pill">64-instruction microcode</span>
    <span class="spec-pill">3-factor plasticity</span>
    <span class="spec-pill">Python SDK</span>
  </div>
  <p class="ss text-anim d1">
    Programmable microcode neurons with Loihi 2 parity. Graded spike transmission, eligibility traces, reward-modulated plasticity. 28/28 hardware tests on AWS F2. SDK with CPU, GPU, UART, and PCIe backends.
  </p>
  <div class="section-links text-anim d2"><a href="https://github.com/catalyst-neuromorphic/catalyst-n2">GitHub</a> &nbsp;&middot;&nbsp; <a href="https://doi.org/10.5281/zenodo.18728256">Paper</a></div>
</section>

<section class="section">
  <h2 class="sh text-anim">N3</h2>
  <div class="spec-row text-anim d1">
    <span class="spec-pill">128 cores &middot; 16 tiles</span>
    <span class="spec-pill">4.2M virtual neurons</span>
    <span class="spec-pill">8 neuron models</span>
    <span class="spec-pill">28-opcode learning</span>
    <span class="spec-pill">NeurOS scheduler</span>
  </div>
  <p class="ss text-anim d1">
    Time-division multiplexing, async hybrid NoC with adaptive routing, 4 parallel learning threads, hardware short-term plasticity and homeostatic scaling. NeurOS virtualisation scheduling 680+ concurrent networks. 19/19 hardware tests on AWS F2.
  </p>
  <div class="section-links text-anim d2"><a href="https://doi.org/10.5281/zenodo.18881283">Paper</a></div>
</section>

<section class="section">
  <h2 class="sh text-anim">N4</h2>
  <div class="spec-row text-anim d1">
    <span class="spec-pill">512 cores</span>
    <span class="spec-pill">134M virtual neurons</span>
    <span class="spec-pill">Spike Tensor Core</span>
    <span class="spec-pill">0.378 W edge</span>
    <span class="spec-pill">48 GB HBM3E</span>
    <span class="spec-pill">126/126 FPGA tests</span>
  </div>
  <p class="ss text-anim d1">
    Dual-chiplet architecture with 4.19M physical neurons, expandable to 134M via 32-context TDM. 16&times;16 Spike Tensor Core, 8-head spiking attention with KV cache, 8 synapse formats including KAN B-spline. Hardware backpropagation, hyperdimensional computing, Hopfield memory, post-quantum security.
  </p>
  <p class="ss text-anim d2">
    3,229 simulation tests passing. N4-Edge variant runs at 2.6% LUT utilisation and 0.378 W total on Kria K26.
  </p>
  <div class="section-links text-anim d2"><a href="https://doi.org/10.5281/zenodo.19332513">Paper</a></div>
</section>

<section class="section" id="research">
  <h2 class="sh text-anim">Results</h2>
  <div class="spec-row text-anim d1">
    <span class="spec-pill">SHD 91.0%</span>
    <span class="spec-pill">N-MNIST 99.2%</span>
    <span class="spec-pill">SSC 76.4%</span>
    <span class="spec-pill">GSC-12 88.0%</span>
  </div>
  <p class="ss text-anim d1">
    All from FPGA-validated builds. Trained on GPU, quantized to 16-bit, deployed on hardware.
  </p>
  <div class="section-links text-anim d2">
    <a href="https://doi.org/10.5281/zenodo.19332513">N4 Paper</a> &nbsp;&middot;&nbsp;
    <a href="https://doi.org/10.5281/zenodo.18881283">N3 Paper</a> &nbsp;&middot;&nbsp;
    <a href="https://doi.org/10.5281/zenodo.18728256">N2 Paper</a> &nbsp;&middot;&nbsp;
    <a href="https://doi.org/10.5281/zenodo.18727094">N1 Paper</a> &nbsp;&middot;&nbsp;
    <a href="https://github.com/catalyst-neuromorphic/catalyst-benchmarks">Benchmarks</a>
  </div>
</section>

<section class="section" id="contact" style="border-top:1px solid rgba(255,255,255,0.06)">
  <h2 class="sh text-anim">Contact</h2>
  <p class="ss text-anim d1">Open to research collaboration, FPGA contract work, and partnerships.</p>
  <div class="section-links text-anim d2" style="display:flex;gap:24px">
    <a href="mailto:henry@catalyst-neuromorphic.com">henry@catalyst-neuromorphic.com</a>
    <a href="https://github.com/catalyst-neuromorphic">GitHub</a>
  </div>
</section>

<footer class="site-footer">
  <div class="footer-bottom">
    <span>&copy; 2026 Catalyst Neuromorphic Ltd. Company No. 17054540.</span>
    <span class="footer-legal">
      <a href="/terms">Terms</a>
      <span>&middot;</span>
      <a href="/privacy">Privacy</a>
    </span>
  </div>
</footer>

</div><!-- end .frost -->

