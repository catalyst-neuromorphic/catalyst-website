---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Catalyst — Neuromorphic Processors">

  <!-- HERO -->
  <section class="hero-section min-h-screen flex items-center justify-center text-center relative overflow-hidden">
    <div id="neuralCanvas" class="absolute inset-0 z-[1] grid grid-cols-[repeat(40,1fr)] grid-rows-[repeat(22,1fr)] gap-px"></div>

    <!-- Chip render floating over grid -->
    <div class="absolute inset-0 z-[2] flex items-center justify-center pointer-events-none">
      <div class="chip-glow w-[280px] md:w-[400px] lg:w-[480px] opacity-60">
        <img src="/images/renders/n2-top.webp" alt="Catalyst N2 processor die" class="w-full h-auto rounded-2xl" loading="eager" />
      </div>
    </div>

    <div class="relative z-[3] px-6">
      <h1 class="text-[clamp(4rem,8vw,8rem)] font-bold tracking-tighter leading-[0.9]">Catalyst</h1>
      <p class="text-[clamp(1rem,1.5vw,1.25rem)] text-white/40 mt-5 max-w-[520px] mx-auto leading-relaxed">
        Neuromorphic processors that think, learn, and consume almost nothing.
      </p>
      <div class="flex gap-4 justify-center mt-10">
        <a href="/processors/n2" class="btn-primary">Explore N2 &rarr;</a>
        <a href="/cloud" class="btn-pill">Try Cloud API</a>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-[3] w-6 h-10 rounded-xl border border-white/15 flex justify-center pt-2 max-md:hidden">
      <span class="w-[3px] h-2 rounded-full bg-white/30 animate-bounce"></span>
    </div>
  </section>

  <!-- THE PROBLEM -->
  <section class="py-40 px-6 md:px-12">
    <div class="max-w-[800px] mx-auto text-center">
      <h2 class="reveal text-[clamp(2.5rem,5vw,4rem)] font-bold tracking-tight leading-tight">AI has a power problem.</h2>
      <p class="reveal text-lg text-white/40 mt-6 leading-relaxed max-w-[600px] mx-auto">
        Today's artificial intelligence burns through electricity at an unsustainable rate. Data centres already consume more power than some countries. GPUs brute-force their way through billions of calculations every cycle, whether they need to or not.
      </p>
      <p class="reveal text-lg text-white/40 mt-4 leading-relaxed max-w-[600px] mx-auto">
        There has to be a better way.
      </p>
    </div>
  </section>

  <!-- THE SOLUTION -->
  <section class="py-32 px-6 md:px-12">
    <div class="max-w-[900px] mx-auto text-center">
      <h2 class="reveal text-[clamp(2.5rem,5vw,4rem)] font-bold tracking-tight leading-tight">Nature solved this 500 million years ago.</h2>
      <p class="reveal text-lg text-white/40 mt-6 leading-relaxed max-w-[640px] mx-auto">
        Your brain runs on 20 watts. It processes millions of sensory inputs in real time, learns continuously, and never needs a cooling system. We built processors that work the same way.
      </p>
    </div>
    <div class="max-w-[1000px] mx-auto mt-20 grid grid-cols-3 gap-8 text-center reveal-stagger">
      <div>
        <div class="text-[clamp(2rem,4vw,3.5rem)] font-bold tracking-tight text-white/90" data-count="1000" data-count-suffix="x">0x</div>
        <p class="text-sm text-white/40 mt-3 leading-relaxed">More energy efficient than GPU inference.</p>
      </div>
      <div>
        <div class="text-[clamp(2rem,4vw,3.5rem)] font-bold tracking-tight text-white/90">Real-time</div>
        <p class="text-sm text-white/40 mt-3 leading-relaxed">On-chip learning. No cloud retraining.</p>
      </div>
      <div>
        <div class="text-[clamp(2rem,4vw,3.5rem)] font-bold tracking-tight text-white/90" data-count="20" data-count-suffix="W">0W</div>
        <p class="text-sm text-white/40 mt-3 leading-relaxed">Brain-scale power. Not kilowatts.</p>
      </div>
    </div>
  </section>

  <!-- PRODUCTS -->
  <section id="products" class="py-40 px-6 md:px-12">
    <div class="max-w-[1100px] mx-auto">
      <h2 class="reveal text-[clamp(2rem,4vw,3rem)] font-bold tracking-tight text-center mb-16">Two generations of silicon.</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 reveal-stagger">
        <!-- N2 -->
        <a href="/processors/n2" class="group product-card-n2 rounded-2xl p-8 no-underline transition-all duration-300 hover:border-catalyst-blue/20">
          <div class="w-full aspect-square max-w-[320px] mx-auto mb-6 rounded-xl overflow-hidden">
            <img src="/images/renders/n2-angled.webp" alt="Catalyst N2 die shot" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
          </div>
          <div class="text-center">
            <p class="text-xs text-catalyst-blue font-medium tracking-wider uppercase mb-2">Second Generation</p>
            <h3 class="text-2xl font-bold tracking-tight">Catalyst N2</h3>
            <p class="text-sm text-white/40 mt-2 mb-4">Full Loihi 2 parity. 128 cores, 131,072 neurons, 5 neuron models, programmable learning engine.</p>
            <div class="grid grid-cols-3 gap-4 mt-4 pt-4 border-t border-white/[0.06]">
              <div>
                <p class="text-lg font-bold text-white/90">128</p>
                <p class="text-[10px] text-white/30 uppercase tracking-wider">Cores</p>
              </div>
              <div>
                <p class="text-lg font-bold text-white/90">131K</p>
                <p class="text-[10px] text-white/30 uppercase tracking-wider">Neurons</p>
              </div>
              <div>
                <p class="text-lg font-bold text-white/90">5</p>
                <p class="text-[10px] text-white/30 uppercase tracking-wider">Models</p>
              </div>
            </div>
          </div>
        </a>

        <!-- N1 -->
        <a href="/processors/n1" class="group product-card-n1 rounded-2xl p-8 no-underline transition-all duration-300 hover:border-white/15">
          <div class="w-full aspect-square max-w-[320px] mx-auto mb-6 rounded-xl overflow-hidden">
            <img src="/images/renders/n1-top.webp" alt="Catalyst N1 die shot" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
          </div>
          <div class="text-center">
            <p class="text-xs text-white/40 font-medium tracking-wider uppercase mb-2">First Generation</p>
            <h3 class="text-2xl font-bold tracking-tight">Catalyst N1</h3>
            <p class="text-sm text-white/40 mt-2 mb-4">Full Loihi 1 parity. The foundation — where Catalyst began.</p>
            <div class="grid grid-cols-3 gap-4 mt-4 pt-4 border-t border-white/[0.06]">
              <div>
                <p class="text-lg font-bold text-white/90">128</p>
                <p class="text-[10px] text-white/30 uppercase tracking-wider">Cores</p>
              </div>
              <div>
                <p class="text-lg font-bold text-white/90">131K</p>
                <p class="text-[10px] text-white/30 uppercase tracking-wider">Neurons</p>
              </div>
              <div>
                <p class="text-lg font-bold text-white/90">96</p>
                <p class="text-[10px] text-white/30 uppercase tracking-wider">Tests</p>
              </div>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- BY THE NUMBERS -->
  <section class="py-32 px-6 md:px-12">
    <div class="max-w-[1100px] mx-auto">
      <div class="reveal glass rounded-2xl p-12 md:p-16">
        <h2 class="text-[clamp(2rem,3.5vw,2.5rem)] font-bold tracking-tight text-center mb-12">By the numbers.</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center reveal-stagger">
          <div>
            <p class="text-[clamp(2rem,4vw,3rem)] font-bold tracking-tight text-catalyst-blue" data-count="131072">0</p>
            <p class="text-sm text-white/40 mt-1">Neurons</p>
          </div>
          <div>
            <p class="text-[clamp(2rem,4vw,3rem)] font-bold tracking-tight text-catalyst-blue" data-count="3091">0</p>
            <p class="text-sm text-white/40 mt-1">Tests passing</p>
          </div>
          <div>
            <p class="text-[clamp(2rem,4vw,3rem)] font-bold tracking-tight text-catalyst-blue">28/28</p>
            <p class="text-sm text-white/40 mt-1">FPGA validated</p>
          </div>
          <div>
            <p class="text-[clamp(2rem,4vw,3rem)] font-bold tracking-tight text-catalyst-blue" data-count="85" data-count-suffix=".9%">0%</p>
            <p class="text-sm text-white/40 mt-1">SHD benchmark</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CLOUD API -->
  <section id="access" class="py-32 px-6 md:px-12">
    <div class="max-w-[900px] mx-auto text-center">
      <h2 class="reveal text-[clamp(2rem,3.5vw,3rem)] font-bold tracking-tight">Access Catalyst.</h2>
      <p class="reveal text-base text-white/40 mt-4 leading-relaxed max-w-[640px] mx-auto">
        Run neuromorphic simulations via cloud API, or deploy on dedicated FPGA hardware. No GPU required.
      </p>
      <div class="max-w-[800px] mx-auto mt-12 grid grid-cols-1 md:grid-cols-2 gap-6 reveal-stagger">
        <div class="rounded-2xl p-8 border border-catalyst-blue/20 text-center" style="background: rgba(59,130,246,0.04);">
          <p class="text-lg font-bold text-catalyst-blue">Cloud API</p>
          <p class="text-3xl font-bold mt-2">Free<span class="text-sm text-white/40 font-normal"> to start</span></p>
          <p class="text-sm text-white/40 mt-3">REST API for neuromorphic compute. 500 compute-seconds/week free. No hardware, no install.</p>
          <a href="/cloud" class="btn-primary mt-6 inline-flex text-sm">Get started &rarr;</a>
        </div>
        <div class="rounded-2xl p-8 border border-white/[0.06] text-center">
          <p class="text-lg font-bold">FPGA Dev Boards</p>
          <p class="text-3xl font-bold mt-2">Coming soon</p>
          <p class="text-sm text-white/40 mt-3">Physical hardware with the Catalyst bitstream. Deploy at the edge. Real neuromorphic silicon.</p>
          <a href="mailto:henry@catalyst-neuromorphic.com" class="btn-pill mt-6 inline-flex text-sm">Register interest &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- RESEARCH TEASER -->
  <section class="py-32 px-6 md:px-12">
    <div class="max-w-[900px] mx-auto">
      <h2 class="reveal text-[clamp(2rem,3.5vw,2.5rem)] font-bold tracking-tight text-center mb-12">Published research.</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 reveal-stagger">
        <!-- N2 Paper -->
        <div class="glass rounded-xl p-6">
          <p class="text-xs text-catalyst-blue font-medium tracking-wider uppercase mb-3">Technical Paper</p>
          <h3 class="font-semibold text-white/90 mb-2">Catalyst N2: A Neuromorphic Processor with Full Loihi 2 Parity</h3>
          <p class="text-sm text-white/40 mb-4">18 pages. 128-core architecture, 5 neuron models, programmable microcode learning engine.</p>
          <a href="/papers/catalyst-n2.pdf" class="text-sm text-catalyst-blue hover:underline">Read paper &rarr;</a>
        </div>
        <!-- N1 Paper -->
        <div class="glass rounded-xl p-6">
          <p class="text-xs text-white/40 font-medium tracking-wider uppercase mb-3">Technical Paper</p>
          <h3 class="font-semibold text-white/90 mb-2">Catalyst N1: A First-Generation Neuromorphic Processor</h3>
          <p class="text-sm text-white/40 mb-4">13 pages. Loihi 1 parity. The first complete open neuromorphic processor design.</p>
          <div class="flex items-center gap-4">
            <a href="/papers/catalyst-n1.pdf" class="text-sm text-catalyst-blue hover:underline">Read paper &rarr;</a>
            <span class="text-xs text-white/25 font-mono">DOI: 10.5281/zenodo.18727094</span>
          </div>
        </div>
      </div>
      <div class="text-center mt-8">
        <a href="/research" class="text-sm text-white/40 hover:text-white transition-colors">View all research &rarr;</a>
      </div>
    </div>
  </section>

  <!-- FUNDING -->
  <section class="py-32 px-6 md:px-12">
    <div class="max-w-[800px] mx-auto text-center">
      <div class="glass-accent p-12 reveal">
        <h2 class="text-[clamp(1.8rem,3vw,2.5rem)] font-bold tracking-tight mb-4">Help us go from prototype to production.</h2>
        <p class="text-white/40 leading-relaxed mb-8">
          We're seeking grants, partnerships, and investment to bring neuromorphic computing from prototype to manufactured silicon.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="https://github.com/sponsors/catalyst-neuromorphic" target="_blank" rel="noopener noreferrer" class="btn-primary">Sponsor on GitHub</a>
          <a href="https://ko-fi.com/catalystneuromorphic" target="_blank" rel="noopener noreferrer" class="btn-pill">Support on Ko-Fi</a>
          <a href="mailto:henry@catalyst-neuromorphic.com" class="btn-pill">Get in touch</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .chip-glow {
    filter: drop-shadow(0 0 80px rgba(59,130,246,0.15)) drop-shadow(0 0 160px rgba(59,130,246,0.08));
  }
  .product-card-n2 {
    background: linear-gradient(180deg, rgba(59,130,246,0.03) 0%, transparent 100%);
    border: 1px solid rgba(59,130,246,0.08);
  }
  .product-card-n1 {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
  }
</style>

<script>
  // Neural grid animation
  (function() {
    var canvas = document.getElementById('neuralCanvas');
    if (!canvas) return;
    var COLS = 40, ROWS = 22;
    var cells = [];
    var brightness = new Float32Array(COLS * ROWS);
    for (var i = 0; i < COLS * ROWS; i++) {
      var c = document.createElement('div');
      c.className = 'n-cell';
      canvas.appendChild(c);
      cells.push(c);
    }
    function activate() {
      var cx = Math.random() * COLS, cy = Math.random() * ROWS;
      var r = 2 + Math.random() * 4, str = 0.6 + Math.random() * 0.4;
      for (var y = 0; y < ROWS; y++)
        for (var x = 0; x < COLS; x++) {
          var d = Math.sqrt((x - cx) * (x - cx) + (y - cy) * (y - cy));
          if (d < r) brightness[y * COLS + x] = Math.min(1, brightness[y * COLS + x] + Math.pow(1 - d / r, 2) * str);
        }
    }
    var glow = new Int8Array(COLS * ROWS);
    function render() {
      for (var i = 0; i < cells.length; i++) {
        var b = brightness[i];
        var lv = b > 0.6 ? 4 : b > 0.3 ? 3 : b > 0.12 ? 2 : b > 0.04 ? 1 : 0;
        if (lv !== glow[i]) {
          if (glow[i]) cells[i].classList.remove('a' + glow[i]);
          if (lv) cells[i].classList.add('a' + lv);
          glow[i] = lv;
        }
      }
    }
    var last = 0;
    function tick(t) {
      if (t - last > 50) {
        for (var j = 0; j < brightness.length; j++) { brightness[j] *= 0.96; if (brightness[j] < 0.01) brightness[j] = 0; }
        render();
        last = t;
      }
      requestAnimationFrame(tick);
    }
    function sched() { activate(); setTimeout(sched, 250 + Math.random() * 500); }
    for (var k = 0; k < 5; k++) activate();
    render(); requestAnimationFrame(tick); sched();
  })();
</script>
