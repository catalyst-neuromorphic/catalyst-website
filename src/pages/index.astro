<!-- Fonts: Space Grotesk (headings/logo) + Plus Jakarta Sans (body) -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
  html{scroll-behavior:smooth}

  body{
    background:#050507;
    color:#fff;
    font-family:'Plus Jakarta Sans',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
    -webkit-font-smoothing:antialiased;
    overflow-x:hidden;
  }

  /* noise */
  body::after{
    content:'';position:fixed;inset:0;pointer-events:none;z-index:9999;opacity:.035;
    background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat:repeat;background-size:256px;
  }

  /* ═══════════════════════════════════
     NAV
     ═══════════════════════════════════ */
  .nav{
    position:fixed;top:0;left:0;right:0;z-index:100;
    display:flex;align-items:center;justify-content:space-between;
    padding:30px 56px;
    transition:background .6s ease, backdrop-filter .6s ease, -webkit-backdrop-filter .6s ease;
  }
  .nav::after{
    content:'';position:absolute;bottom:-20px;left:0;right:0;height:20px;
    background:linear-gradient(180deg,rgba(5,5,7,0.4),transparent);
    opacity:0;transition:opacity .6s ease;pointer-events:none;
  }
  .nav.scrolled{
    background:rgba(5,5,7,0.55);
    backdrop-filter:blur(24px) saturate(180%);
    -webkit-backdrop-filter:blur(24px) saturate(180%);
  }
  .nav.scrolled::after{opacity:1}
  .nav-logo{
    font-family:'Space Grotesk',system-ui,sans-serif;
    font-size:1.9rem;font-weight:700;color:#fff;
    letter-spacing:-0.02em;text-decoration:none;
  }
  .nav-links{display:flex;align-items:center;gap:50px}
  .nav-links a{
    font-family:'Plus Jakarta Sans',sans-serif;
    font-size:1.2rem;font-weight:500;color:rgba(255,255,255,0.6);
    text-decoration:none;transition:color .25s;
  }
  .nav-links a:hover{color:#fff}

  /* Auth area */
  .auth-area{position:relative}
  .avatar-btn{
    width:34px;height:34px;border-radius:50%;
    background:rgba(59,130,246,0.15);border:1px solid rgba(59,130,246,0.25);
    color:#60A5FA;cursor:pointer;
    display:none;align-items:center;justify-content:center;
    transition:background .2s;
  }
  .avatar-btn:hover{background:rgba(59,130,246,0.25)}
  .avatar-dropdown{
    position:absolute;top:calc(100% + 12px);right:0;
    background:rgba(15,15,20,0.92);backdrop-filter:blur(24px) saturate(180%);
    border:1px solid rgba(255,255,255,0.08);border-radius:14px;
    padding:6px;min-width:180px;
    opacity:0;visibility:hidden;transform:translateY(-6px);
    transition:opacity .2s,visibility .2s,transform .2s;
    z-index:200;
  }
  .avatar-dropdown.open{opacity:1;visibility:visible;transform:translateY(0)}
  .avatar-dropdown a,.avatar-dropdown button{
    display:block;width:100%;padding:9px 14px;border-radius:8px;
    font-family:'Plus Jakarta Sans',sans-serif;font-size:.85rem;font-weight:500;
    color:rgba(255,255,255,0.6);text-decoration:none;text-align:left;
    background:none;border:none;cursor:pointer;transition:background .15s,color .15s;
  }
  .avatar-dropdown a:hover,.avatar-dropdown button:hover{
    background:rgba(255,255,255,0.06);color:#fff;
  }
  .avatar-divider{height:1px;background:rgba(255,255,255,0.06);margin:4px 0}

  /* ═══════════════════════════════════
     HERO
     ═══════════════════════════════════ */
  #hero-canvas { position:fixed; top:0; left:0; width:100%; height:100%; z-index:0; }
  .hero { height:100vh; position:relative; z-index:1; display:flex; align-items:center; justify-content:center; flex-direction:column; }
  .hero h1 { font-family:'Space Grotesk',system-ui,sans-serif; font-size:clamp(4rem,10vw,8rem); font-weight:700; color:white; letter-spacing:-0.03em; text-shadow:0 0 80px rgba(59,130,246,0.3),0 0 160px rgba(59,130,246,0.1); }
  .hero p { color:rgba(255,255,255,0.4); font-size:1.1rem; margin-top:16px; text-align:center; font-family:'Plus Jakarta Sans',system-ui,sans-serif; }
  .hero-ctas { display:flex; gap:16px; margin-top:36px; }
  .hero-ctas a { display:inline-flex; align-items:center; gap:8px; padding:14px 32px; border-radius:999px; font-family:'Plus Jakarta Sans',sans-serif; font-size:.95rem; font-weight:600; text-decoration:none; transition:all .3s; position:relative;z-index:1; }
  .hero-ctas .primary { background:linear-gradient(135deg,#3B82F6,#2563EB); color:#fff; box-shadow:0 4px 20px rgba(59,130,246,0.35); }
  .hero-ctas .primary:hover { box-shadow:0 8px 32px rgba(59,130,246,0.5); transform:translateY(-1px); }
  .hero-ctas .secondary { border:1px solid rgba(255,255,255,0.15); color:rgba(255,255,255,0.7); background:rgba(255,255,255,0.04); }
  .hero-ctas .secondary:hover { background:rgba(255,255,255,0.08); color:#fff; }

  /* ═══════════════════════════════════
     SECTION WRAPPER
     ═══════════════════════════════════ */
  /* frosted glass background for content over hero */
  .frost{
    position:relative;z-index:1;
    background:rgba(5,5,7,0.65);
    backdrop-filter:blur(40px) saturate(150%);
    -webkit-backdrop-filter:blur(40px) saturate(150%);
    /* Soft fade-in at top — masks the entire frost effect (bg + blur) */
    -webkit-mask-image:linear-gradient(to bottom, transparent, black 220px);
    mask-image:linear-gradient(to bottom, transparent, black 220px);
  }

  .section{
    position:relative;z-index:1;
    max-width:1100px;
    margin:0 auto;
    padding:220px 32px 60px;
  }

  .pillar-stack,.app-section{position:relative}

  .sh{
    font-family:'Space Grotesk','Plus Jakarta Sans',sans-serif;
    font-size:clamp(2.4rem,5vw,3.6rem);
    font-weight:700;letter-spacing:-.035em;
    line-height:1.08;text-align:center;
    margin-bottom:18px;
  }
  .ss{
    font-size:1.05rem;color:rgba(255,255,255,0.5);
    text-align:center;max-width:560px;
    margin:0 auto 72px;line-height:1.7;
    font-weight:400;
  }

  /* ═══════════════════════════════════
     EDITORIAL PILLAR CARDS
     ═══════════════════════════════════ */
  .pillar-stack{
    display:flex;flex-direction:column;
    gap:28px;
  }

  .pcard{
    position:relative;z-index:2;
    display:flex;
    height:340px;
    border-radius:20px;
    overflow:hidden;
    /* glassmorphism fill — extra glassy */
    background:linear-gradient(
      165deg,
      rgba(255,255,255,0.12) 0%,
      rgba(255,255,255,0.05) 35%,
      rgba(255,255,255,0.025) 100%
    );
    backdrop-filter:blur(28px) saturate(190%) brightness(1.06);
    -webkit-backdrop-filter:blur(28px) saturate(190%) brightness(1.06);
    border:1px solid transparent;
    box-shadow:
      0 8px 32px rgba(0,0,0,0.45),
      inset 0 1px 0 rgba(255,255,255,0.14),
      inset 0 -1px 0 rgba(255,255,255,0.02);
    --mx:50%;--my:50%;
    transform:translateZ(0);
    transition:box-shadow .5s,transform .3s;
    cursor:pointer;
  }
  .pcard:hover{
    transform:translateY(-2px);
    box-shadow:
      0 12px 48px rgba(0,0,0,0.55),
      inset 0 1px 0 rgba(255,255,255,0.18),
      inset 0 -1px 0 rgba(255,255,255,0.03);
  }

  /* gradient glow border — always-on faint, stronger on hover */
  .pcard::before{
    content:'';position:absolute;inset:0;border-radius:20px;padding:1px;
    background:linear-gradient(
      135deg,
      rgba(59,130,246,0.22) 0%,
      rgba(59,130,246,0.06) 25%,
      rgba(59,130,246,0.02) 50%,
      rgba(59,130,246,0.06) 75%,
      rgba(59,130,246,0.18) 100%
    );
    -webkit-mask:linear-gradient(#fff 0 0) content-box,linear-gradient(#fff 0 0);
    -webkit-mask-composite:xor;mask-composite:exclude;
    pointer-events:none;z-index:5;
    opacity:.55;transition:opacity .4s;
  }
  .pcard:hover::before{opacity:1}

  /* bottom glow removed — fog box-shadow replaces it */

  /* Aero-style top reflection on text area */
  .pcard-text::before{
    content:'';position:absolute;top:0;left:0;right:0;height:45%;
    background:linear-gradient(180deg,rgba(255,255,255,0.025) 0%,transparent 100%);
    pointer-events:none;border-radius:0 20px 0 0;
  }
  .pcard:nth-child(even) .pcard-text::before{
    border-radius:20px 0 0 0;
  }

  /* image half */
  .pcard-img{
    position:relative;width:55%;flex-shrink:0;overflow:hidden;
  }
  .pcard-img .bg{
    position:absolute;inset:-10px;
    background-size:cover;background-position:center;
    will-change:transform;
    transition:transform 14s cubic-bezier(.22,1,.36,1);
  }
  .pcard:hover .bg{transform:scale(1.06)}

  /* gradient fade between image and text */
  .pcard-img .fade{
    position:absolute;inset:0;z-index:1;
  }
  .pcard:nth-child(odd) .pcard-img .fade{
    background:linear-gradient(90deg,transparent 25%,rgba(5,5,7,0.55) 70%,rgba(5,5,7,0.8) 100%);
  }
  .pcard:nth-child(even) .pcard-img .fade{
    background:linear-gradient(270deg,transparent 25%,rgba(5,5,7,0.55) 70%,rgba(5,5,7,0.8) 100%);
  }

  /* text half */
  .pcard-text{
    position:relative;width:45%;
    display:flex;flex-direction:column;justify-content:center;
    padding:48px 48px 48px 24px;
    z-index:2;
  }

  /* alternate: image right, text left */
  .pcard:nth-child(even) .pcard-img{order:2}
  .pcard:nth-child(even) .pcard-text{order:1;padding:48px 24px 48px 48px}

  .pcard-tag{
    display:inline-block;font-size:.65rem;font-weight:600;
    text-transform:uppercase;letter-spacing:.08em;
    color:#60A5FA;margin-bottom:14px;
    width:fit-content;
  }
  .pcard-h{
    font-family:'Space Grotesk','Plus Jakarta Sans',sans-serif;
    font-size:clamp(1.5rem,2.5vw,2rem);font-weight:700;
    letter-spacing:-.025em;line-height:1.15;margin-bottom:12px;
  }
  .pcard-p{
    font-size:.92rem;color:rgba(255,255,255,0.55);line-height:1.7;
    font-weight:400;
  }

  /* number accent */
  .pcard-num{
    position:absolute;top:32px;right:32px;
    font-family:'Space Grotesk',sans-serif;
    font-size:6rem;font-weight:800;letter-spacing:-.06em;
    color:rgba(59,130,246,0.06);line-height:1;
    pointer-events:none;z-index:0;
  }
  .pcard:nth-child(even) .pcard-num{right:auto;left:32px}

  /* ── animation: slide from image side ── */
  .pcard.anim{
    opacity:0;
    transition:opacity 1.1s cubic-bezier(.16,1,.3,1),transform 1.1s cubic-bezier(.16,1,.3,1);
  }
  .pcard.anim:nth-child(1){transform:translateX(-80px) scale(.97)}
  .pcard.anim:nth-child(2){transform:translateX(80px) scale(.97);transition-delay:.1s}
  .pcard.anim:nth-child(3){transform:translateX(-80px) scale(.97);transition-delay:.2s}
  .pcard.anim.in{opacity:1;transform:none}

  /* heading/subheading reveal */
  .text-anim{
    opacity:0;transform:translateY(28px);
    transition:opacity .9s cubic-bezier(.16,1,.3,1),transform .9s cubic-bezier(.16,1,.3,1);
  }
  .text-anim.in{opacity:1;transform:none}
  .text-anim.d1{transition-delay:.08s}

  /* ═══════════════════════════════════
     APPLICATION MARQUEE
     ═══════════════════════════════════ */
  .app-section{
    position:relative;z-index:1;
    padding:80px 0 120px;
    overflow:visible;
  }
  .app-section .sh,.app-section .ss{padding:0 32px}
  .app-section .ss{margin-bottom:56px}

  .divider{
    width:56px;height:1px;
    background:linear-gradient(90deg,transparent,rgba(59,130,246,.25),transparent);
    margin:0 auto 56px;
  }

  /* viewing window — wider but still not full-bleed */
  .marquee-wrap{
    position:relative;
    overflow:hidden;
    max-width:1140px;
    margin:0 auto 14px;
    -webkit-mask-image:linear-gradient(90deg,transparent 0%,#000 6%,#000 94%,transparent 100%);
    mask-image:linear-gradient(90deg,transparent 0%,#000 6%,#000 94%,transparent 100%);
  }

  .marquee-track{
    display:flex;gap:14px;
    width:max-content;
    will-change:transform;
  }
  /* 13 unique cards per row — longer duration so they don't whip past */
  .marquee-track.r1{animation:scroll-left 80s linear infinite}
  .marquee-track.r2{animation:scroll-left 90s linear infinite reverse}

  .marquee-track:hover{animation-play-state:paused}

  @keyframes scroll-left{
    0%{transform:translateX(0)}
    100%{transform:translateX(-50%)}
  }

  /* marquee card */
  .mcard{
    position:relative;z-index:2;
    flex:0 0 300px;height:200px;
    border-radius:16px;overflow:hidden;
    background:linear-gradient(
      165deg,
      rgba(255,255,255,0.10) 0%,
      rgba(255,255,255,0.04) 40%,
      rgba(255,255,255,0.02) 100%
    );
    backdrop-filter:blur(20px) saturate(180%) brightness(1.04);
    -webkit-backdrop-filter:blur(20px) saturate(180%) brightness(1.04);
    border:1px solid transparent;
    box-shadow:
      0 4px 20px rgba(0,0,0,0.35),
      inset 0 1px 0 rgba(255,255,255,0.10);
    --mx:50%;--my:50%;
    cursor:pointer;
    transition:box-shadow .4s,transform .3s;
  }
  .mcard:hover{
    transform:translateY(-2px);
    box-shadow:
      0 8px 32px rgba(0,0,0,0.45),
      inset 0 1px 0 rgba(255,255,255,0.14);
  }

  /* gradient glow border */
  .mcard::before{
    content:'';position:absolute;inset:0;border-radius:16px;padding:1px;
    background:linear-gradient(
      135deg,
      rgba(59,130,246,0.18) 0%,
      rgba(59,130,246,0.04) 30%,
      rgba(59,130,246,0.02) 50%,
      rgba(59,130,246,0.04) 70%,
      rgba(59,130,246,0.14) 100%
    );
    -webkit-mask:linear-gradient(#fff 0 0) content-box,linear-gradient(#fff 0 0);
    -webkit-mask-composite:xor;mask-composite:exclude;
    pointer-events:none;z-index:4;
    opacity:.45;transition:opacity .3s;
  }
  .mcard:hover::before{opacity:.9}

  .mcard .bg{
    position:absolute;inset:-6px;
    background-size:cover;background-position:center;
    transition:transform 12s cubic-bezier(.22,1,.36,1);
  }
  .mcard:hover .bg{transform:scale(1.05)}

  .mcard .ov{
    position:absolute;inset:0;z-index:1;
    background:linear-gradient(180deg,
      rgba(5,5,7,0) 5%,
      rgba(5,5,7,.55) 45%,
      rgba(5,5,7,.93) 100%
    );
  }

  .mcard .ct{
    position:absolute;bottom:0;left:0;right:0;z-index:2;
    padding:16px 20px 20px;
  }
  .mcard .tag{
    font-size:.6rem;font-weight:600;text-transform:uppercase;
    letter-spacing:.08em;color:#60A5FA;margin-bottom:6px;
    display:block;text-shadow:0 1px 6px rgba(0,0,0,0.8);
  }
  .mcard .ct h3{
    font-family:'Space Grotesk','Plus Jakarta Sans',sans-serif;
    font-size:.95rem;font-weight:600;line-height:1.2;margin-bottom:4px;
    text-shadow:0 1px 8px rgba(0,0,0,0.9);
  }
  .mcard .ct p{font-size:.75rem;color:rgba(255,255,255,0.45);line-height:1.5;font-weight:400;text-shadow:0 1px 6px rgba(0,0,0,0.8)}

  /* ═══════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════ */
  @media(max-width:900px){
    .pcard{flex-direction:column;height:auto}
    .pcard-img{width:100%;height:240px}
    .pcard-text{width:100%;padding:32px !important}
    .pcard:nth-child(even) .pcard-img{order:0}
    .pcard:nth-child(even) .pcard-text{order:1}
    .pcard:nth-child(odd) .pcard-img .fade,
    .pcard:nth-child(even) .pcard-img .fade{
      background:linear-gradient(180deg,transparent 30%,rgba(5,5,7,0.7) 80%,rgba(5,5,7,0.9) 100%);
    }
    .pcard-num{display:none}
    .mcard{flex:0 0 260px;height:180px}
    .stats-grid{grid-template-columns:1fr 1fr}
    .footer-grid{grid-template-columns:1fr 1fr}
    .nav-links{gap:20px}
  }

  /* ═══════════════════════════════════
     STATS SECTION
     ═══════════════════════════════════ */
  .stats-section{
    position:relative;z-index:1;
    padding:100px 32px;
  }
  .stats-grid{
    display:grid;grid-template-columns:repeat(4,1fr);
    gap:32px;max-width:1100px;margin:0 auto;
  }
  .stat-card{
    text-align:center;padding:40px 24px;
    border-radius:20px;
    background:rgba(255,255,255,0.03);
    border:1px solid rgba(255,255,255,0.06);
  }
  .stat-num{
    font-family:'Space Grotesk',sans-serif;
    font-size:clamp(2.2rem,4vw,3.2rem);font-weight:700;
    letter-spacing:-.03em;
    background:linear-gradient(135deg,#60A5FA,#3B82F6);
    -webkit-background-clip:text;-webkit-text-fill-color:transparent;
    background-clip:text;
  }
  .stat-label{
    font-size:.85rem;color:rgba(255,255,255,0.45);
    margin-top:8px;font-weight:500;
  }

  /* ═══════════════════════════════════
     CLOUD / CTA SECTIONS
     ═══════════════════════════════════ */
  .cta-section{
    position:relative;z-index:1;
    max-width:1100px;margin:0 auto;
    padding:100px 32px;
  }
  .cta-grid{
    display:grid;grid-template-columns:1fr 1fr;gap:28px;
  }
  .cta-card{
    padding:48px 40px;border-radius:20px;
    background:linear-gradient(
      165deg,
      rgba(255,255,255,0.14) 0%,
      rgba(255,255,255,0.06) 35%,
      rgba(255,255,255,0.03) 100%
    );
    backdrop-filter:blur(28px) saturate(190%) brightness(1.08);
    -webkit-backdrop-filter:blur(28px) saturate(190%) brightness(1.08);
    border:1px solid transparent;
    box-shadow:
      0 8px 32px rgba(0,0,0,0.45),
      inset 0 1px 0 rgba(255,255,255,0.14),
      inset 0 -1px 0 rgba(255,255,255,0.02);
    position:relative;overflow:hidden;
    transition:box-shadow .5s,transform .3s;
  }
  .cta-card:hover{
    transform:translateY(-2px);
    box-shadow:
      0 12px 48px rgba(0,0,0,0.55),
      inset 0 1px 0 rgba(255,255,255,0.18),
      inset 0 -1px 0 rgba(255,255,255,0.03);
  }
  .cta-card::before{
    content:'';position:absolute;inset:0;border-radius:20px;padding:1px;
    background:linear-gradient(
      135deg,
      rgba(59,130,246,0.22) 0%,
      rgba(59,130,246,0.06) 25%,
      rgba(59,130,246,0.02) 50%,
      rgba(59,130,246,0.06) 75%,
      rgba(59,130,246,0.18) 100%
    );
    -webkit-mask:linear-gradient(#fff 0 0) content-box,linear-gradient(#fff 0 0);
    -webkit-mask-composite:xor;mask-composite:exclude;
    pointer-events:none;z-index:5;
    opacity:.55;transition:opacity .4s;
  }
  .cta-card:hover::before{opacity:1}
  .cta-card>*{position:relative;z-index:2}
  .cta-card h3{
    font-family:'Space Grotesk',sans-serif;
    font-size:1.5rem;font-weight:700;letter-spacing:-.02em;
    margin-bottom:12px;position:relative;z-index:2;
  }
  .cta-card p{
    font-size:.95rem;color:rgba(255,255,255,0.5);
    line-height:1.7;margin-bottom:28px;position:relative;z-index:2;
  }
  .btn{
    display:inline-flex;align-items:center;gap:6px;
    padding:12px 28px;border-radius:999px;
    font-family:'Plus Jakarta Sans',sans-serif;
    font-size:.88rem;font-weight:600;text-decoration:none;
    transition:all .3s;position:relative;z-index:2;
  }
