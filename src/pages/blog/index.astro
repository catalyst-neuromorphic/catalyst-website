---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog — Catalyst Neuromorphic" description="Updates, deep dives, and technical articles from the Catalyst team.">

  <section class="pt-36 pb-20 px-6 md:px-12 text-center">
    <p class="text-sm text-catalyst-blue font-medium tracking-wider uppercase mb-4">Blog</p>
    <h1 class="text-[clamp(3rem,6vw,5rem)] font-bold tracking-tighter">Updates &amp; deep dives.</h1>
    <p class="text-lg text-white/40 mt-4">Technical articles from the Catalyst team.</p>
  </section>

  <section class="pb-32 px-6 md:px-12">
    <div class="max-w-[800px] mx-auto">
      {posts.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-white/30">No posts yet. Check back soon.</p>
        </div>
      ) : (
        <div class="space-y-6 reveal-stagger">
          {posts.map(post => (
            <a href={`/blog/${post.slug}`} class="block glass rounded-xl p-8 no-underline hover:bg-white/[0.06] transition-colors duration-200 group">
              <div class="flex items-center gap-3 mb-3">
                <time class="text-xs text-white/25 font-mono">{post.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}</time>
                {post.data.tags?.map(tag => (
                  <span class="text-[9px] text-catalyst-blue/60 border border-catalyst-blue/20 rounded-full px-2 py-0.5">{tag}</span>
                ))}
              </div>
              <h2 class="text-lg font-semibold group-hover:text-catalyst-blue transition-colors">{post.data.title}</h2>
              <p class="text-sm text-white/40 mt-2">{post.data.description}</p>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

</BaseLayout>
