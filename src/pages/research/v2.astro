---
import BaseLayout from '../../layouts/BaseLayout.astro';
// V2 — DENSE DASHBOARD: Linear-style. Everything visible, tightly organized, no wasted scroll.
---

<BaseLayout title="Research V2 — Dense" description="Dense dashboard research page variant" hasFog={true}>

  <!-- HERO — compact -->
  <section class="pt-32 pb-10 px-6 md:px-12" style="position:relative;z-index:1;">
    <div class="max-w-[1300px] mx-auto flex flex-col md:flex-row md:items-end md:justify-between gap-6">
      <div>
        <p class="text-xs text-catalyst-blue font-medium tracking-wider uppercase mb-3">Research</p>
        <h1 style="font-family:'Space Grotesk',sans-serif; font-size:clamp(2.5rem,5vw,4rem); font-weight:700; letter-spacing:-0.035em; line-height:1;">Verified, not just claimed.</h1>
        <p class="text-base text-white/35 mt-3 max-w-[450px]">Two processor generations. Real FPGA hardware. Every result reproducible.</p>
      </div>
      <div class="flex gap-3">
        <a href="/papers/catalyst-n2.pdf" class="btn-pill text-sm" target="_blank">N2 Paper</a>
        <a href="/papers/catalyst-n1.pdf" class="btn-pill text-sm" target="_blank">N1 Paper</a>
      </div>
    </div>
  </section>

  <!-- MEGA STAT STRIP — big numbers, tight -->
  <section class="py-8 px-6 md:px-12">
    <div class="max-w-[1300px] mx-auto">
      <div class="reveal grid grid-cols-4 lg:grid-cols-8 gap-px bg-white/[0.04] rounded-2xl overflow-hidden">
        {[
          { val: '128', label: 'Cores' },
          { val: '131K', label: 'Neurons' },
          { val: '5', label: 'Models' },
          { val: '28/28', label: 'FPGA' },
          { val: '3,091', label: 'Tests' },
          { val: '85.9%', label: 'SHD' },
          { val: '152', label: 'Parity' },
          { val: '2', label: 'Papers' },
        ].map(item => (
          <div class="bg-surface px-3 py-4 text-center">
            <div style="font-family:'Space Grotesk',sans-serif; font-size:1.4rem; font-weight:700; letter-spacing:-0.03em;" class="text-white/90">{item.val}</div>
            <div class="text-[9px] text-white/30 uppercase tracking-wider mt-1">{item.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TWO-COLUMN: Papers + Validation side by side -->
  <section class="py-12 px-6 md:px-12">
    <div class="max-w-[1300px] mx-auto grid grid-cols-1 lg:grid-cols-5 gap-6">

      <!-- LEFT: Papers (2 cols) -->
      <div class="lg:col-span-2 space-y-4">
        <h3 class="text-xs text-white/30 uppercase tracking-widest mb-2">Papers</h3>
        {[
          { gen: 'N2', title: 'Full Loihi 2 Parity', pages: 18, doi: '10.5281/zenodo.18728256', doiUrl: 'https://zenodo.org/records/18728256', pdfUrl: '/papers/catalyst-n2.pdf', latest: true },
          { gen: 'N1', title: 'A 131K-Neuron Processor', pages: 13, doi: '10.5281/zenodo.18727094', doiUrl: 'https://zenodo.org/records/18727094', pdfUrl: '/papers/catalyst-n1.pdf', latest: false },
        ].map(p => (
          <div class="card-glass p-5">
            <div class="flex items-center gap-2 mb-2">
              <span class={`text-[9px] uppercase tracking-widest px-2 py-0.5 rounded-full ${p.latest ? 'text-catalyst-blue/60 bg-catalyst-blue/10' : 'text-white/20 bg-white/5'}`}>{p.gen}</span>
              <span class="text-[10px] text-white/20">{p.pages}pp</span>
            </div>
            <h4 class="text-sm font-semibold">{p.title}</h4>
            <div class="flex items-center gap-2 mt-3">
              <a href={p.doiUrl} target="_blank" rel="noopener noreferrer"><img src={`https://zenodo.org/badge/DOI/${p.doi}.svg`} alt="DOI" style="display:inline-block; height:18px;" /></a>
            </div>
            <div class="flex gap-2 mt-3">
              <a href={p.pdfUrl} class="text-xs text-catalyst-blue hover:underline" target="_blank">PDF</a>
              <span class="text-white/10">|</span>
              <a href={p.doiUrl} class="text-xs text-catalyst-blue hover:underline" target="_blank" rel="noopener noreferrer">Zenodo</a>
            </div>
          </div>
        ))}
      </div>

      <!-- RIGHT: FPGA Validation (3 cols) -->
      <div class="lg:col-span-3">
        <div class="flex items-center justify-between mb-2">
          <h3 class="text-xs text-white/30 uppercase tracking-widest">FPGA Validation</h3>
          <span class="text-xs font-mono text-catalyst-green font-bold">28/28 PASS</span>
        </div>
        <div class="card-glass p-6">
          <!-- Platform badge -->
          <div class="flex items-center gap-2 mb-5">
            <span class="text-[9px] bg-white/5 text-white/40 px-2 py-0.5 rounded-full">AWS F2</span>
            <span class="text-[9px] bg-white/5 text-white/40 px-2 py-0.5 rounded-full">Xilinx UltraScale+ VU47P</span>
            <span class="text-[9px] bg-white/5 text-white/40 px-2 py-0.5 rounded-full">Bit-exact</span>
          </div>
          <!-- Categories grid -->
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            {[
              { name: 'Neuron', n: 7 },
              { name: 'Synapse', n: 6 },
              { name: 'CUBA', n: 1 },
              { name: 'Topology', n: 3 },
              { name: 'Routing', n: 3 },
              { name: 'Scale', n: 5 },
              { name: 'Operational', n: 3 },
            ].map(c => (
              <div class="bg-white/[0.03] rounded-lg px-3 py-2.5 flex items-center justify-between">
                <span class="text-xs text-white/50">{c.name}</span>
                <span class="text-xs font-mono text-catalyst-green">{c.n}/{c.n}</span>
              </div>
            ))}
            <div class="bg-catalyst-blue/[0.04] border border-catalyst-blue/[0.08] rounded-lg px-3 py-2.5">
              <span class="text-[9px] text-catalyst-blue/60 uppercase tracking-wider">Discovery</span>
              <p class="text-[10px] text-white/25 mt-0.5">BRAM init → silence protocol</p>
            </div>
          </div>
          <!-- Protocol strip -->
          <div class="mt-5 pt-4 border-t border-white/[0.04]">
            <div class="text-[9px] text-white/25 uppercase tracking-wider mb-2">7-step protocol</div>
            <div class="flex gap-1.5">
              {['Define', 'Compile', 'Silence', 'Deploy', 'Inject', 'Read', 'Compare'].map((s, i) => (
                <div class="flex-1 bg-white/[0.03] rounded-md py-1.5 text-center">
                  <div class="text-[9px] text-catalyst-blue/40 font-mono">{i + 1}</div>
                  <div class="text-[10px] text-white/50">{s}</div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- THREE-COLUMN: Benchmark + Parity + SDK -->
  <section class="py-12 px-6 md:px-12" style="background:rgba(255,255,255,0.008); border-top:1px solid rgba(255,255,255,0.03); border-bottom:1px solid rgba(255,255,255,0.03);">
    <div class="max-w-[1300px] mx-auto grid grid-cols-1 lg:grid-cols-3 gap-6">

      <!-- Benchmark -->
      <div class="card-glass p-6">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-xs text-white/30 uppercase tracking-widest">SHD Benchmark</h3>
        </div>
        <div class="flex items-baseline gap-2 mb-1">
          <span style="font-family:'Space Grotesk',sans-serif; font-size:2.5rem; font-weight:700; letter-spacing:-0.03em;">85.9</span>
          <span class="text-white/30 text-sm">% float</span>
        </div>
        <div class="flex items-baseline gap-2 mb-5">
          <span style="font-family:'Space Grotesk',sans-serif; font-size:1.5rem; font-weight:700; letter-spacing:-0.03em; color:rgba(255,255,255,0.5);">85.4</span>
          <span class="text-white/20 text-xs">% 8-bit quantized</span>
        </div>
        <!-- Normalized bars 80-90 range -->
        <div class="space-y-3">
          {[
            { name: 'Catalyst N2', score: 85.9, ours: true },
            { name: 'Catalyst N2 (8b)', score: 85.4, ours: true },
            { name: 'Zenke & Vogels', score: 83.4, ours: false },
            { name: 'Cramer et al.', score: 83.2, ours: false },
          ].map(item => (
            <div>
              <div class="flex justify-between text-[10px] mb-1">
                <span class={item.ours ? 'text-white/60' : 'text-white/25'}>{item.name}</span>
                <span class="font-mono text-white/30">{item.score}%</span>
              </div>
              <div class="h-1.5 rounded-full bg-white/[0.04] overflow-hidden">
                <div class={`h-full rounded-full ${item.ours ? 'bg-catalyst-blue' : 'bg-white/10'}`} style={`width:${((item.score - 80) / 10) * 100}%`}></div>
              </div>
            </div>
          ))}
        </div>
        <p class="text-[9px] text-white/15 mt-3">Recurrent LIF networks. Bars: 80-90% range.</p>
      </div>

      <!-- Parity -->
      <div class="card-glass p-6">
        <h3 class="text-xs text-white/30 uppercase tracking-widest mb-4">Loihi 2 Parity</h3>
        <div class="text-center py-4">
          <div class="flex items-center justify-center gap-8">
            <div>
              <div style="font-family:'Space Grotesk',sans-serif; font-size:2.5rem; font-weight:700; color:rgb(34,197,94);">152</div>
              <div class="text-[10px] text-white/30 mt-1">Full</div>
            </div>
            <div>
              <div style="font-family:'Space Grotesk',sans-serif; font-size:2.5rem; font-weight:700; color:rgb(96,165,250);">3</div>
              <div class="text-[10px] text-white/30 mt-1">HW-only</div>
            </div>
            <div>
              <div style="font-family:'Space Grotesk',sans-serif; font-size:2.5rem; font-weight:700; color:rgba(255,255,255,0.1);">0</div>
              <div class="text-[10px] text-white/30 mt-1">Missing</div>
            </div>
          </div>
        </div>
        <div class="mt-4 pt-4 border-t border-white/[0.04] space-y-3">
          {[
            { part: '1', title: 'Pipeline ordering', desc: '10 stages in Loihi 2 order' },
            { part: '2', title: 'Feature coverage', desc: '155 features mapped' },
            { part: '3', title: 'Numerical accuracy', desc: 'CPU exact, FPGA bit-exact' },
          ].map(a => (
            <div class="flex gap-3">
              <span class="text-[9px] text-catalyst-blue/40 font-mono shrink-0 w-4">{a.part}</span>
              <div>
                <div class="text-xs font-medium text-white/60">{a.title}</div>
                <div class="text-[10px] text-white/20">{a.desc}</div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- SDK -->
      <div class="card-glass p-6">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-xs text-white/30 uppercase tracking-widest">SDK Tests</h3>
          <span class="text-xs text-white/20">v3.7.0</span>
        </div>
        <div class="flex items-baseline gap-3 mb-5">
          <span style="font-family:'Space Grotesk',sans-serif; font-size:2.5rem; font-weight:700; letter-spacing:-0.03em;">3,091</span>
          <span class="text-xs text-white/20">from 168 (18.4x)</span>
        </div>
        <div class="space-y-2">
          {[
            { label: 'Unit', n: '~1,200', pct: 39 },
            { label: 'Integration', n: '~800', pct: 26 },
            { label: 'Regression', n: '~500', pct: 16 },
            { label: 'CPU-GPU', n: '~400', pct: 13 },
            { label: 'Stress', n: '~100', pct: 3 },
          ].map(t => (
            <div class="flex items-center gap-3">
              <span class="text-[10px] text-white/40 w-16 shrink-0">{t.label}</span>
              <div class="flex-1 h-1.5 rounded-full bg-white/[0.04] overflow-hidden">
                <div class="h-full rounded-full bg-catalyst-blue/50" style={`width:${t.pct * 2.5}%`}></div>
              </div>
              <span class="text-[10px] text-white/25 font-mono w-12 text-right">{t.n}</span>
            </div>
          ))}
        </div>
        <div class="mt-5 pt-4 border-t border-white/[0.04]">
          <div class="grid grid-cols-3 gap-3">
            {['CPU', 'GPU', 'FPGA'].map(b => (
              <div class="bg-white/[0.03] rounded-lg px-2 py-2 text-center">
                <div class="text-xs font-semibold text-white/60">{b}</div>
                <div class="text-[9px] text-white/20 mt-0.5">{b === 'CPU' ? 'Reference' : b === 'GPU' ? 'CUDA' : 'PCIe'}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- N1 → N2 TABLE — full width -->
  <section class="py-12 px-6 md:px-12">
    <div class="max-w-[1300px] mx-auto">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-xs text-white/30 uppercase tracking-widest">N1 &rarr; N2 Evolution</h3>
      </div>
      <div class="reveal card-glass p-5 overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/10">
              <th class="text-left py-2 pr-6 text-white/30 font-medium text-xs">Spec</th>
              <th class="text-left py-2 px-6 text-white/15 font-medium text-xs">N1</th>
              <th class="text-left py-2 pl-6 text-catalyst-blue font-semibold text-xs">N2</th>
            </tr>
          </thead>
          <tbody class="text-xs">
            {[
              ['Models', '1 (CUBA LIF)', '5 — CUBA, Izh, ALIF, \u03A3\u0394, R&F'],
              ['Engine', 'Fixed datapath', 'Programmable microcode'],
              ['Spikes', 'Binary', 'Binary + 8/16/24-bit graded'],
              ['Weights', '8-bit fixed', '1/2/4/8/16-bit variable'],
              ['Traces', '2', '5'],
              ['Learning', 'STDP + reward', '3-factor + homeostatic + persistent reward'],
              ['Observability', 'State read', '25 probes, perf counters, DVFS'],
              ['Tests', '168', '3,091 (18.4\u00D7)'],
              ['FPGA', '16-core subset', '28/28, 7 categories, full protocol'],
            ].map(([spec, n1, n2]) => (
              <tr class="border-b border-white/[0.03]">
                <td class="py-2 pr-6 text-white/40">{spec}</td>
                <td class="py-2 px-6 text-white/15">{n1}</td>
                <td class="py-2 pl-6 text-white/60">{n2}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- LICENSING + CTA row -->
  <section class="py-12 px-6 md:px-12">
    <div class="max-w-[1300px] mx-auto flex flex-col lg:flex-row gap-6">
      <div class="flex-1 grid grid-cols-4 gap-3">
        {[
          { l: 'Papers', v: 'Open access' },
          { l: 'SDK', v: 'BSL 1.1' },
          { l: 'RTL', v: 'Patent pending' },
          { l: 'API', v: 'MIT' },
        ].map(item => (
          <div class="bg-white/[0.03] border border-white/[0.04] rounded-lg px-3 py-2.5 text-center">
            <div class="text-[9px] text-white/20 uppercase tracking-wider">{item.l}</div>
            <div class="text-xs font-semibold text-white/60 mt-0.5">{item.v}</div>
          </div>
        ))}
      </div>
      <div class="flex gap-3 items-center">
        <a href="/cloud" class="btn-pill text-sm">Try Cloud API &rarr;</a>
      </div>
    </div>
  </section>

</BaseLayout>
