---
import BaseLayout from '../../layouts/BaseLayout.astro';
// V6 — FUSION: V4 trust-first narrative + V2 charts + Original wide layout + Homepage design language
---

<BaseLayout title="Research — Catalyst Neuromorphic" description="Two generations of neuromorphic processors. Loihi 2 parity. Validated on real FPGA hardware. Two published papers." hasFog={true}>

  <!-- HERO -->
  <section class="pt-36 pb-12 px-6 md:px-12" style="position:relative;z-index:1;">
    <div class="max-w-[1200px] mx-auto text-center">
      <p class="text-sm text-catalyst-blue font-medium tracking-wider uppercase mb-5">Research</p>
      <h1 style="font-family:'Space Grotesk',sans-serif; font-size:clamp(2.8rem,6vw,4.8rem); font-weight:700; letter-spacing:-0.04em; line-height:0.95;">
        The data behind<br/>the claims.
      </h1>
      <p class="text-lg text-white/35 mt-5 max-w-[540px] mx-auto">Two processor generations. Two published papers. Real FPGA hardware. Every result reproducible.</p>
      <div class="flex flex-wrap gap-2 justify-center mt-8">
        <span class="text-[10px] bg-catalyst-green/10 text-catalyst-green/70 px-3 py-1.5 rounded-full border border-catalyst-green/10">28/28 FPGA tests</span>
        <span class="text-[10px] bg-catalyst-blue/10 text-catalyst-blue/60 px-3 py-1.5 rounded-full border border-catalyst-blue/10">85.9% SHD accuracy</span>
        <span class="text-[10px] bg-white/5 text-white/40 px-3 py-1.5 rounded-full border border-white/5">Loihi 2 parity — 152/155</span>
        <span class="text-[10px] bg-white/5 text-white/40 px-3 py-1.5 rounded-full border border-white/5">3,091 SDK tests</span>
        <span class="text-[10px] bg-white/5 text-white/40 px-3 py-1.5 rounded-full border border-white/5">2 papers on Zenodo</span>
      </div>
    </div>
  </section>

  <!-- AT A GLANCE — stat cards with gradient numbers (homepage .stat-card style) -->
  <section class="pb-28 px-6 md:px-12" style="position:relative;z-index:1;">
    <div class="max-w-[1200px] mx-auto">
      <div class="grid grid-cols-4 lg:grid-cols-8 gap-4" id="stat-bar">
        {[
          { val: 128, label: 'Cores', sub: 'per chip', suffix: '' },
          { val: 131, label: 'Neurons', sub: 'per chip', suffix: 'K', decimal: false },
          { val: 5, label: 'Neuron models', sub: 'programmable', suffix: '' },
          { val: 28, label: 'FPGA tests', sub: '0 failures', suffix: '/28' },
          { val: 3091, label: 'SDK tests', sub: 'v3.7.0', suffix: '' },
          { val: 859, label: 'SHD accuracy', sub: 'float', suffix: '%', decimal: true },
          { val: 152, label: 'Loihi 2 parity', sub: 'of 155', suffix: '/155' },
          { val: 2, label: 'Papers', sub: 'open access', suffix: '' },
        ].map(item => (
          <div class="r-stat-card">
            <div
              class="stat-counter r-stat-num"
              data-target={item.val}
              data-suffix={item.suffix}
              data-decimal={item.decimal ? 'true' : 'false'}
            >0</div>
            <div class="text-[9px] text-white/40 uppercase tracking-wider mt-1.5">{item.label}</div>
            <div class="text-[9px] text-white/20 mt-0.5">{item.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PAPERS — glass cards with key findings -->
  <section class="pb-32 px-6 md:px-12" style="position:relative;z-index:1;">
    <div class="max-w-[1200px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-7 reveal-stagger">
      {[
        {
          gen: 'N2', tag: 'Latest', tagBg: 'bg-catalyst-blue/10 text-catalyst-blue/60 border-catalyst-blue/10',
          title: 'Full Loihi 2 Parity in an Open Neuromorphic Architecture',
          highlights: ['5 neuron models with programmable microcode', '28/28 FPGA validation across 7 categories', '155-feature parity audit (152 full, 3 HW-only)', 'SHD 85.9% float / 85.4% quantized'],
          pages: 18, doi: '10.5281/zenodo.18728256', doiUrl: 'https://zenodo.org/records/18728256', pdf: '/papers/catalyst-n2.pdf',
        },
        {
          gen: 'N1', tag: 'First gen', tagBg: 'bg-white/5 text-white/30 border-white/5',
          title: 'A 131K-Neuron Open Neuromorphic Processor with Programmable Synaptic Plasticity',
          highlights: ['128-core architecture, 1,024 neurons/core', '25 RTL testbenches, 98 scenarios, 0 failures', 'Triple RV32IMF RISC-V embedded cluster', '16-core FPGA validation on VU47P'],
          pages: 13, doi: '10.5281/zenodo.18727094', doiUrl: 'https://zenodo.org/records/18727094', pdf: '/papers/catalyst-n1.pdf',
        },
      ].map(p => (
        <div class="card-glass p-8 md:p-10 flex flex-col">
          <div class="flex items-center gap-3 mb-4" style="position:relative;z-index:2;">
            <span class={`text-[9px] uppercase tracking-widest px-2.5 py-1 rounded-full border ${p.tagBg}`}>{p.tag}</span>
            <span class="text-xs text-white/25">{p.pages} pages</span>
          </div>
          <h3 class="text-xl font-semibold mb-1" style="position:relative;z-index:2;">{p.gen}</h3>
          <p class="text-sm text-white/45 leading-relaxed mb-4" style="position:relative;z-index:2;">{p.title}</p>
          <div class="space-y-1.5 mb-5 flex-1" style="position:relative;z-index:2;">
            {p.highlights.map(h => (
              <div class="flex items-start gap-2 text-xs">
                <span class="text-catalyst-blue/40 mt-0.5 shrink-0">&#9656;</span>
                <span class="text-white/45">{h}</span>
              </div>
            ))}
          </div>
          <div class="flex items-center gap-3 mb-4" style="position:relative;z-index:2;">
            <a href={p.doiUrl} target="_blank" rel="noopener noreferrer"><img src={`https://zenodo.org/badge/DOI/${p.doi}.svg`} alt="DOI" style="display:inline-block; height:18px;" /></a>
          </div>
          <div class="flex gap-3" style="position:relative;z-index:2;">
            <a href={p.pdf} class="r-btn r-btn-blue" target="_blank">Read PDF</a>
            <a href={p.doiUrl} class="r-btn r-btn-ghost" target="_blank" rel="noopener noreferrer">Zenodo</a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- gradient divider -->
  <div class="r-divider"></div>

  <!-- FPGA VALIDATION -->
  <section class="py-32 px-6 md:px-12" style="position:relative;z-index:1;">
    <div class="max-w-[1200px] mx-auto">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-14">
        <div>
          <h2 class="reveal text-[clamp(2rem,3.5vw,3rem)] font-bold tracking-tight">FPGA validation</h2>
          <p class="reveal text-white/35 mt-2 max-w-[550px]">N2 validated on Xilinx UltraScale+ VU47P (AWS F2). Cycle-accurate. Bit-exact against CPU simulator.</p>
        </div>
        <div class="reveal text-right">
          <div class="stat-counter" style="font-family:'Space Grotesk',sans-serif; font-size:clamp(2.5rem,5vw,3.5rem); font-weight:700; letter-spacing:-0.03em; background:linear-gradient(135deg,rgb(34,197,94),rgb(74,222,128)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;" data-target="28" data-suffix="/28" data-decimal="false">0</div>
          <div class="text-xs text-white/30 mt-1">All categories &mdash; 0 failures</div>
        </div>
      </div>

      <!-- 7-step protocol — glass panel -->
      <div class="reveal mb-10">
        <div class="flex items-center gap-2 mb-5">
          <h3 class="text-sm font-semibold text-white/60">7-step validation protocol</h3>
          <span class="text-xs text-white/20">&mdash; every test, every time</span>
        </div>
        <div class="card-glass p-2">
          <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-7 gap-2" style="position:relative;z-index:2;">
            {[
              { n: '1', title: 'Define', desc: 'Python SDK network' },
              { n: '2', title: 'Compile', desc: 'Hardware bitstream' },
              { n: '3', title: 'Silence', desc: '\u03B8=32767 stale cores' },
              { n: '4', title: 'Deploy', desc: 'PCIe MMIO write' },
              { n: '5', title: 'Inject', desc: 'Spike stimuli' },
              { n: '6', title: 'Readback', desc: 'PCIe capture' },
              { n: '7', title: 'Compare', desc: 'Bit-exact vs CPU' },
            ].map(item => (
              <div class="r-protocol-step">
                <div class="text-catalyst-blue/50 text-[10px] font-mono">{item.n}</div>
                <div class="text-sm font-semibold mt-1">{item.title}</div>
                <div class="text-[10px] text-white/25 mt-1 leading-snug">{item.desc}</div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Test categories — card-glass -->
      <div class="reveal grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        {[
          { name: 'Basic Neuron', count: 7, desc: 'Membrane potential, threshold, reset, refractory period' },
          { name: 'Synaptic', count: 6, desc: 'Excitatory, inhibitory, variable-precision weights' },
          { name: 'CUBA Dynamics', count: 1, desc: 'Matches analytical solution — decay, integration, overflow' },
          { name: 'Network Topology', count: 3, desc: 'Feed-forward, recurrent loops, fan-out patterns' },
          { name: 'Multi-Core Routing', count: 3, desc: 'Cross-core mesh delivery with axonal delays' },
          { name: 'Scale & Performance', count: 5, desc: '81K spikes/3.4ms — 163K cross-core microcode spikes' },
          { name: 'Operational', count: 3, desc: 'BRAM init, state isolation, deployment sequencing' },
        ].map(cat => (
          <div class="card-glass p-5">
            <div class="flex items-center justify-between mb-2" style="position:relative;z-index:2;">
              <span class="text-xs font-mono text-catalyst-green font-bold">{cat.count}/{cat.count} &#10003;</span>
            </div>
            <div class="text-sm font-semibold text-white/80 mb-1" style="position:relative;z-index:2;">{cat.name}</div>
            <div class="text-xs text-white/25 leading-relaxed" style="position:relative;z-index:2;">{cat.desc}</div>
          </div>
        ))}
        <!-- Discovery callout -->
        <div class="card-glass p-5" style="border-color:transparent;">
          <div class="text-[10px] uppercase tracking-widest text-catalyst-blue/50 mb-2" style="position:relative;z-index:2;">Discovery</div>
          <div class="text-sm font-semibold text-white/80 mb-1" style="position:relative;z-index:2;">BRAM initialization</div>
          <div class="text-xs text-white/25 leading-relaxed" style="position:relative;z-index:2;">FPGAs init BRAM to zeros. &theta;=0 fires every neuron every timestep. Led to the silence protocol (Step 3).</div>
        </div>
      </div>

      <!-- Platform badges -->
      <div class="reveal flex items-center gap-2 mt-6">
        <span class="text-[9px] bg-white/5 text-white/40 px-2.5 py-1 rounded-full">AWS F2</span>
        <span class="text-[9px] bg-white/5 text-white/40 px-2.5 py-1 rounded-full">Xilinx UltraScale+ VU47P</span>
        <span class="text-[9px] bg-white/5 text-white/40 px-2.5 py-1 rounded-full">PCIe MMIO</span>
        <span class="text-[9px] bg-white/5 text-white/40 px-2.5 py-1 rounded-full">Bit-exact</span>
      </div>
    </div>
  </section>

  <!-- gradient divider -->
  <div class="r-divider"></div>

  <!-- SHD BENCHMARK -->
  <section class="py-32 px-6 md:px-12" style="position:relative;z-index:1;">
    <div class="max-w-[1200px] mx-auto">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-14">
        <div>
          <h2 class="reveal text-[clamp(2rem,3.5vw,3rem)] font-bold tracking-tight">SHD benchmark</h2>
          <p class="reveal text-white/35 mt-2 max-w-[500px]">Spiking Heidelberg Digits — spoken digit classification with spike-encoded audio. Standard SNN benchmark.</p>
        </div>
      </div>

      <div class="reveal grid grid-cols-1 lg:grid-cols-3 gap-7">
        <!-- Left: big numbers + methodology -->
        <div class="card-glass p-8 flex flex-col justify-between">
          <div style="position:relative;z-index:2;">
            <div class="mb-6">
              <div class="stat-counter r-big-num" style="font-family:'Space Grotesk',sans-serif; font-size:3.5rem; font-weight:700; letter-spacing:-0.03em; line-height:1; background:linear-gradient(135deg,#60A5FA,#3B82F6); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;" data-target="859" data-suffix="%" data-decimal="true">0</div>
              <div class="text-xs text-white/40 mt-1">Floating-point</div>
            </div>
            <div class="mb-6">
              <div style="font-family:'Space Grotesk',sans-serif; font-size:2.2rem; font-weight:700; letter-spacing:-0.03em; line-height:1; color:rgba(255,255,255,0.5);">85.4<span class="text-base text-white/20">%</span></div>
              <div class="text-xs text-white/30 mt-1">8-bit quantized</div>
              <div class="text-[10px] text-white/15 mt-0.5">0.5% loss from integer quantization</div>
            </div>
          </div>
          <div class="pt-4 border-t border-white/[0.06] space-y-2" style="position:relative;z-index:2;">
            <div class="text-[9px] text-white/25 uppercase tracking-wider mb-2">Methodology</div>
            <div><span class="text-[10px] text-white/45 font-medium">Split:</span> <span class="text-[10px] text-white/25">70/10/20 train/val/test</span></div>
            <div><span class="text-[10px] text-white/45 font-medium">Network:</span> <span class="text-[10px] text-white/25">Recurrent LIF</span></div>
            <div><span class="text-[10px] text-white/45 font-medium">Augmentation:</span> <span class="text-[10px] text-white/25">None at test time</span></div>
          </div>
        </div>

        <!-- Right: comparison bars -->
        <div class="card-glass p-8 lg:col-span-2">
          <h3 class="text-sm font-semibold text-white/50 mb-6" style="position:relative;z-index:2;">vs. published recurrent LIF baselines</h3>
          <div class="space-y-5" style="position:relative;z-index:2;">
            {[
              { name: 'Catalyst N2', sub: 'float', score: 85.9, color: 'bg-catalyst-blue', ours: true },
              { name: 'Catalyst N2', sub: '8-bit quantized', score: 85.4, color: 'bg-catalyst-green', ours: true },
              { name: 'Zenke & Vogels', sub: '2021', score: 83.4, color: 'bg-white/15', ours: false },
              { name: 'Cramer et al.', sub: '2022', score: 83.2, color: 'bg-white/15', ours: false },
            ].map(item => (
              <div class="flex items-center gap-4">
                <div class="w-36 shrink-0">
                  <div class={`text-sm ${item.ours ? 'font-semibold text-white/80' : 'text-white/40'}`}>{item.name}</div>
                  <div class="text-[10px] text-white/20">{item.sub}</div>
                </div>
                <div class="flex-1 h-3 rounded-full bg-white/[0.06] overflow-hidden">
                  <div class={`h-full rounded-full anim-bar ${item.color}`} data-width={`${((item.score - 80) / 10) * 100}%`} style="width:0%"></div>
                </div>
                <div class={`text-sm font-mono w-14 text-right ${item.ours ? 'text-white/80' : 'text-white/30'}`}>{item.score}%</div>
              </div>
            ))}
          </div>
          <p class="text-[10px] text-white/15 mt-5" style="position:relative;z-index:2;">Bars normalized to 80–90% range. Comparison limited to recurrent LIF networks.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- gradient divider -->
  <div class="r-divider"></div>

  <!-- PARITY AUDIT -->
  <section class="py-32 px-6 md:px-12" style="position:relative;z-index:1;">
    <div class="max-w-[1200px] mx-auto">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-14">
        <div>
          <h2 class="reveal text-[clamp(2rem,3.5vw,3rem)] font-bold tracking-tight">Loihi 2 parity</h2>
          <p class="reveal text-white/35 mt-2 max-w-[550px]">We mapped every documented capability of Intel's Loihi 2 architecture and implemented each one. Three-part verification process.</p>
        </div>
        <div class="reveal text-right">
          <div class="stat-counter" style="font-family:'Space Grotesk',sans-serif; font-size:clamp(2.5rem,5vw,3.5rem); font-weight:700; letter-spacing:-0.03em; background:linear-gradient(135deg,#60A5FA,#3B82F6); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;" data-target="152" data-suffix="/155" data-decimal="false">0</div>
          <div class="text-xs text-white/30 mt-1">features matched</div>
        </div>
      </div>

      <!-- Parity summary — single glass card, not three separate ones -->
      <div class="reveal card-glass p-8 md:p-10 mb-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8" style="position:relative;z-index:2;">
          <div>
            <div style="font-family:'Space Grotesk',sans-serif; font-size:2.5rem; font-weight:700; letter-spacing:-0.03em; background:linear-gradient(135deg,rgb(34,197,94),rgb(74,222,128)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;">152</div>
            <div class="text-sm text-white/55 mt-1">Matching Loihi 2</div>
            <div class="text-xs text-white/25 mt-1">Neuron models, synapse types, learning rules, spike formats, routing, observability — all matched</div>
          </div>
          <div>
            <div style="font-family:'Space Grotesk',sans-serif; font-size:2.5rem; font-weight:700; letter-spacing:-0.03em; color:rgba(255,255,255,0.25);">3</div>
            <div class="text-sm text-white/55 mt-1">Need fabricated silicon</div>
            <div class="text-xs text-white/25 mt-1">Multi-chip serial I/O — these require physical pins that only exist on a manufactured chip, not on FPGA prototypes</div>
          </div>
          <div>
            <div style="font-family:'Space Grotesk',sans-serif; font-size:2.5rem; font-weight:700; letter-spacing:-0.03em; color:rgba(255,255,255,0.25);">0</div>
            <div class="text-sm text-white/55 mt-1">Omitted</div>
            <div class="text-xs text-white/25 mt-1">Every feature that can be implemented on an FPGA prototype has been implemented. Nothing is deferred or planned.</div>
          </div>
        </div>
      </div>

      <!-- Three-part audit — glass cards -->
      <div class="reveal grid grid-cols-1 md:grid-cols-3 gap-5">
        {[
          { part: '1', title: 'Pipeline ordering', desc: 'Our 10-stage processing pipeline executes in the same order as Loihi 2 — from synapse input through to spike output.' },
          { part: '2', title: 'Feature-by-feature audit', desc: 'Every feature in Intel\u2019s documentation was mapped to our implementation. 155 features, each individually verified.' },
          { part: '3', title: 'Numerical equivalence', desc: 'Our CPU simulator is exact. Our FPGA produces bit-identical results. Our GPU is statistically equivalent.' },
        ].map(item => (
          <div class="card-glass p-6">
            <div class="text-[10px] text-catalyst-blue/60 font-mono mb-2" style="position:relative;z-index:2;">Part {item.part}</div>
            <div class="text-sm font-semibold text-white/75 mb-2" style="position:relative;z-index:2;">{item.title}</div>
            <div class="text-xs text-white/30 leading-relaxed" style="position:relative;z-index:2;">{item.desc}</div>
          </div>
        ))}
      </div>

      <div class="reveal mt-5 text-xs text-white/20">Full methodology: N2 Paper, Section 5</div>
    </div>
  </section>

  <!-- gradient divider -->
  <div class="r-divider"></div>

  <!-- SDK TESTING -->
  <section class="py-32 px-6 md:px-12" style="position:relative;z-index:1;">
    <div class="max-w-[1200px] mx-auto">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-14">
        <div>
          <h2 class="reveal text-[clamp(2rem,3.5vw,3rem)] font-bold tracking-tight">Software verification</h2>
          <p class="reveal text-white/35 mt-2 max-w-[500px]">The neurocore SDK mirrors the hardware specification. Software simulator produces bit-identical results to the FPGA.</p>
        </div>
        <div class="reveal text-right">
          <div class="flex items-baseline gap-3 justify-end">
            <span class="text-white/15 font-mono text-lg line-through">168</span>
            <span class="stat-counter" style="font-family:'Space Grotesk',sans-serif; font-size:2.5rem; font-weight:700; letter-spacing:-0.03em; background:linear-gradient(135deg,#60A5FA,#3B82F6); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;" data-target="3091" data-suffix="" data-decimal="false">0</span>
          </div>
          <div class="text-xs text-white/25 mt-1">18.4&times; growth &mdash; v3.7.0</div>
        </div>
      </div>

      <!-- What we test — describe the approach, not just counts -->
      <div class="reveal grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-8">
        {[
          { title: 'Every component in isolation', desc: 'Each neuron model, synapse type, and learning rule has its own test suite. If a single parameter drifts, we catch it before it propagates.' },
          { title: 'Full network builds', desc: 'We assemble complete networks — multi-core routing, fan-out patterns, recurrent loops — and verify the output matches the mathematical specification.' },
          { title: 'Three backends, one answer', desc: 'The same network runs on CPU, GPU (CUDA), and FPGA. All three must produce identical results. The CPU is the reference; the others prove correctness.' },
          { title: 'Every bug fix is permanent', desc: 'When we find and fix a bug, the failing case becomes a permanent test. The suite only grows. Nothing breaks twice.' },
          { title: 'Scale and stress', desc: 'We push the simulator to its limits — maximum neuron counts, memory pressure, pathological topologies — to find failures that only appear at scale.' },
          { title: 'Bit-exact FPGA verification', desc: 'The FPGA output is compared bit-for-bit against the CPU simulator. Not approximately equal. Not statistically equivalent. Identical.' },
        ].map(item => (
          <div class="card-glass p-6">
            <div class="text-sm font-semibold text-white/80 mb-2" style="position:relative;z-index:2;">{item.title}</div>
            <div class="text-xs text-white/30 leading-relaxed" style="position:relative;z-index:2;">{item.desc}</div>
          </div>
        ))}
      </div>

      <!-- Backends — glass cards -->
      <div class="reveal grid grid-cols-1 md:grid-cols-3 gap-5">
        {[
          { name: 'CPU', desc: 'Reference implementation. Exact results. Ground truth for all comparisons.' },
          { name: 'GPU', desc: 'CUDA backend. Statistically equivalent — floating-point reordering only.' },
          { name: 'FPGA', desc: 'PCIe MMIO driver. Bit-exact match against CPU simulator.' },
        ].map(item => (
          <div class="card-glass p-5">
            <div class="text-sm font-semibold text-white/75" style="position:relative;z-index:2;">{item.name}</div>
            <div class="text-xs text-white/30 mt-1 leading-relaxed" style="position:relative;z-index:2;">{item.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- gradient divider -->
  <div class="r-divider"></div>

  <!-- N1 → N2 EVOLUTION TABLE -->
  <section class="py-32 px-6 md:px-12" style="position:relative;z-index:1;">
    <div class="max-w-[1200px] mx-auto">
      <h2 class="reveal text-[clamp(2rem,3.5vw,3rem)] font-bold tracking-tight mb-12">N1 &rarr; N2</h2>
      <div class="reveal overflow-x-auto card-glass p-6 md:p-8">
        <table class="w-full text-sm" style="position:relative;z-index:2;">
          <thead>
