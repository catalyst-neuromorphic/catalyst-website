---
const columns = [
  {
    title: 'Products',
    links: [
      { href: '/processors/n2', label: 'N2 Processor' },
      { href: '/processors/n1', label: 'N1 Processor' },
      { href: '/cloud', label: 'Catalyst Cloud' },
      { href: '/cloud/pricing', label: 'Pricing' },
    ],
  },
  {
    title: 'Research',
    links: [
      { href: '/research', label: 'Papers' },
      { href: '/research#benchmarks', label: 'Benchmarks' },
      { href: '/cloud/docs', label: 'API Docs' },
    ],
  },
  {
    title: 'Company',
    links: [
      { href: '/about', label: 'About' },
      { href: '/technology', label: 'Technology' },
      { href: 'mailto:henry@catalyst-neuromorphic.com', label: 'Contact' },
    ],
  },
  {
    title: 'Connect',
    links: [
      { href: 'https://github.com/catalyst-neuromorphic', label: 'GitHub', external: true },
      { href: 'https://github.com/sponsors/catalyst-neuromorphic', label: 'Sponsor', external: true },
      { href: 'https://ko-fi.com/catalystneuromorphic', label: 'Ko-Fi', external: true },
    ],
  },
];
---

<footer class="border-t border-white/[0.06] mt-20">
  <div class="max-w-[1200px] mx-auto px-6 md:px-12 py-16">
    <!-- Columns -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 mb-16">
      {columns.map(col => (
        <div>
          <h4 class="text-xs font-medium text-white/30 uppercase tracking-wider mb-4">{col.title}</h4>
          <ul class="space-y-3">
            {col.links.map(link => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-white/50 no-underline hover:text-white transition-colors duration-300"
                  target={link.external ? '_blank' : undefined}
                  rel={link.external ? 'noopener noreferrer' : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 pt-8 border-t border-white/[0.04]">
      <a href="/" class="text-sm font-display font-bold tracking-tight text-white/40 no-underline hover:text-white/60 transition-colors">Catalyst</a>
      <p class="text-xs text-white/[0.2]">&copy; 2026 Catalyst Neuromorphic. All rights reserved.</p>
    </div>
  </div>
</footer>
