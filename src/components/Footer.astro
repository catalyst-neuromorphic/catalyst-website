---
const links = [
  { href: '/processors', label: 'Processors' },
  { href: '/technology', label: 'Technology' },
  { href: '/research', label: 'Research' },
  { href: '/about', label: 'About' },
  { href: 'https://github.com/Mr-wabbit/neurocore', label: 'GitHub', external: true },
  { href: 'https://ko-fi.com/catalystneuromorphic', label: 'Ko-fi', external: true },
  { href: 'mailto:henry@catalyst-neuromorphic.com', label: 'Contact' },
];
---

<footer class="py-12 px-6 md:px-12 text-center">
  <div class="flex flex-wrap justify-center gap-8 mb-5">
    {links.map(link => (
      <a
        href={link.href}
        class="text-[13px] text-white/30 no-underline hover:text-white/60 transition-colors duration-300"
        target={link.external ? '_blank' : undefined}
        rel={link.external ? 'noopener noreferrer' : undefined}
      >
        {link.label}
      </a>
    ))}
  </div>
  <p class="text-xs text-white/[0.15]">&copy; 2026 Catalyst Neuromorphic. All rights reserved.</p>
</footer>
