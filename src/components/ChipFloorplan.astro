---
interface Props {
  chip?: 'n1' | 'n2' | 'n3';
  class?: string;
  showLabels?: boolean;
}

const { chip = 'n2', class: className = '', showLabels = false } = Astro.props;
const id = chip; // unique prefix for SVG IDs

// ── Layout constants ──
const VB_W = 800, VB_H = 960;
const DIE = { x: 100, y: 60, w: 600, h: 840, rx: 8 };
const PAD = 8;
const INT = { x: DIE.x + PAD, y: DIE.y + PAD, w: DIE.w - 2 * PAD, h: DIE.h - 2 * PAD };

// Regions
const MGMT = { x: INT.x, y: INT.y, w: INT.w, h: 48 };
const GAP = 6;
const GRID_TOP = MGMT.y + MGMT.h + GAP;
const SRAM_W = 110;
const SRAM_GAP = 8;
const GRID_W = INT.w - SRAM_W - SRAM_GAP;
const GRID_H = 680;

const COLS = 8, ROWS = 16;
const CELL_W = GRID_W / COLS;
const CELL_H = GRID_H / ROWS;
const CORE_GAP = 2;
const CORE_W = CELL_W - CORE_GAP;
const CORE_H = CELL_H - CORE_GAP;

const SRAM = { x: INT.x + GRID_W + SRAM_GAP, y: GRID_TOP, w: SRAM_W, h: GRID_H };
const IO_TOP = GRID_TOP + GRID_H + GAP;
const IO = { x: INT.x, y: IO_TOP, w: INT.w, h: INT.y + INT.h - IO_TOP };

// Per-core sub-block proportions (differ by chip gen)
const isN2 = chip === 'n2';
const NEURON_H_FRAC = 0.55;
const SYNAPSE_W_FRAC = isN2 ? 0.52 : 0.68;
const LEARN_W_FRAC = isN2 ? 0.45 : 0.28;
const SUB_GAP = CORE_W * 0.03; // gap between synapse and learning blocks

// Generate core positions
const cores: Array<{x: number; y: number; w: number; h: number; row: number; col: number}> = [];
for (let r = 0; r < ROWS; r++) {
  for (let c = 0; c < COLS; c++) {
    cores.push({
      x: INT.x + c * CELL_W,
      y: GRID_TOP + r * CELL_H,
      w: CORE_W,
      h: CORE_H,
      row: r,
      col: c,
    });
  }
}

// Mesh grid lines (between cores = the spike routing network)
const meshH: Array<{y: number}> = [];
for (let r = 1; r < ROWS; r++) {
  meshH.push({ y: GRID_TOP + r * CELL_H - CORE_GAP / 2 });
}
const meshV: Array<{x: number}> = [];
for (let c = 1; c < COLS; c++) {
  meshV.push({ x: INT.x + c * CELL_W - CORE_GAP / 2 });
}

// I/O bond pads around die perimeter
const padSize = 6;
const padGap = 14;
const padsTop: Array<{x: number}> = [];
const padsBot: Array<{x: number}> = [];
const padsLeft: Array<{y: number}> = [];
const padsRight: Array<{y: number}> = [];
for (let px = DIE.x + 20; px < DIE.x + DIE.w - 20; px += padGap) {
  padsTop.push({ x: px });
  padsBot.push({ x: px });
}
for (let py = DIE.y + 20; py < DIE.y + DIE.h - 20; py += padGap) {
  padsLeft.push({ y: py });
  padsRight.push({ y: py });
}

// SRAM bank divisions
const sramBanks = 8;
const sramBankH = SRAM.h / sramBanks;

// N3 "coming soon" state
const isN3 = chip === 'n3';

// Colors
const colors = {
  neuron: isN3 ? 'rgba(255,255,255,0.04)' : 'rgba(245,158,11,0.18)',
  synapse: isN3 ? 'rgba(255,255,255,0.03)' : 'rgba(217,119,6,0.13)',
  learning: isN3 ? 'rgba(255,255,255,0.03)' : (isN2 ? 'rgba(59,130,246,0.22)' : 'rgba(59,130,246,0.12)'),
  mgmt: isN3 ? 'rgba(255,255,255,0.04)' : 'rgba(34,197,94,0.15)',
  mgmtStroke: isN3 ? 'rgba(255,255,255,0.06)' : 'rgba(34,197,94,0.25)',
  sram: isN3 ? 'rgba(255,255,255,0.03)' : 'rgba(168,85,247,0.14)',
  sramStroke: isN3 ? 'rgba(255,255,255,0.05)' : 'rgba(168,85,247,0.2)',
  sramLine: isN3 ? 'rgba(255,255,255,0.03)' : 'rgba(168,85,247,0.1)',
  io: isN3 ? 'rgba(255,255,255,0.03)' : 'rgba(100,116,139,0.12)',
  ioStroke: isN3 ? 'rgba(255,255,255,0.05)' : 'rgba(100,116,139,0.15)',
  mesh: isN3 ? 'rgba(255,255,255,0.02)' : 'rgba(245,158,11,0.06)',
  pad: isN3 ? 'rgba(255,255,255,0.03)' : 'rgba(148,163,184,0.12)',
  dieStroke: isN3 ? 'rgba(255,255,255,0.06)' : 'rgba(255,255,255,0.12)',
  glowOpacity: isN3 ? '0.15' : '0.5',
};
---

<svg viewBox={`0 0 ${VB_W} ${VB_H}`} xmlns="http://www.w3.org/2000/svg"
     class:list={[className]} role="img"
     aria-label={`Catalyst ${chip.toUpperCase()} chip floorplan`}>
  <defs>
    <!-- Gradient glow border -->
    <linearGradient id={`${id}-glow`} x1="0" y1="1" x2="1" y2="0">
      <stop offset="0%" stop-color="#f97316"/>
      <stop offset="28%" stop-color="#ec4899"/>
      <stop offset="62%" stop-color="#8b5cf6"/>
      <stop offset="100%" stop-color="#3b82f6"/>
    </linearGradient>
    <filter id={`${id}-blur`}>
      <feGaussianBlur stdDeviation="22"/>
    </filter>

    <!-- Die top highlight -->
    <linearGradient id={`${id}-shine`} x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="rgba(255,255,255,0.06)"/>
      <stop offset="15%" stop-color="rgba(255,255,255,0)"/>
    </linearGradient>

    <!-- Decorative fill patterns -->
    <pattern id={`${id}-pat-core`} width="6" height="6" patternUnits="userSpaceOnUse">
      <line x1="0" y1="2.5" x2="6" y2="2.5" stroke="rgba(255,255,255,0.06)" stroke-width="0.35"/>
    </pattern>
    <pattern id={`${id}-pat-sram`} width="4" height="4" patternUnits="userSpaceOnUse">
      <rect x="0.3" y="0.3" width="3" height="3" fill="none" stroke="rgba(255,255,255,0.04)" stroke-width="0.25" rx="0.2"/>
    </pattern>
    <pattern id={`${id}-pat-mgmt`} width="7" height="7" patternUnits="userSpaceOnUse">
      <line x1="0" y1="0" x2="7" y2="7" stroke="rgba(255,255,255,0.045)" stroke-width="0.3"/>
      <line x1="7" y1="0" x2="0" y2="7" stroke="rgba(255,255,255,0.045)" stroke-width="0.3"/>
    </pattern>
    <pattern id={`${id}-pat-io`} width="5" height="5" patternUnits="userSpaceOnUse">
      <line x1="2.5" y1="0" x2="2.5" y2="5" stroke="rgba(255,255,255,0.035)" stroke-width="0.3"/>
    </pattern>
  </defs>

  <!-- ═══ GLOW BORDER ═══ -->
  <rect x={DIE.x - 12} y={DIE.y - 12} width={DIE.w + 24} height={DIE.h + 24} rx="18"
        fill="none" stroke={`url(#${id}-glow)`} stroke-width="16"
        filter={`url(#${id}-blur)`} opacity={colors.glowOpacity}/>

  <!-- ═══ DIE BODY ═══ -->
  <rect x={DIE.x} y={DIE.y} width={DIE.w} height={DIE.h} rx={DIE.rx}
        fill="#08090d" stroke={colors.dieStroke} stroke-width="1"/>
  <!-- Top shine -->
  <rect x={DIE.x} y={DIE.y} width={DIE.w} height={DIE.h} rx={DIE.rx}
        fill={`url(#${id}-shine)`}/>

  <!-- ═══ I/O BOND PADS ═══ -->
  <g data-region="pads" opacity="0.8">
    {padsTop.map(p => (
      <rect x={p.x} y={DIE.y + 4} width={padSize} height={3} rx="0.5" fill={colors.pad}/>
    ))}
    {padsBot.map(p => (
      <rect x={p.x} y={DIE.y + DIE.h - 7} width={padSize} height={3} rx="0.5" fill={colors.pad}/>
    ))}
    {padsLeft.map(p => (
      <rect x={DIE.x + 4} y={p.y} width={3} height={padSize} rx="0.5" fill={colors.pad}/>
    ))}
    {padsRight.map(p => (
      <rect x={DIE.x + DIE.w - 7} y={p.y} width={3} height={padSize} rx="0.5" fill={colors.pad}/>
    ))}
  </g>

  <!-- ═══ MANAGEMENT CORE ═══ -->
  <g data-region="management">
    <rect x={MGMT.x} y={MGMT.y} width={MGMT.w} height={MGMT.h} rx="3"
          fill={colors.mgmt}/>
    <rect x={MGMT.x} y={MGMT.y} width={MGMT.w} height={MGMT.h} rx="3"
          fill={`url(#${id}-pat-mgmt)`}/>
    <rect x={MGMT.x} y={MGMT.y} width={MGMT.w} height={MGMT.h} rx="3"
          fill="none" stroke={colors.mgmtStroke} stroke-width="0.5"/>
    <!-- Sub-divisions -->
    <line x1={MGMT.x + MGMT.w * 0.25} y1={MGMT.y + 4}
          x2={MGMT.x + MGMT.w * 0.25} y2={MGMT.y + MGMT.h - 4}
          stroke={colors.mgmtStroke} stroke-width="0.3" opacity="0.6"/>
    <line x1={MGMT.x + MGMT.w * 0.55} y1={MGMT.y + 4}
          x2={MGMT.x + MGMT.w * 0.55} y2={MGMT.y + MGMT.h - 4}
          stroke={colors.mgmtStroke} stroke-width="0.3" opacity="0.6"/>
    {showLabels && (
      <text x={MGMT.x + MGMT.w * 0.125} y={MGMT.y + MGMT.h / 2 + 3}
            text-anchor="middle" fill="rgba(34,197,94,0.5)"
            font-family="'Space Grotesk',system-ui" font-size="7" font-weight="500">RISC-V</text>
    )}
    {showLabels && (
      <text x={MGMT.x + MGMT.w * 0.4} y={MGMT.y + MGMT.h / 2 + 3}
            text-anchor="middle" fill="rgba(34,197,94,0.5)"
            font-family="'Space Grotesk',system-ui" font-size="7" font-weight="500">CONFIG</text>
    )}
    {showLabels && (
      <text x={MGMT.x + MGMT.w * 0.775} y={MGMT.y + MGMT.h / 2 + 3}
            text-anchor="middle" fill="rgba(34,197,94,0.5)"
            font-family="'Space Grotesk',system-ui" font-size="7" font-weight="500">HOST I/F</text>
    )}
  </g>

  <!-- ═══ MESH INTERCONNECT (grid lines between cores) ═══ -->
  <g data-region="mesh" opacity="0.8">
    {meshH.map(line => (
      <line x1={INT.x} x2={INT.x + GRID_W}
            y1={line.y} y2={line.y}
            stroke={colors.mesh} stroke-width="0.8"/>
    ))}
    {meshV.map(line => (
      <line x1={line.x} x2={line.x}
            y1={GRID_TOP} y2={GRID_TOP + GRID_H}
            stroke={colors.mesh} stroke-width="0.8"/>
    ))}
  </g>

  <!-- ═══ CORE GRID (128 neuromorphic cores) ═══ -->
  <g data-region="cores">
    {cores.map(core => {
      const neuronH = core.h * NEURON_H_FRAC;
      const bottomY = core.y + neuronH + 1;
      const bottomH = core.h - neuronH - 1;
      const synapseW = core.w * SYNAPSE_W_FRAC;
      const learnX = core.x + synapseW + SUB_GAP;
      const learnW = core.w - synapseW - SUB_GAP;
      return (
        <g>
          {/* Neuron array (top) */}
          <rect x={core.x} y={core.y} width={core.w} height={neuronH} rx="1.5"
                fill={colors.neuron}/>
          {/* Synapse memory (bottom-left) */}
          <rect x={core.x} y={bottomY} width={synapseW} height={bottomH} rx="1"
                fill={colors.synapse}/>
          {/* Learning engine (bottom-right) */}
          <rect x={learnX} y={bottomY} width={learnW} height={bottomH} rx="1"
                fill={colors.learning}/>
          {/* Pattern overlay */}
          <rect x={core.x} y={core.y} width={core.w} height={core.h} rx="1.5"
                fill={`url(#${id}-pat-core)`}/>
        </g>
      );
    })}
  </g>

  <!-- ═══ SRAM BANKS ═══ -->
  <g data-region="sram">
    <rect x={SRAM.x} y={SRAM.y} width={SRAM.w} height={SRAM.h} rx="3"
          fill={colors.sram}/>
    <rect x={SRAM.x} y={SRAM.y} width={SRAM.w} height={SRAM.h} rx="3"
          fill={`url(#${id}-pat-sram)`}/>
    <rect x={SRAM.x} y={SRAM.y} width={SRAM.w} height={SRAM.h} rx="3"
          fill="none" stroke={colors.sramStroke} stroke-width="0.5"/>
    {/* Bank division lines */}
    {Array.from({ length: sramBanks - 1 }).map((_, i) => (
      <line x1={SRAM.x + 4} x2={SRAM.x + SRAM.w - 4}
            y1={SRAM.y + (i + 1) * sramBankH}
            y2={SRAM.y + (i + 1) * sramBankH}
            stroke={colors.sramLine} stroke-width="0.4"/>
    ))}
    {showLabels && (
      <text x={SRAM.x + SRAM.w / 2} y={SRAM.y + SRAM.h / 2 + 3}
            text-anchor="middle" fill="rgba(168,85,247,0.4)"
            font-family="'Space Grotesk',system-ui" font-size="8" font-weight="500"
            writing-mode="tb">SRAM</text>
    )}
  </g>

  <!-- ═══ I/O INTERFACE ═══ -->
  <g data-region="io">
    <rect x={IO.x} y={IO.y} width={IO.w} height={IO.h} rx="3"
          fill={colors.io}/>
    <rect x={IO.x} y={IO.y} width={IO.w} height={IO.h} rx="3"
          fill={`url(#${id}-pat-io)`}/>
    <rect x={IO.x} y={IO.y} width={IO.w} height={IO.h} rx="3"
          fill="none" stroke={colors.ioStroke} stroke-width="0.5"/>
    {/* I/O sub-divisions */}
    <line x1={IO.x + IO.w * 0.33} y1={IO.y + 4}
          x2={IO.x + IO.w * 0.33} y2={IO.y + IO.h - 4}
          stroke={colors.ioStroke} stroke-width="0.3" opacity="0.5"/>
    <line x1={IO.x + IO.w * 0.66} y1={IO.y + 4}
          x2={IO.x + IO.w * 0.66} y2={IO.y + IO.h - 4}
          stroke={colors.ioStroke} stroke-width="0.3" opacity="0.5"/>
    {showLabels && (
      <text x={IO.x + IO.w * 0.165} y={IO.y + IO.h / 2 + 3}
            text-anchor="middle" fill="rgba(100,116,139,0.4)"
            font-family="'Space Grotesk',system-ui" font-size="7" font-weight="500">SPIKE IN</text>
    )}
    {showLabels && (
      <text x={IO.x + IO.w * 0.5} y={IO.y + IO.h / 2 + 3}
            text-anchor="middle" fill="rgba(100,116,139,0.4)"
            font-family="'Space Grotesk',system-ui" font-size="7" font-weight="500">MESH I/F</text>
    )}
    {showLabels && (
      <text x={IO.x + IO.w * 0.83} y={IO.y + IO.h / 2 + 3}
            text-anchor="middle" fill="rgba(100,116,139,0.4)"
            font-family="'Space Grotesk',system-ui" font-size="7" font-weight="500">SPIKE OUT</text>
    )}
  </g>

  <!-- ═══ CHIP LABEL ═══ -->
  <text x={DIE.x + DIE.w / 2} y={DIE.y + DIE.h - 14}
        text-anchor="middle" fill="rgba(255,255,255,0.06)"
        font-family="'Space Grotesk',system-ui" font-size="13" font-weight="600"
        letter-spacing="0.12em">
    CATALYST {chip.toUpperCase()}
  </text>

  {/* N3 "Coming Soon" overlay */}
  {isN3 && (
    <g>
      <rect x={DIE.x} y={DIE.y} width={DIE.w} height={DIE.h} rx={DIE.rx}
            fill="rgba(5,5,7,0.5)"/>
      <text x={DIE.x + DIE.w / 2} y={DIE.y + DIE.h / 2 - 10}
            text-anchor="middle" fill="rgba(255,255,255,0.15)"
            font-family="'Space Grotesk',system-ui" font-size="64" font-weight="700"
            letter-spacing="-0.02em">N3</text>
      <text x={DIE.x + DIE.w / 2} y={DIE.y + DIE.h / 2 + 25}
            text-anchor="middle" fill="rgba(255,255,255,0.08)"
            font-family="'Plus Jakarta Sans','Space Grotesk',system-ui" font-size="14" font-weight="500"
            letter-spacing="0.15em" text-transform="uppercase">COMING SOON</text>
    </g>
  )}
</svg>
