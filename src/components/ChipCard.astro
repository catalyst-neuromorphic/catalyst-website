---
interface Props {
  name: string;
  generation: string;
  tagline: string;
  stats: { label: string; value: string }[];
  href: string;
  accent?: boolean;
  latest?: boolean;
}

const { name, generation, tagline, stats, href, accent = false, latest = false } = Astro.props;
---

<a href={href} class:list={[
  'block p-10 transition-all duration-500 hover:-translate-y-1 no-underline group',
  accent ? 'glass-accent' : 'glass'
]}>
  {latest && (
    <span class="inline-flex items-center text-[11px] uppercase tracking-widest text-catalyst-blue/80 mb-3">
      <span class="inline-block w-1.5 h-1.5 rounded-full bg-catalyst-blue mr-2 animate-pulse"></span>
      Latest
    </span>
  )}
  <p class="text-[11px] uppercase tracking-widest text-white/30 mb-2">{generation}</p>
  <h3 class="text-2xl md:text-3xl font-bold tracking-tight mb-2">{name}</h3>
  <p class="text-sm text-white/40 mb-6">{tagline}</p>

  <!-- Chip placeholder image area -->
  <div class="w-full h-40 rounded-2xl mb-6 flex items-center justify-center" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04);">
    <span class="text-white/10 text-sm">Chip image</span>
  </div>

  <div class="grid grid-cols-2 gap-4 mb-6">
    {stats.map(stat => (
      <div>
        <div class="text-lg font-bold">{stat.value}</div>
        <div class="text-[11px] uppercase tracking-wider text-white/30">{stat.label}</div>
      </div>
    ))}
  </div>

  <span class="text-sm text-white/50 group-hover:text-white transition-colors">Learn more &rarr;</span>
</a>
