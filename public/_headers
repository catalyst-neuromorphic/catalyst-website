/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  X-XSS-Protection: 0
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  # SHA-256 hashes for inline scripts that cannot be externalized:
  #   sha256-mHbvPrXUG06xYIqUCj6XMz6uaJGLsniNehYq9faMvYo= = importmap (local three.js)
  #   sha256-eIXWvAmxkr251LJZkjniEK5LcPF3NkapbJepohwYRIc= = Astro island hydration bootstrap
  #   sha256-U7a72oKuFFz8D7GUHLA1NZ0ciymHmDOc9T9aVDg2rWU= = Astro island hydration runtime
  Content-Security-Policy: default-src 'self'; script-src 'self' 'sha256-mHbvPrXUG06xYIqUCj6XMz6uaJGLsniNehYq9faMvYo=' 'sha256-eIXWvAmxkr251LJZkjniEK5LcPF3NkapbJepohwYRIc=' 'sha256-U7a72oKuFFz8D7GUHLA1NZ0ciymHmDOc9T9aVDg2rWU='; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https:; connect-src 'self' https://api.catalyst-neuromorphic.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

/papers/*
  Content-Disposition: inline

/*.pdf
  Content-Disposition: inline
